          </div>
        </div>
      </div>
      
      <!-- Edit Customer Modal -->
      <div class="modal-overlay" id="editCustomerModal">
        <div class="modal">
          <div class="modal-header"><div class="modal-title"><i class="fa-solid fa-pen"></i> Edit Customer</div><button class="modal-close" onclick="closeModal('editCustomerModal')">&times;</button></div>
          <div class="modal-body">
            <input type="hidden" id="editRowId">
            <div class="form-group"><label class="form-label">Seat</label><input class="form-control" id="editSeat" type="text"></div>
            <div class="form-row"><div class="form-group"><label class="form-label">First Name</label><input class="form-control" id="editFirstName" type="text"></div><div class="form-group"><label class="form-label">Last Name</label><input class="form-control" id="editLastName" type="text"></div></div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-control" id="editEmail" type="email"></div>
            <div class="form-group"><label class="form-label">RFID UID</label><input class="form-control" id="editRfid" type="text"></div>
            <div class="form-group"><label class="form-label">MAC Address</label><input class="form-control" id="editMac" type="text"></div>
            <div class="form-group"><label class="form-label">Status</label><select class="form-control" id="editStatus"><option value="Active">Active</option><option value="Idle">Idle</option><option value="Inactive">Inactive</option></select></div>
          </div>
          <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('editCustomerModal')">Cancel</button><button class="btn btn-primary" onclick="saveCustomerEdit()">Save Changes</button></div>
        </div>
      </div>
      
      <!-- Edit Walk-in Modal -->
      <div class="modal-overlay" id="editWalkinModal">
        <div class="modal">
          <div class="modal-header"><div class="modal-title"><i class="fa-solid fa-pen"></i> Edit Walk-in</div><button class="modal-close" onclick="closeModal('editWalkinModal')">&times;</button></div>
          <div class="modal-body">
            <input type="hidden" id="editWalkinRowId">
            <div class="form-group"><label class="form-label">Seat</label><input class="form-control" id="editWalkinSeat" type="text"></div>
            <div class="form-row"><div class="form-group"><label class="form-label">First Name</label><input class="form-control" id="editWalkinFirstName" type="text"></div><div class="form-group"><label class="form-label">Last Name</label><input class="form-control" id="editWalkinLastName" type="text"></div></div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-control" id="editWalkinEmail" type="email"></div>
            <div class="form-group"><label class="form-label">MAC Address</label><input class="form-control" id="editWalkinMac" type="text"></div>
            <div class="form-group"><label class="form-label">WiFi Hours</label><input class="form-control" id="editWalkinWifiHours" type="number" step="0.5"></div>
            <div class="form-group"><label class="form-label">Status</label><select class="form-control" id="editWalkinStatus"><option value="Active">Active</option><option value="Idle">Idle</option><option value="Inactive">Inactive</option></select></div>
          </div>
          <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('editWalkinModal')">Cancel</button><button class="btn btn-primary" onclick="saveWalkinEdit()">Save Changes</button></div>
        </div>
      </div>
      
      <!-- Session Time Edit Modal -->
      <div class="modal-overlay" id="wifiEditModal">
        <div class="modal">
          <div class="modal-header"><div class="modal-title"><i class="fa-solid fa-clock"></i> Extend Session Time</div><button class="modal-close" onclick="closeModal('wifiEditModal')">&times;</button></div>
          <div class="modal-body">
            <input type="hidden" id="wifiCustomerId">
            <div class="form-group"><label class="form-label">Customer Name</label><input class="form-control" id="wifiCustomerName" type="text" readonly disabled></div>
            <div class="form-group"><label class="form-label">Current Session Ends</label><input class="form-control" id="wifiCurrentHours" type="text" readonly disabled></div>
            <div class="form-group">
                <label class="form-label">Add Minutes</label>
                <select class="form-control" id="wifiAddMinutes">
                    <option value="30">30 minutes</option>
                    <option value="60">1 hour</option>
                    <option value="90">1 hour 30 mins</option>
                    <option value="120">2 hours</option>
                    <option value="180">3 hours</option>
                </select>
            </div>
          </div>
          <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('wifiEditModal')">Cancel</button><button class="btn btn-primary" onclick="updateWifiHours()">Extend Session</button></div>
        </div>
      </div>
      
      <!-- Customer Details Modal -->
      <div class="modal-overlay" id="viewCustModal">
        <div class="modal">
          <div class="modal-header"><div class="modal-title"><i class="fa-solid fa-user"></i> Customer Details</div><button class="modal-close" onclick="closeModal('viewCustModal')">&times;</button></div>
          <div class="modal-body" id="viewCustBody"></div>
          <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('viewCustModal')">Close</button></div>
        </div>
      </div>
    </main>
  </div>

<script>
    const rows = ['A', 'B', 'C', 'D'];
    const seatsPerRow = 7;
    let occupiedSeats = []; // Will be fetched later
    let selectedSeatForWalkin = null;
    let currentMacCount = 1;

    document.addEventListener('DOMContentLoaded', () => {
      loadRealUsers();
      renderPendingTable();
    });

    async function loadRealUsers() {
      try {
        // Load All Customers (role=customer)
        const resMem = await fetch('/api/users?role=customer');
        const dataMem = await resMem.json();
        const allCustomers = dataMem.users || [];
        
        // Load Active Sessions (for time info)
        const resAct = await fetch('/api/active-customers');
        const dataAct = await resAct.json();
        const activeSessions = dataAct.customers || [];
        
        const memberBody = document.getElementById('custBody');
        const walkinBody = document.getElementById('walkinsBody');
        memberBody.innerHTML = '';
        walkinBody.innerHTML = '';
        
        allCustomers.forEach(user => {
          const session = activeSessions.find(s => s.id === user.id);
          const endTime = session ? new Date(session.end_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : 'No active session';
          
          const tr = document.createElement('tr');
          tr.setAttribute('data-type', user.type === 'member' ? 'Member' : 'Walk-in');
          tr.setAttribute('data-status', session ? 'Active' : 'Inactive');
          
          tr.innerHTML = `
            <td>${session?.seat_label || '—'}</td>
            <td class="td-bold">${escapeHtml(user.first_name)} ${escapeHtml(user.last_name)}</td>
            <td>${escapeHtml(user.email)}</td>
            <td>${user.type === 'member' ? 'Member' : 'Walk-in'}</td>
            <td>—</td>
            <td class="wifi-cell">
                ${endTime} 
                ${session ? `<button class="wifi-edit-btn" onclick="openWifiEditModal(this, '${user.first_name} ${user.last_name}', '${endTime}', ${user.id})"><i class="fa-solid fa-pen"></i></button>` : ''}
            </td>
            <td>${session?.mac_address || '—'}</td>
            <td><span class="badge badge-${session ? 'green' : 'red'}">${session ? 'Active' : 'Inactive'}</span></td>
            <td>
              <div style="display:flex;gap:5px">
                <button class="btn btn-ghost btn-sm" title="View"><i class="fa-solid fa-eye"></i></button>
                <button class="btn btn-ghost btn-sm" title="Edit"><i class="fa-solid fa-pen"></i></button>
                <button class="btn btn-danger btn-sm" onclick="removeUser(${user.id})" title="Delete"><i class="fa-solid fa-trash"></i></button>
              </div>
            </td>
          `;
          
          if (user.type === 'walkin') {
            walkinBody.appendChild(tr);
          } else {
            memberBody.appendChild(tr);
          }
        });

      } catch (err) { console.error(err); }
    }

    function openWifiEditModal(btn, name, currentEndTime, id) {
        document.getElementById('wifiCustomerName').value = name;
        document.getElementById('wifiCurrentHours').value = currentEndTime;
        document.getElementById('wifiCustomerId').value = id;
        openModal('wifiEditModal');
    }

    async function updateWifiHours() {
        const id = document.getElementById('wifiCustomerId').value;
        const minutes = document.getElementById('wifiAddMinutes').value;
        
        try {
            const res = await fetch('/api/session/extend', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: id, minutes: parseInt(minutes) })
            });
            const data = await res.json();
            if (data.success) {
                toast("Session extended!", "success");
                closeModal('wifiEditModal');
                loadRealUsers();
            } else {
                alert("Failed to extend session.");
            }
        } catch (err) {
            console.error(err);
        }
    }

    async function renderPendingTable() {
      const tbody = document.getElementById('pendingBody');
      const badge = document.getElementById('pendingBadge');
      try {
        const res = await fetch('/api/users?status=pending');
        const data = await res.json();
        const pending = data.users || [];

        tbody.innerHTML = '';
        if (pending.length === 0) {
          tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:40px; color:#94a3b8;">No pending registrations.</td></tr>';
          badge.style.display = 'none';
          return;
        }

        badge.textContent = pending.length;
        badge.style.display = 'inline';

        pending.forEach(req => {
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td>${new Date(req.created_at).toLocaleDateString()}</td>
            <td class="td-bold">${escapeHtml(req.first_name)} ${escapeHtml(req.last_name)}</td>
            <td>${escapeHtml(req.email)}</td>
            <td><span class="badge badge-orange">Pending</span></td>
            <td>
              <div style="display:flex;gap:5px">
                <button class="btn btn-primary btn-sm" style="background:#059669" onclick="approvePending(${req.id})">Approve</button>
                <button class="btn btn-danger btn-sm" onclick="removeUser(${req.id}, 'Application rejected')">Reject</button>
              </div>
            </td>
          `;
          tbody.appendChild(tr);
        });
      } catch (err) { console.error(err); }
    }

    async function approvePending(id) {
      if(!confirm("Approve this user?")) return;
      try {
        const res = await fetch(`/api/users/approve/${id}`, { method: 'POST' });
        if((await res.json()).success) {
          toast("User approved!", "success");
          renderPendingTable();
          loadRealUsers();
        }
      } catch (err) { console.error(err); }
    }

    async function removeUser(id, msg = "User removed") {
      if(!confirm("Are you sure?")) return;
      try {
        const res = await fetch(`/api/users/${id}`, { method: 'DELETE' });
        if((await res.json()).success) {
          toast(msg, "info");
          loadRealUsers();
          renderPendingTable();
        }
      } catch (err) { console.error(err); }
    }

    async function addWalkin() {
      const email = document.getElementById('wi-email').value.trim();
      const firstName = document.getElementById('wi-firstname').value.trim();
      const lastName = document.getElementById('wi-lastname').value.trim();
      if (!firstName || !lastName || !email) { alert("Required fields missing."); return; }
      try {
        const res = await fetch('/api/users/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ firstName, lastName, email, role: 'customer', type: 'walkin' })
        });
        if((await res.json()).success) {
          toast("Customer added!", "success");
          closeModal('addWalkinModal');
          loadRealUsers();
        }
      } catch (err) { console.error(err); }
    }

    function renderModalSeatLayout() {
      const container = document.getElementById('modalSeatLayout');
      if(!container) return;
      let html = '<div class="modal-seat-grid">';
      for (let r of rows) {
        html += `<div class="modal-seat-row"><div class="modal-row-label">${r}</div><div class="modal-seats">`;
        for (let i = 1; i <= seatsPerRow; i++) {
          const seatId = `${r}${i}`;
          html += `<div class="modal-seat available" data-seat="${seatId}"><span>${seatId}</span><span>Free</span></div>`;
        }
        html += `</div></div>`;
      }
      html += '</div>';
      container.innerHTML = html;
      document.querySelectorAll('.modal-seat.available').forEach(el => {
        el.onclick = () => {
          document.querySelectorAll('.modal-seat').forEach(s => s.classList.remove('selected'));
          el.classList.add('selected');
          selectedSeatForWalkin = el.dataset.seat;
          document.getElementById('selectedSeatDisplay').innerHTML = `Selected: <strong>${selectedSeatForWalkin}</strong>`;
        };
      });
    }

    function addNewMacField() {
      if (currentMacCount >= 3) return;
      const container = document.getElementById('macFieldsContainer');
      const div = document.createElement('div');
      div.className = 'mac-input-group';
      div.innerHTML = `<input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" onclick="this.parentElement.remove(); currentMacCount--;"><i class="fa-solid fa-minus"></i></button>`;
      container.appendChild(div);
      currentMacCount++;
    }

    function switchTab(event, id) { 
      document.querySelectorAll('.tab-panel, .tab-btn').forEach(el => el.classList.remove('active')); 
      document.getElementById(id).classList.add('active'); 
      event.currentTarget.classList.add('active'); 
      if (id === 'tab-pending') renderPendingTable();
    }

    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    function openAddWalkinModal() { renderModalSeatLayout(); openModal('addWalkinModal'); }
    function openSidebar() { document.getElementById('sidebar').classList.add('mobile-open'); document.getElementById('mobileOverlay').classList.add('show'); }
    function closeSidebar() { document.getElementById('sidebar').classList.remove('mobile-open'); document.getElementById('mobileOverlay').classList.remove('show'); }
    function escapeHtml(s) { return s ? String(s).replace(/[&<>]/g, m => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;' }[m])) : ''; }
    function toast(m, t) {
      const el = document.createElement('div');
      el.style.cssText = `position:fixed;bottom:20px;right:20px;background:${t==='success'?'#059669':'#1e293b'};color:white;padding:10px 20px;border-radius:8px;z-index:9999;`;
      el.textContent = m;
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 2500);
    }
    document.getElementById('addMacBtn')?.addEventListener('click', addNewMacField);
</script>

