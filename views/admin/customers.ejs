            </div>
            <div class="form-group"><label class="form-label">Status</label><select class="form-control" id="wi-status"><option value="active">Active</option><option value="inactive">Inactive</option></select></div>
            <div class="form-group"><label class="form-label">Assign Seat * (Click on seat below)</label>
