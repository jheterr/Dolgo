<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Customers List' %>

<%- contentFor('style') %>
<style>

  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;z-index:1000;padding:16px;}
  .modal-overlay.open{display:flex;}
  .modal{background:var(--white);border-radius:var(--radius);padding:28px;width:100%;max-width:500px;box-shadow:0 20px 60px rgba(0,0,0,.2);display:flex;flex-direction:column;gap:16px;max-height:90vh;overflow-y:auto;}
  .modal-header{display:flex;align-items:center;justify-content:space-between;}
  .modal-title{font-family:'Poppins',sans-serif;font-size:1rem;font-weight:700;}
  .modal-close{background:none;border:none;font-size:1.3rem;color:var(--text-sm);cursor:pointer;}
  .modal-body{display:flex;flex-direction:column;gap:14px;}
  .modal-footer{display:flex;justify-content:flex-end;gap:10px;}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .form-group{display:flex;flex-direction:column;gap:5px;}
  .form-label{font-size:12px;font-weight:600;color:#475569;}
  .form-control{padding:8px 12px;border:1px solid #cbd5e1;border-radius:6px;font-size:13px;}
  .search-bar{position:relative;width:230px;}
  .search-bar input{padding-left:34px;border-radius:20px;}
  .search-bar i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-sm);font-size:11px;}
  .btn-sm{padding:5px 10px;font-size:11px;}
  .wifi-edit-btn{background:none;border:none;cursor:pointer;color:var(--orange);margin-left:5px;font-size:11px;transition:0.2s;}
  .wifi-edit-btn:hover{color:#b85520;transform:scale(1.1);}
  .page-header-actions{display:flex;gap:12px;align-items:center;flex-wrap:wrap;}
  .btn-add-walkin{background:#8A8636;color:white;border:none;padding:8px 16px;border-radius:8px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:8px;font-size:13px;}
  .btn-add-walkin:hover{background:#726f2c;}

  /* Filter dropdown styles */
  .filter-group {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .filter-dropdown {
    padding: 6px 14px;
    border-radius: 30px;
    border: 1px solid #cbd5e1;
    background: white;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    outline: none;
    transition: all 0.2s;
  }
  .filter-dropdown:hover {
    border-color: #CF6322;
  }
  .filter-dropdown:focus {
    border-color: #CF6322;
    box-shadow: 0 0 0 2px rgba(207,99,34,0.1);
  }
  .card-header-with-filter {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .section-title {
    font-size: 0.88rem;
    font-weight: 700;
    margin-bottom: 0;
  }

  /* MAC Address fields */
  .mac-fields-container {
    background: #f8fafc;
    padding: 12px;
    border-radius: 20px;
    margin: 8px 0;
  }
  .mac-input-group {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
    align-items: center;
  }
  .mac-input-group input { flex: 1; margin: 0; }
  .remove-mac-btn {
    background: #fee2e2;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 30px;
    cursor: pointer;
    color: #b91c1c;
  }
  .add-mac-btn {
    background: #f1f5f9;
    border: none;
    padding: 8px 16px;
    border-radius: 30px;
    font-size: 0.7rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
  }

  /* RFID Scan group */
  .rfid-input-group {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .btn-scan {
    background: #4A7C59;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }
  .btn-scan:hover {
    background: #3d6a4a;
  }

  /* Seat Layout inside Modal */
  .modal-seat-layout {
    background: #f8fafc;
    border-radius: 20px;
    padding: 16px;
    margin: 12px 0;
  }
  .modal-seat-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .modal-seat-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .modal-row-label {
    width: 32px;
    font-weight: 800;
    background: #e2e8f0;
    border-radius: 20px;
    text-align: center;
    padding: 4px 0;
    font-size: 0.8rem;
  }
  .modal-seats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .modal-seat {
    width: 50px;
    height: 50px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    font-size: 0.65rem;
    font-weight: 600;
    cursor: pointer;
    transition: 0.1s;
    border: 2px solid;
  }
  
  .modal-seat span:first-child { font-size: 0.7rem; font-weight: 800; }
  .modal-seat.available { background: #dcfce7; border-color: #86efac; color: #166534; }
  .modal-seat.occupied { background: #fee2e2; border-color: #fecaca; color: #991b1b; cursor: not-allowed; opacity: 0.7; }
  .modal-seat.reserved { background: #fef9c3; border-color: #fde047; color: #854d0e; cursor: not-allowed; opacity: 0.7; }
  .modal-seat.idle { background: #fed7aa; border-color: #fdba74; color: #9a3412; cursor: not-allowed; opacity: 0.7; }
  .modal-seat.selected { background: #4f46e5; border-color: #4f46e5; color: white; }
  .legend {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 12px;
    font-size: 0.65rem;
  }
  .legend span { display: inline-flex; align-items: center; gap: 4px; }

  @media (max-width: 768px) {
    .page-header-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .search-bar {
      width: 100%;
    }
    .card-header-with-filter {
      flex-direction: column;
      align-items: stretch;
    }
    .filter-group {
      justify-content: space-between;
    }
    .modal-seat { width: 40px; height: 40px; font-size: 0.55rem; }
    .rfid-input-group { flex-direction: column; }
    .btn-scan { width: 100%; }
  }
    
</style>

