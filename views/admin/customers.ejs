<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Customers List' %>

<%- contentFor('style') %>
<style>

  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;z-index:1000;padding:16px;}
  .modal-overlay.open{display:flex;}
  .modal{background:var(--white);border-radius:var(--radius);padding:28px;width:100%;max-width:500px;box-shadow:0 20px 60px rgba(0,0,0,.2);display:flex;flex-direction:column;gap:16px;max-height:90vh;overflow-y:auto;}
  .modal-header{display:flex;align-items:center;justify-content:space-between;}
  .modal-title{font-family:'Poppins',sans-serif;font-size:1rem;font-weight:700;}
  .modal-close{background:none;border:none;font-size:1.3rem;color:var(--text-sm);cursor:pointer;}
  .modal-body{display:flex;flex-direction:column;gap:14px;}
  .modal-footer{display:flex;justify-content:flex-end;gap:10px;}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .form-group{display:flex;flex-direction:column;gap:5px;}
  .form-label{font-size:12px;font-weight:600;color:#475569;}
  .form-control{padding:8px 12px;border:1px solid #cbd5e1;border-radius:6px;font-size:13px;}
  .search-bar{position:relative;width:230px;}
  .search-bar input{padding-left:34px;border-radius:20px;}
  .search-bar i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-sm);font-size:11px;}
  .btn-sm{padding:5px 10px;font-size:11px;}
  .wifi-edit-btn{background:none;border:none;cursor:pointer;color:var(--orange);margin-left:5px;font-size:11px;transition:0.2s;}
  .wifi-edit-btn:hover{color:#b85520;transform:scale(1.1);}
  .page-header-actions{display:flex;gap:12px;align-items:center;flex-wrap:wrap;}
  .btn-add-walkin{background:#8A8636;color:white;border:none;padding:8px 16px;border-radius:8px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:8px;font-size:13px;transition: 0.2s;}
  .btn-add-walkin:hover{background:#726f2c;transform: translateY(-2px);}
  .btn-add-member{background:#CF6322;color:white;border:none;padding:8px 16px;border-radius:8px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:8px;font-size:13px;transition: 0.2s;}
  .btn-add-member:hover{background:#b85520;transform: translateY(-2px);}
  .btn-upgrade{background:#4A7C59;color:white;border:none;padding:5px 10px;border-radius:6px;font-size:10px;font-weight:700;cursor:pointer;transition:0.2s;}
  .btn-upgrade:hover{background:#3d6a4a;transform:scale(1.05);}

  /* Filter dropdown styles */
  .filter-group {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .filter-dropdown {
    padding: 6px 14px;
    border-radius: 30px;
    border: 1px solid #cbd5e1;
    background: white;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    outline: none;
    transition: all 0.2s;
  }
  .filter-dropdown:hover {
    border-color: #CF6322;
  }
  .filter-dropdown:focus {
    border-color: #CF6322;
    box-shadow: 0 0 0 2px rgba(207,99,34,0.1);
  }
  .card-header-with-filter {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .section-title {
    font-size: 0.88rem;
    font-weight: 700;
    margin-bottom: 0;
  }

  /* MAC Address fields */
  .mac-fields-container {
    background: #f8fafc;
    padding: 12px;
    border-radius: 20px;
    margin: 8px 0;
  }
  .mac-input-group {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
    align-items: center;
  }
  .mac-input-group input { flex: 1; margin: 0; }
  .remove-mac-btn {
    background: #fee2e2;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 30px;
    cursor: pointer;
    color: #b91c1c;
  }
  .add-mac-btn {
    background: #f1f5f9;
    border: none;
    padding: 8px 16px;
    border-radius: 30px;
    font-size: 0.7rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
  }

  /* RFID Scan group */
  .rfid-input-group {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .btn-scan {
    background: #4A7C59;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }
  .btn-scan:hover {
    background: #3d6a4a;
  }

  /* Seat Layout inside Modal (Visual) */
  .modal-seat-layout {
    background: #f8fafc;
    border-radius: 12px;
    padding: 10px;
    margin: 12px 0;
    height: 300px;
    overflow: hidden;
    position: relative;
    border: 1.5px solid #e2e8f0;
  }
  #modalSeatMap {
    position: absolute;
    width: 800px;
    height: 450px;
    transform-origin: 0 0;
    cursor: crosshair;
  }
  .modal-seat-layout .fp-item {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .modal-seat-layout .item-visual {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .modal-seat-layout .chair-icon {
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }
  .modal-seat-layout .item-label {
    position: absolute;
    top: calc(100% + 2px);
    left: 50%;
    transform: translateX(-50%);
    font-size: 8px;
    font-weight: 700;
    color: #475569;
    white-space: nowrap;
    pointer-events: none;
  }
  .modal-seat-layout .item-label.center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 9px;
  }
  .modal-seat-layout .fp-item.selected .item-visual {
    box-shadow: 0 0 0 3px #4f46e5;
    border-radius: 4px;
    transform: scale(1.1);
  }
  .modal-seat-layout .fp-item.selected .item-visual.chair-icon {
    box-shadow: none;
    filter: drop-shadow(0 0 3px #4f46e5);
  }
  
  .legend {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 12px;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .legend-item { display: inline-flex; align-items: center; gap: 4px; }
  .legend-dot { width: 10px; height: 10px; border-radius: 50%; }

  @media (max-width: 768px) {
    .page-header-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .search-bar {
      width: 100%;
    }
    .card-header-with-filter {
      flex-direction: column;
      align-items: stretch;
    }
    .filter-group {
      justify-content: space-between;
    }
    .modal-seat-layout { height: 200px; }
    .rfid-input-group { flex-direction: column; }
    .btn-scan { width: 100%; }
  }
    
</style>

<div class="app">
    <%- include('../partials/admin_sidebar', { active: 'Customers' }) %>
    
    <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>
    
    <main class="content">
      <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>

      <div class="page-header">
        <h1 class="page-title">Customers List</h1>
        <div class="page-header-actions">
          <button class="btn-add-member" onclick="openAddUserModal('member')"><i class="fa-solid fa-user-plus"></i> Add Member</button>
          <button class="btn-add-walkin" onclick="openAddUserModal('walkin')"><i class="fa-solid fa-person-walking-arrow-right"></i> Add Walk-in</button>
          <div class="search-bar">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input class="form-control" id="custSearch" type="text" placeholder="Search name or email…" oninput="searchCustomers()">
          </div>
        </div>
      </div>
      
      <div class="tabs-nav">
        <button class="tab-btn active" onclick="switchTab(event,'tab-customers')">Customers</button>
        <button class="tab-btn" onclick="switchTab(event,'tab-pending')">Pending Approvals <span id="pendingBadge" style="background:#dc2626; color:white; border-radius:50%; padding:2px 6px; font-size:10px; margin-left:4px; display:none;">0</span></button>
      </div>
      
      <!-- TAB: CUSTOMERS (Members + Walk-ins merged) -->
      <div id="tab-customers" class="tab-panel active">
        <div class="card">
          <div class="card-header-with-filter">
            <div class="section-title"><i class="fa-solid fa-users"></i> All Customers</div>
            <div class="filter-group">
              <select id="custTypeFilter" class="filter-dropdown" onchange="filterCustomers()">
                <option value="all">All Types</option>
                <option value="Member">Member</option>
                <option value="Premium">Premium</option>
                <option value="Walk-in">Walk-in</option>
              </select>
              <select id="custStatusFilter" class="filter-dropdown" onchange="filterCustomers()">
                <option value="all">All Status</option>
                <option value="Active">Active</option>
                <option value="Idle">Idle</option>
                <option value="Inactive">Inactive</option>
              </select>
            </div>
          </div>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr><th>Seat</th><th>Name</th><th>Email</th><th>Type</th><th>RFID</th><th>WiFi</th><th>MAC Address</th><th>Status</th><th>Action</th></tr>
              </thead>
              <tbody id="custBody">
                <!-- Populated by JS loadRealUsers() -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <!-- TAB: PENDING APPROVALS -->
      <div id="tab-pending" class="tab-panel">
        <div class="card">
          <div class="card-header-with-filter">
            <div class="section-title"><i class="fa-solid fa-user-clock"></i> Pending User Verifications</div>
          </div>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr><th>Date</th><th>Name</th><th>Email</th><th>Status</th><th>Action</th></tr>
              </thead>
              <tbody id="pendingBody">
                <!-- Will be populated by JS -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <!-- Add Walk-in Modal -->
      <div class="modal-overlay" id="addWalkinModal">
        <div class="modal">
          <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-person-walking-arrow-right"></i> Add New Walk-in Customer</div>
            <button class="modal-close" onclick="closeModal('addWalkinModal')">&times;</button>
          </div>
          <div class="modal-body">
            <div class="form-group"><label class="form-label">Email *</label><input class="form-control" id="wi-email" type="email" placeholder="customer@example.com"></div>
            <div class="form-row">
              <div class="form-group"><label class="form-label">First Name *</label><input class="form-control" id="wi-firstname" type="text" placeholder="First name"></div>
              <div class="form-group"><label class="form-label">Last Name *</label><input class="form-control" id="wi-lastname" type="text" placeholder="Last name"></div>
            </div>
            <div class="form-group"><label class="form-label">Phone Number</label><input class="form-control" id="wi-phone" type="tel" placeholder="+63 912 3456 789"></div>
            <div class="form-group">
              <label class="form-label">RFID UID <span style="color:#dc2626; font-size:10px;">(optional)</span></label>
              <div class="rfid-input-group">
                <input class="form-control" id="wi-rfid" type="text" placeholder="eg, 4A3F2B1C">
                <button type="button" class="btn-scan" onclick="simulateRFIDScan()"><i class="fa-solid fa-qrcode"></i> Scan RFID</button>
              </div>
            </div>
            <div class="form-group"><label class="form-label">WiFi Session Hours</label><input class="form-control" id="wi-hours" type="number" step="0.5" min="0" value="2"></div>
            <div class="form-group"><label class="form-label">MAC Addresses (up to 3 devices)</label>
              <div id="macFieldsContainer" class="mac-fields-container"><div class="mac-input-group"><input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" style="display:none;"><i class="fa-solid fa-minus"></i></button></div></div>
              <button type="button" id="addMacBtn" class="add-mac-btn"><i class="fa-solid fa-plus"></i> Add another MAC address</button>
            </div>
            <div class="form-group"><label class="form-label">Status</label><select class="form-control" id="wi-status"><option value="active">Active</option><option value="inactive">Inactive</option></select></div>
            <div class="form-group"><label class="form-label" style="display: flex; justify-content: space-between;">Assign Seat * <span>(Select on map)</span></label>
              <div class="modal-seat-layout" id="modalSeatLayout">
                <div id="modalSeatMap"></div>
              </div>
              <input type="hidden" id="selectedSeat" value="">
              <input type="hidden" id="selectedSeatId" value="">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <div style="font-size:0.75rem; color:#4f46e5; font-weight: 700;" id="selectedSeatDisplay">No seat selected</div>
                <div class="legend">
                  <div class="legend-item"><span class="legend-dot" style="background:#10b981"></span>Available</div>
                  <div class="legend-item"><span class="legend-dot" style="background:#d65c29"></span>Taken</div>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeModal('addWalkinModal')">Cancel</button>
            <button class="btn btn-primary" onclick="addWalkin()"><i class="fa-solid fa-plus"></i> Add Walk-in</button>
          </div>
        </div>
      </div>
      
      <!-- Edit Customer Modal -->
      <div class="modal-overlay" id="editCustomerModal">
        <div class="modal">
          <div class="modal-header"><div class="modal-title"><i class="fa-solid fa-pen"></i> Edit Customer</div><button class="modal-close" onclick="closeModal('editCustomerModal')">&times;</button></div>
          <div class="modal-body">
            <input type="hidden" id="editRowId">
            <div class="form-group"><label class="form-label">Seat</label><input class="form-control" id="editSeat" type="text"></div>
            <div class="form-row"><div class="form-group"><label class="form-label">First Name</label><input class="form-control" id="editFirstName" type="text"></div><div class="form-group"><label class="form-label">Last Name</label><input class="form-control" id="editLastName" type="text"></div></div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-control" id="editEmail" type="email"></div>
            <div class="form-group"><label class="form-label">RFID UID</label><input class="form-control" id="editRfid" type="text"></div>
            <div class="form-group"><label class="form-label">MAC Address</label><input class="form-control" id="editMac" type="text"></div>
            <div class="form-group"><label class="form-label">Status</label><select class="form-control" id="editStatus"><option value="Active">Active</option><option value="Idle">Idle</option><option value="Inactive">Inactive</option></select></div>
          </div>
          <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('editCustomerModal')">Cancel</button><button class="btn btn-primary" onclick="saveCustomerEdit()">Save Changes</button></div>
        </div>
      </div>
      
      <!-- Edit Walk-in Modal -->
      <div class="modal-overlay" id="editWalkinModal">
        <div class="modal">
          <div class="modal-header"><div class="modal-title"><i class="fa-solid fa-pen"></i> Edit Walk-in</div><button class="modal-close" onclick="closeModal('editWalkinModal')">&times;</button></div>
          <div class="modal-body">
            <input type="hidden" id="editWalkinRowId">
            <div class="form-group"><label class="form-label">Seat</label><input class="form-control" id="editWalkinSeat" type="text"></div>
            <div class="form-row"><div class="form-group"><label class="form-label">First Name</label><input class="form-control" id="editWalkinFirstName" type="text"></div><div class="form-group"><label class="form-label">Last Name</label><input class="form-control" id="editWalkinLastName" type="text"></div></div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-control" id="editWalkinEmail" type="email"></div>
            <div class="form-group"><label class="form-label">MAC Address</label><input class="form-control" id="editWalkinMac" type="text"></div>
            <div class="form-group"><label class="form-label">WiFi Hours</label><input class="form-control" id="editWalkinWifiHours" type="number" step="0.5"></div>
            <div class="form-group"><label class="form-label">Status</label><select class="form-control" id="editWalkinStatus"><option value="Active">Active</option><option value="Idle">Idle</option><option value="Inactive">Inactive</option></select></div>
          </div>
          <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('editWalkinModal')">Cancel</button><button class="btn btn-primary" onclick="saveWalkinEdit()">Save Changes</button></div>
        </div>
      </div>
      
      <!-- Session Time Edit Modal -->
      <div class="modal-overlay" id="wifiEditModal">
        <div class="modal">
          <div class="modal-header"><div class="modal-title"><i class="fa-solid fa-clock"></i> Extend Session Time</div><button class="modal-close" onclick="closeModal('wifiEditModal')">&times;</button></div>
          <div class="modal-body">
            <input type="hidden" id="wifiCustomerId">
            <div class="form-group"><label class="form-label">Customer Name</label><input class="form-control" id="wifiCustomerName" type="text" readonly disabled></div>
            <div class="form-group"><label class="form-label">Current Session Ends</label><input class="form-control" id="wifiCurrentHours" type="text" readonly disabled></div>
            <div class="form-group">
                <label class="form-label">Add Minutes</label>
                <select class="form-control" id="wifiAddMinutes">
                    <option value="30">30 minutes</option>
                    <option value="60">1 hour</option>
                    <option value="90">1 hour 30 mins</option>
                    <option value="120">2 hours</option>
                    <option value="180">3 hours</option>
                </select>
            </div>
          </div>
          <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('wifiEditModal')">Cancel</button><button class="btn btn-primary" onclick="updateWifiHours()">Extend Session</button></div>
        </div>
      </div>
      
      <!-- Customer Details Modal -->
      <div class="modal-overlay" id="viewCustModal">
        <div class="modal">
          <div class="modal-header"><div class="modal-title"><i class="fa-solid fa-user"></i> Customer Details</div><button class="modal-close" onclick="closeModal('viewCustModal')">&times;</button></div>
          <div class="modal-body" id="viewCustBody"></div>
          <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('viewCustModal')">Close</button></div>
        </div>
      </div>
    </main>
  </div>

<script>
    const rows = ['A', 'B', 'C', 'D'];
    const seatsPerRow = 7;
    let occupiedSeats = []; // Will be fetched later
    let selectedSeatForWalkin = null;
    let currentMacCount = 1;

    document.addEventListener('DOMContentLoaded', () => {
      loadRealUsers();
      renderPendingTable();
    });

    async function loadRealUsers() {
      try {
        // Fetch members and walk-ins separately at DB level (no guessing)
        const [resMem, resWalk, resAct] = await Promise.all([
          fetch('/api/users?role=customer&typeGroup=member'),
          fetch('/api/users?role=customer&typeGroup=walkin'),
          fetch('/api/active-customers')
        ]);
        const members   = (await resMem.json()).users  || [];
        const walkins   = (await resWalk.json()).users || [];
        const activeSessions = (await resAct.json()).customers || [];

        const memberBody = document.getElementById('custBody');
        memberBody.innerHTML = '';

        function buildRow(user, typeLabel) {
          const session = activeSessions.find(s => s.id === user.id);
          const endTime = session ? new Date(session.end_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : 'No active session';
          const dbStatus = user.status || '';
          const statusNorm = dbStatus.charAt(0).toUpperCase() + dbStatus.slice(1).toLowerCase();
          const rowStatus = ['Active','Idle','Inactive'].includes(statusNorm) ? statusNorm : (session ? 'Active' : 'Inactive');
          const badgeClass = rowStatus === 'Active' ? 'green' : (rowStatus === 'Idle' ? 'orange' : 'red');

          const tr = document.createElement('tr');
          tr.setAttribute('data-type', typeLabel);
          tr.setAttribute('data-status', rowStatus);
          tr.setAttribute('data-name', (user.first_name + ' ' + user.last_name).toLowerCase());
          tr.setAttribute('data-email', (user.email || '').toLowerCase());

          tr.innerHTML = `
            <td>${session?.seat_label || '—'}</td>
            <td class="td-bold">${escapeHtml(user.first_name)} ${escapeHtml(user.last_name)}</td>
            <td>${escapeHtml(user.email)}</td>
            <td>${typeLabel}</td>
            <td>—</td>
            <td class="wifi-cell">
                ${endTime}
                ${session ? `<button class=\"wifi-edit-btn\" onclick=\"openWifiEditModal(this, '${user.first_name} ${user.last_name}', '${endTime}', ${user.id})\"><i class=\"fa-solid fa-pen\"></i></button>` : ''}
            </td>
            <td>${session?.mac_address || '—'}</td>
            <td><span class="badge badge-${badgeClass}">${rowStatus}</span></td>
            <td>
              <div style="display:flex;gap:5px">
                <button class="btn btn-ghost btn-sm" onclick='viewCustomer(${JSON.stringify(user)})' title="View"><i class="fa-solid fa-eye"></i></button>
                <button class="btn btn-ghost btn-sm" onclick='openEditCustomerModal(${JSON.stringify(user)})' title="Edit"><i class="fa-solid fa-pen"></i></button>
                ${typeLabel === 'Walk-in' ? `<button class="btn-upgrade" onclick="upgradeToMember(${user.id})" title="Upgrade to Member"><i class="fa-solid fa-star"></i> Upgrade</button>` : ''}
                <button class="btn btn-danger btn-sm" onclick="removeUser(${user.id})" title="Delete"><i class="fa-solid fa-trash"></i></button>
              </div>
            </td>
          `;
          return tr;
        }

        // Populate Members tab — includes member, premium, and self-registered (NULL type)
        members.forEach(user => {
          const label = (user.type || '').toLowerCase().includes('prem') ? 'Premium' : 'Member';
          memberBody.appendChild(buildRow(user, label));
        });

        // Populate Walk-in tab — only users with type LIKE '%walk%'
        walkins.forEach(user => {
          memberBody.appendChild(buildRow(user, 'Walk-in'));
        });

      } catch (err) { console.error(err); }
    }

    function openEditCustomerModal(user) {
        document.getElementById('editRowId').value = user.id;
        document.getElementById('editFirstName').value = user.first_name;
        document.getElementById('editLastName').value = user.last_name;
        document.getElementById('editEmail').value = user.email;
        document.getElementById('editStatus').value = user.status || 'Active';
        openModal('editCustomerModal');
    }

    async function saveCustomerEdit() {
        const id = document.getElementById('editRowId').value;
        const firstName = document.getElementById('editFirstName').value;
        const lastName = document.getElementById('editLastName').value;
        const email = document.getElementById('editEmail').value;
        const status = document.getElementById('editStatus').value;

        try {
            const res = await fetch(`/api/users/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ firstName, lastName, email, status, role: 'customer', type: 'member' })
            });
            if ((await res.json()).success) {
                toast("Customer updated!", "success");
                closeModal('editCustomerModal');
                loadRealUsers();
            }
        } catch (err) { console.error(err); }
    }

    function viewCustomer(user) {
        const body = document.getElementById('viewCustBody');
        body.innerHTML = `
            <div style="display:flex; flex-direction:column; gap:10px;">
                <p><strong>Name:</strong> ${user.first_name} ${user.last_name}</p>
                <p><strong>Email:</strong> ${user.email}</p>
                <p><strong>Role:</strong> ${user.role}</p>
                <p><strong>Type:</strong> ${user.type}</p>
                <p><strong>Status:</strong> ${user.status}</p>
                <p><strong>Joined:</strong> ${new Date(user.created_at).toLocaleDateString()}</p>
            </div>
        `;
        openModal('viewCustModal');
    }

    function openWifiEditModal(btn, name, currentEndTime, id) {
        document.getElementById('wifiCustomerName').value = name;
        document.getElementById('wifiCurrentHours').value = currentEndTime;
        document.getElementById('wifiCustomerId').value = id;
        openModal('wifiEditModal');
    }

    async function updateWifiHours() {
        const id = document.getElementById('wifiCustomerId').value;
        const minutes = document.getElementById('wifiAddMinutes').value;
        
        try {
            const res = await fetch('/api/session/extend', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: id, minutes: parseInt(minutes) })
            });
            const data = await res.json();
            if (data.success) {
                toast("Session extended!", "success");
                closeModal('wifiEditModal');
                loadRealUsers();
            } else {
                alert("Failed to extend session.");
            }
        } catch (err) {
            console.error(err);
        }
    }

    async function renderPendingTable() {
      const tbody = document.getElementById('pendingBody');
      const badge = document.getElementById('pendingBadge');
      try {
        const res = await fetch('/api/users?status=pending&role=customer');
        const data = await res.json();
        const pending = data.users || [];

        tbody.innerHTML = '';
        if (pending.length === 0) {
          tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:40px; color:#94a3b8;">No pending registrations.</td></tr>';
          badge.style.display = 'none';
          return;
        }

        badge.textContent = pending.length;
        badge.style.display = 'inline';

        pending.forEach(req => {
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td>${new Date(req.created_at).toLocaleDateString()}</td>
            <td class="td-bold">${escapeHtml(req.first_name)} ${escapeHtml(req.last_name)}</td>
            <td>${escapeHtml(req.email)}</td>
            <td><span class="badge badge-orange">Pending</span></td>
            <td>
              <div style="display:flex;gap:5px">
                <button class="btn btn-primary btn-sm" style="background:#059669" onclick="approvePending(${req.id})">Approve</button>
                <button class="btn btn-danger btn-sm" onclick="removeUser(${req.id}, 'Application rejected')">Reject</button>
              </div>
            </td>
          `;
          tbody.appendChild(tr);
        });
      } catch (err) { console.error(err); }
    }

    async function approvePending(id) {
      if(!confirm("Approve this user?")) return;
      try {
        const res = await fetch(`/api/users/approve/${id}`, { method: 'POST' });
        if((await res.json()).success) {
          toast("User approved!", "success");
          renderPendingTable();
          loadRealUsers();
        }
      } catch (err) { console.error(err); }
    }

    async function upgradeToMember(id) {
      if(!confirm("Upgrade this walk-in customer to a full Member?")) return;
      try {
        const res = await fetch(`/api/users/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'member' }) // Backend will preserve other fields if we use PATCH or if API is robust
        });
        // Note: Our PUT route at 208 expects all fields. Let's make it smarter or fetch first.
        // For simplicity, I'll fetch user data first then update.
        const userRes = await fetch(`/api/users/${id}`);
        const userData = (await userRes.json()).user;
        
        if (userData) {
          const updateRes = await fetch(`/api/users/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
              firstName: userData.first_name, 
              lastName: userData.last_name, 
              email: userData.email, 
              role: userData.role, 
              status: userData.status,
              type: 'member' 
            })
          });
          if ((await updateRes.json()).success) {
            toast("Customer upgraded to Member!", "success");
            loadRealUsers();
          }
        }
      } catch (err) { console.error(err); }
    }

    async function removeUser(id, msg = "User removed") {
      if(!confirm("Are you sure?")) return;
      try {
        const res = await fetch(`/api/users/${id}`, { method: 'DELETE' });
        if((await res.json()).success) {
          toast(msg, "info");
          loadRealUsers();
          renderPendingTable();
        }
      } catch (err) { console.error(err); }
    }

    async function addWalkin() {
      const email = document.getElementById('wi-email').value.trim();
      const firstName = document.getElementById('wi-firstname').value.trim();
      const lastName = document.getElementById('wi-lastname').value.trim();
      const phone = document.getElementById('wi-phone').value.trim();
      const rfid = document.getElementById('wi-rfid').value.trim();
      const hours = parseFloat(document.getElementById('wi-hours').value);
      const elementId = document.getElementById('selectedSeatId').value;
      const status = document.getElementById('wi-status').value;
      const isWalkin = document.getElementById('addWalkinModal').dataset.type === 'walkin';

      if (!firstName || !lastName || !email || !elementId) { 
        alert("Required fields missing (Name, Email, and Seat Selection are mandatory)."); 
        return; 
      }

      try {
        const res = await fetch('/api/users/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            firstName, lastName, email, 
            role: 'customer', 
            type: isWalkin ? 'walkin' : 'member',
            phone,
            status
          })
        });
        const data = await res.json();
        
        if(data.success) {
          const userId = data.userId;
          
          // Now start the session
          const sessionRes = await fetch('/api/session/start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId, elementId, hours })
          });
          
          if ((await sessionRes.json()).success) {
            toast(`${isWalkin ? 'Walk-in' : 'Member'} added and seat assigned!`, "success");
            closeModal('addWalkinModal');
            loadRealUsers();
          } else {
            toast("User created but failed to assign seat.", "warning");
          }
        } else {
          alert("Error adding customer: " + (data.error || "Unknown error"));
        }
      } catch (err) { console.error(err); }
    }

    async function renderModalSeatLayout() {
      const container = document.getElementById('modalSeatMap');
      const viewport = document.getElementById('modalSeatLayout');
      if (!container) return;

      container.innerHTML = '<div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:12px;">Loading map...</div>';

      try {
        const res = await fetch('/api/layout');
        const data = await res.json();
        let items = data.items || [];
        
        container.innerHTML = '';

        if (items.length === 0) {
          container.innerHTML = '<div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:12px;">No layout found.</div>';
          return;
        }

        items.forEach(item => {
          const el = document.createElement('div');
          el.className = 'fp-item';
          el.style.left = item.x + 'px';
          el.style.top = item.y + 'px';
          el.style.width = item.w + 'px';
          el.style.height = item.h + 'px';
          el.style.zIndex = (item.type === 'chair' || item.type === 'chair-sq') ? 5 : item.type.startsWith('block') ? 2 : 3;

          const visual = document.createElement('div');
          visual.className = 'item-visual';
          visual.style.transform = 'rotate(' + (item.rot || 0) + 'deg)';

          const isSeat = (item.type === 'chair' || item.type === 'chair-sq');
          const status = (item.statuses && item.statuses[0]) || 'open';

          if (item.type === 'chair') {
            visual.classList.add('chair-icon');
            visual.style.webkitMaskImage = 'url(/images/chair.png)';
            visual.style.maskImage = 'url(/images/chair.png)';
            visual.style.backgroundColor = (status === 'taken') ? '#d65c29' : '#10b981';
          } else if (item.type === 'chair-sq') {
            visual.style.background = (status === 'taken') ? '#d65c29' : '#10b981';
            visual.style.borderRadius = '4px';
          } else if (item.type === 'round-table' || item.type === 'rect-table') {
            visual.style.background = item.color || '#fdba74';
            visual.style.border = '1.5px solid #f97316';
            visual.style.borderRadius = item.type === 'round-table' ? '50%' : '6px';
          } else {
            visual.style.background = item.color || '#cbd5e1';
            visual.style.borderRadius = '4px';
          }
          el.appendChild(visual);

          if (item.label || item.type === 'room') {
            const lbl = document.createElement('span');
            lbl.className = 'item-label';
            if (item.type !== 'chair' && item.type !== 'chair-sq') {
              lbl.classList.add('center');
              lbl.style.color = '#1e293b';
            }
            lbl.textContent = item.label || (item.type === 'room' ? 'Room' : '');
            el.appendChild(lbl);
          }

          if (isSeat && status === 'open') {
            el.onclick = () => {
              document.querySelectorAll('#modalSeatMap .fp-item').forEach(s => s.classList.remove('selected'));
              el.classList.add('selected');
              selectedSeatForWalkin = item.label;
              document.getElementById('selectedSeat').value = item.label;
              document.getElementById('selectedSeatId').value = item.id;
              document.getElementById('selectedSeatDisplay').innerHTML = `Selected: <strong>${item.label}</strong>`;
            };
          } else if (isSeat && status !== 'open') {
            el.style.cursor = 'not-allowed';
            el.title = 'Seat already taken';
          }

          container.appendChild(el);
        });

        // Scale to fit modal
        const vWidth = viewport.clientWidth || 450;
        const vHeight = viewport.clientHeight || 300;
        const scale = Math.min(vWidth / 800, vHeight / 450) * 0.95;
        container.style.transform = `scale(${scale})`;
        container.style.left = `${(vWidth - (800 * scale)) / 2}px`;
        container.style.top = `${(vHeight - (450 * scale)) / 2}px`;

      } catch (e) {
        console.error(e);
        container.innerHTML = '<div style="color:red; font-size:11px;">Error loading map.</div>';
      }
    }

    function addNewMacField() {
      if (currentMacCount >= 3) return;
      const container = document.getElementById('macFieldsContainer');
      const div = document.createElement('div');
      div.className = 'mac-input-group';
      div.innerHTML = `<input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" onclick="this.parentElement.remove(); currentMacCount--;"><i class="fa-solid fa-minus"></i></button>`;
      container.appendChild(div);
      currentMacCount++;
    }

    function filterCustomers() {
      const typeVal = document.getElementById('custTypeFilter').value;
      const statusVal = document.getElementById('custStatusFilter').value;
      const searchVal = document.getElementById('custSearch').value.toLowerCase().trim();
      
      document.querySelectorAll('#custBody tr').forEach(tr => {
        const type   = tr.getAttribute('data-type') || '';
        const status = tr.getAttribute('data-status') || '';
        const name   = tr.getAttribute('data-name') || '';
        const email  = tr.getAttribute('data-email') || '';

        const typeOk = typeVal === 'all' || type === typeVal;
        const statusOk = statusVal === 'all' || status === statusVal;
        const searchOk = !searchVal || name.includes(searchVal) || email.includes(searchVal);
        tr.style.display = (typeOk && statusOk && searchOk) ? '' : 'none';
      });
    }

    function searchCustomers() {
      filterCustomers();
    }

    function switchTab(event, id) { 
      document.querySelectorAll('.tab-panel, .tab-btn').forEach(el => el.classList.remove('active')); 
      document.getElementById(id).classList.add('active'); 
      event.currentTarget.classList.add('active'); 
      if (id === 'tab-pending') renderPendingTable();
    }

    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    function openAddUserModal(type) { 
      const modal = document.getElementById('addWalkinModal');
      const title = modal.querySelector('.modal-title');
      const submitBtn = modal.querySelector('.btn-primary');
      
      modal.dataset.type = type;
      if (type === 'member') {
        title.innerHTML = '<i class="fa-solid fa-user-plus"></i> Add New Member';
        submitBtn.innerHTML = '<i class="fa-solid fa-plus"></i> Add Member';
      } else {
        title.innerHTML = '<i class="fa-solid fa-person-walking-arrow-right"></i> Add New Walk-in Customer';
        submitBtn.innerHTML = '<i class="fa-solid fa-plus"></i> Add Walk-in';
      }
      
      // Reset form
      document.getElementById('wi-email').value = '';
      document.getElementById('wi-firstname').value = '';
      document.getElementById('wi-lastname').value = '';
      document.getElementById('selectedSeat').value = '';
      document.getElementById('selectedSeatId').value = '';
      document.getElementById('selectedSeatDisplay').innerHTML = 'No seat selected';
      
      renderModalSeatLayout(); 
      openModal('addWalkinModal'); 
    }
    function openSidebar() { document.getElementById('sidebar').classList.add('mobile-open'); document.getElementById('mobileOverlay').classList.add('show'); }
    function closeSidebar() { document.getElementById('sidebar').classList.remove('mobile-open'); document.getElementById('mobileOverlay').classList.remove('show'); }
    function escapeHtml(s) { return s ? String(s).replace(/[&<>]/g, m => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;' }[m])) : ''; }
    function toast(m, t) {
      const el = document.createElement('div');
      el.style.cssText = `position:fixed;bottom:20px;right:20px;background:${t==='success'?'#059669':'#1e293b'};color:white;padding:10px 20px;border-radius:8px;z-index:9999;`;
      el.textContent = m;
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 2500);
    }
    document.getElementById('addMacBtn')?.addEventListener('click', addNewMacField);
</script>

