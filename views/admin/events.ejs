<%- contentFor('script') %>
<script>
let eventCustomBanners = JSON.parse(localStorage.getItem('eventCustomBanners') || '{}');

function setSeatImage(seatId, imageData) {
  // Now handled via API
}

function setEventBanner(eventId, imageData) {
  if(imageData) {
    eventCustomBanners[eventId] = imageData;
  } else {
    delete eventCustomBanners[eventId];
  }
  localStorage.setItem('eventCustomBanners', JSON.stringify(eventCustomBanners));
}


function openSidebar(){
  document.getElementById('sidebar').classList.add('mobile-open');
  document.getElementById('mobileOverlay').classList.add('show');
}

function closeSidebar(){
  document.getElementById('sidebar').classList.remove('mobile-open');
  document.getElementById('mobileOverlay').classList.remove('show');
}

function openModal(id){
  document.getElementById(id).classList.add('open');
}

function closeModal(id){
  document.getElementById(id).classList.remove('open');
}

let yr=new Date().getFullYear(), mo=new Date().getMonth();
let currentCalView = 'monthly';
let currentWeekStart = getStartOfWeek(new Date());

function getStartOfWeek(d) {
  const date = new Date(d);
  const day = date.getDay();
  const diff = date.getDate() - day;
  const start = new Date(date.setDate(diff));
  start.setHours(0,0,0,0);
  return start;
}

function changeView(view) {
  currentCalView = view;
  if (view === 'weekly') {
    currentWeekStart = getStartOfWeek(new Date(yr, mo, 15));
  }
  renderCal();
}

function navigateCal(dir) {
  if (currentCalView === 'monthly') {
    mo += dir;
    if (mo > 11) { mo = 0; yr++; }
    if (mo < 0) { mo = 11; yr--; }
  } else if (currentCalView === 'yearly') {
    yr += dir;
  } else if (currentCalView === 'weekly') {
    currentWeekStart.setDate(currentWeekStart.getDate() + (dir * 7));
    yr = currentWeekStart.getFullYear();
    mo = currentWeekStart.getMonth();
  }
  renderCal();
}
const MN=['January','February','March','April','May','June','July','August','September','October','November','December'];

// Default seat colors
const defaultSeatColors = {
  "A3": "#CF6322", "B2": "#8A8636", "C5": "#4A7C59", "C1": "#CF6322",
  "A7": "#8A8636", "A2": "#4A7C59", "D3": "#CF6322", "B4": "#8A8636",
  "D6": "#4A7C59", "B3": "#CF6322", "C3": "#8A8636", "A5": "#4A7C59"
};

function getDefaultSeatColor(seatId){
  return defaultSeatColors[seatId] || "#CF6322";
}

// Time slots from 8am to 11pm
const timeSlots = [
  "8:00 AM", "9:00 AM", "10:00 AM", "11:00 AM", "12:00 PM",
  "1:00 PM", "2:00 PM", "3:00 PM", "4:00 PM", "5:00 PM",
  "6:00 PM", "7:00 PM", "8:00 PM", "9:00 PM", "10:00 PM", "11:00 PM"
];

function getTimeHour(timeStr) {
  if (!timeStr) return 0;
  // If timeStr is "08:00 AM"
  if (timeStr.includes('AM') || timeStr.includes('PM')) {
      const hourMap = {
        "08:00 AM": 8, "09:00 AM": 9, "10:00 AM": 10, "11:00 AM": 11,
        "12:00 PM": 12, "01:00 PM": 13, "02:00 PM": 14, "03:00 PM": 15,
        "04:00 PM": 16, "05:00 PM": 17, "06:00 PM": 18, "07:00 PM": 19,
        "08:00 PM": 20, "09:00 PM": 21, "10:00 PM": 22, "11:00 PM": 23
      };
      return hourMap[timeStr] || 0;
  }
  // If timeStr is "HH:mm" or "HH:mm:ss"
  return parseInt(timeStr.split(':')[0]);
}

function getCustomersForTimeSlot(date, timeSlot) {
  const resOnDate = customerReservations.filter(r => {
      return getLocalDateString(r.start_time) === date && r.status === 'confirmed';
  });
  const slotHour = getTimeHour(timeSlot);
  return resOnDate.filter(r => {
      const h = new Date(r.start_time).getHours();
      return h === slotHour;
  });
}

function getEventsForTimeSlot(date, timeSlot) {
  const eventsOnDate = events.filter(e => {
      return getLocalDateString(e.event_date) === date;
  });
  const slotHour = getTimeHour(timeSlot);
  return eventsOnDate.filter(e => {
    const h = new Date(e.event_date).getHours();
    return h === slotHour;
  });
}

// Show schedule modal for clicked date
function showScheduleModal(dateStr) {
  const formattedDate = new Date(dateStr).toLocaleDateString('en-US', { 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
  });
  const dayEvents = getEventsByDate(dateStr);
  
  let scheduleHtml = `<div class="date-title">Schedule - ${formattedDate}</div>`;
  
  // Events section
  if (dayEvents.length > 0) {
    scheduleHtml += `<div style="background:#fff8f0; padding:12px; border-radius:12px; margin-bottom:16px; border-left:4px solid var(--orange);">
      <div style="font-weight:700; margin-bottom:8px; color:var(--orange);"><i class="fa-solid fa-calendar-star"></i> Events</div>`;
    dayEvents.forEach(e => {
      const timeStr = new Date(e.event_date).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
      scheduleHtml += `
        <div style="padding:6px 0; border-bottom:1px solid #e2e8f0; cursor:pointer;" onclick="showEventDetail(${JSON.stringify(e).replace(/"/g, '&quot;')})">
          <span style="font-weight:700;">${escapeHtml(e.title)}</span>
          <span style="font-size:11px; color:#64748b; margin-left:8px;">${timeStr}</span>
          <span style="font-size:10px; color:#94a3b8; margin-left:8px;">📍 ${e.location}</span>
        </div>
      `;
    });
    scheduleHtml += `</div>`;
  }
  
  // Reservations schedule
  scheduleHtml += `<div class="schedule-list">`;
  
  for (const timeSlot of timeSlots) {
    const customers = getCustomersForTimeSlot(dateStr, timeSlot);
    let customersHtml = '';
    
    if (customers.length > 0) {
      customersHtml = customers.map(c => {
        const name = `${c.first_name} ${c.last_name}`;
        return `<span onclick="showReservationDetail(${JSON.stringify(c).replace(/"/g, '&quot;')})" style="cursor:pointer;">${escapeHtml(name)} (Seat ${c.seat_label})</span>`;
      }).join('');
    } else {
      customersHtml = '<span class="schedule-empty">No reservations</span>';
    }
    
    scheduleHtml += `
      <div class="schedule-hour">
        <div class="schedule-time">${timeSlot}</div>
        <div class="schedule-customers">${customersHtml}</div>
      </div>
    `;
  }
  
  scheduleHtml += `</div>`;
  document.getElementById('scheduleModalBody').innerHTML = scheduleHtml;
  openModal('scheduleModal');
}

let events = [];
let customerReservations = [];

async function loadAllData() {
    try {
        const [evRes, revRes] = await Promise.all([
            fetch('/api/events').then(res => res.json()),
            fetch('/api/reservations').then(res => res.json())
        ]);
        events = evRes.events || [];
        customerReservations = revRes.reservations || [];
        
        renderCal();
        switchView();
    } catch (e) { console.error('Error loading events:', e); }
}

