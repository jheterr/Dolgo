function saveSeatImage(){
  const fileInput = document.getElementById('seat-image-file');
  if(fileInput.files && fileInput.files[0]){
    const reader = new FileReader();
    reader.onload = async function(e){
      const imageData = e.target.result;
      try {
          const res = await fetch('/api/floor-elements/image', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ label: currentSeatForImage, image: imageData })
          });
          const data = await res.json();
          if(data.success) {
              closeModal('editSeatImageModal');
              loadAllData();
          }
      } catch(err) { console.error(err); }
    };
    reader.readAsDataURL(fileInput.files[0]);
  } else {
    alert('Please select an image first');
  }
}

