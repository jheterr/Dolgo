function getLocalDateString(date) {
    if (!date) return '';
    const d = new Date(date);
    const year = d.getFullYear();
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
}

function getEventsByDate(dateStr){ 
    return events.filter(e => getLocalDateString(e.event_date) === dateStr); 
}
function getReservationsByDate(dateStr){ 
    return customerReservations.filter(r => getLocalDateString(r.start_time) === dateStr); 
}
function isToday(dateStr){
  return dateStr === getLocalDateString(new Date());
}
function getTodayReservations(){
  const todayStr = getLocalDateString(new Date());
  return customerReservations.filter(r => getLocalDateString(r.start_time) === todayStr && r.status === 'confirmed');
}
function getUpcomingReservations(){
  const todayStr = getLocalDateString(new Date());
  return customerReservations.filter(r => getLocalDateString(r.start_time) > todayStr && r.status === 'confirmed');
}
function getUpcomingEvents(){
  const todayStr = getLocalDateString(new Date());
  return events.filter(e => getLocalDateString(e.event_date) >= todayStr);
}
function getPastEvents(){
  const todayStr = getLocalDateString(new Date());
  return events.filter(e => getLocalDateString(e.event_date) < todayStr);
}

function sortItems(items, isEvent){
  const sortType = document.getElementById('sortSelect').value;
  if(sortType === 'date_asc') return [...items].sort((a,b)=>new Date(a.event_date) - new Date(b.event_date));
  if(sortType === 'date_desc') return [...items].sort((a,b)=>new Date(b.event_date) - new Date(a.event_date));
  if(sortType === 'name_asc') return [...items].sort((a,b)=>(a.title||'').localeCompare(b.title||''));
  if(sortType === 'name_desc') return [...items].sort((a,b)=>(b.title||'').localeCompare(a.title||''));
  return items;
}
function sortReservations(items){
  const sortType = document.getElementById('sortSelect').value;
  if(sortType === 'date_asc') return [...items].sort((a,b)=>new Date(a.start_time) - new Date(b.start_time));
  if(sortType === 'date_desc') return [...items].sort((a,b)=>new Date(b.start_time) - new Date(a.start_time));
  if(sortType === 'name_asc') return [...items].sort((a,b)=>`${a.first_name} ${a.last_name}`.localeCompare(`${b.first_name} ${b.last_name}`));
  if(sortType === 'name_desc') return [...items].sort((a,b)=>`${b.last_name} ${b.last_name}`.localeCompare(`${a.first_name} ${a.last_name}`));
  return items;
}

function switchView(){
  const viewType = document.getElementById('viewSelect').value;
  const container = document.getElementById('cardsContainer');
  let items = [], isEvent = false;
  switch(viewType){
    case 'todayReservations': items = sortReservations(getTodayReservations()); break;
    case 'upcomingReservations': items = sortReservations(getUpcomingReservations()); break;
    case 'upcomingEvents': items = sortItems(getUpcomingEvents(), true); isEvent = true; break;
    case 'pastEvents': items = sortItems(getPastEvents(), true); isEvent = true; break;
    default: items = sortReservations(getTodayReservations());
  }
  if(items.length === 0){ container.innerHTML = `<div class="empty-state"><i class="fa-regular fa-folder-open"></i><p>No items to display</p></div>`; return; }
  if(isEvent){
    container.innerHTML = items.map(ev => {
      const d = new Date(ev.event_date);
      const dateStr = d.toLocaleDateString();
      const timeStr = d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
      return `
        <div class="event-card" onclick="showEventDetail(${JSON.stringify(ev).replace(/"/g, '&quot;')})">
          <div class="card-banner" style="background-image: url('${ev.image || 'data:image/svg+xml,%3Csvg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 200 100\'%3E%3Crect width=\'200\' height=\'100\' fill=\'%23CF6322\'/%3E%3Ctext x=\'100\' y=\'55\' text-anchor=\'middle\' fill=\'white\' font-size=\'14\' font-weight=\'bold\'%3E'+ev.title.substring(0,15)+'%3C/text%3E%3C/svg%3E'}'); background-size: cover;">
            <div class="card-badge">${viewType === 'upcomingEvents' ? 'Upcoming' : 'Past'}</div>
          </div>
          <div class="card-content">
            <div class="card-title">${escapeHtml(ev.title)}</div>
            <div class="card-meta"><span><i class="fa-regular fa-calendar"></i> ${dateStr}</span><span><i class="fa-regular fa-clock"></i> ${timeStr}</span><span class="card-location"><i class="fa-solid fa-location-dot"></i> ${ev.location}</span></div>
            <div class="card-description">${escapeHtml((ev.description || '').substring(0,80))}${ev.description && ev.description.length>80?'...':''}</div>
          </div>
        </div>
      `;
    }).join('');
  } else {
    container.innerHTML = items.map(r => {
      const name = `${r.first_name} ${r.last_name}`;
      const d = new Date(r.start_time);
      const dateStr = d.toLocaleDateString();
      const timeStr = d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
      const duration = Math.round((new Date(r.end_time) - d) / (1000 * 60 * 60));
      return `
        <div class="event-card" onclick="showReservationDetail(${JSON.stringify(r).replace(/"/g, '&quot;')})">
          <div class="card-banner" style="background-image: url('${r.seat_image || `data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='${getDefaultSeatColor(r.seat_label).replace('#','%23')}'/%3E%3Ctext x='50' y='55' text-anchor='middle' fill='white' font-size='12' font-weight='bold'%3ESeat ${r.seat_label}%3C/text%3E%3C/svg%3E`}'); background-size: cover;">
            <div class="card-badge" style="background:#8A8636;">${r.status === 'confirmed' ? 'Confirmed' : 'Pending'}</div>
          </div>
          <div class="card-content">
            <div class="card-title">${escapeHtml(name)}</div>
            <div class="card-meta"><span><i class="fa-regular fa-calendar"></i> ${dateStr}</span><span><i class="fa-regular fa-clock"></i> ${timeStr}</span><span class="card-location"><i class="fa-solid fa-chair"></i> Seat ${r.seat_label || 'N/A'}</span></div>
            <div class="card-description">${duration} hour(s) • ${r.status === 'confirmed' ? 'Confirmed reservation' : 'Awaiting payment'}</div>
          </div>
        </div>
      `;
    }).join('');
  }
}

