    if (data.success) {
      alert('Event deleted successfully');
      closeModal('eventDetailModal');
      loadAllData();
    } else {
      alert('Error deleting event: ' + data.error);
    }
  } catch (e) { console.error(e); alert('Failed to delete event'); }
}

function renderCal() {
  const g = document.getElementById('calGrid');
  const title = document.getElementById('calTitle');
  if (!g || !title) return;
  
  g.className = 'cal-grid ' + currentCalView + '-view';
  
  if (currentCalView === 'monthly') {
    title.textContent = MN[mo] + ' ' + yr;
    renderMonthlyView(g);
  } else if (currentCalView === 'yearly') {
    title.textContent = 'Year ' + yr;
    renderYearlyView(g);
  } else if (currentCalView === 'weekly') {
    const end = new Date(currentWeekStart);
    end.setDate(end.getDate() + 6);
    title.textContent = `${MN[currentWeekStart.getMonth()]} ${currentWeekStart.getDate()} - ${MN[end.getMonth()]} ${end.getDate()}, ${yr}`;
    renderWeeklyView(g);
  }
  
  // Re-attach listeners for monthly/weekly
  document.querySelectorAll('.cal-day:not(.empty)').forEach(day => {
    day.addEventListener('click', () => {
      const date = day.getAttribute('data-date');
      showScheduleModal(date);
    });
  });
}

function renderMonthlyView(g) {
  g.innerHTML = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(d=>`<div class="cal-head">${d}</div>`).join('');
  const first = new Date(yr, mo, 1).getDay();
  const days = new Date(yr, mo + 1, 0).getDate();
  
  for(let i=0; i<first; i++) g.innerHTML += '<div class="cal-day empty"></div>';
  for(let d=1; d<=days; d++) {
    const dateStr = `${yr}-${String(mo+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isTodayFlag = isToday(dateStr);
    const dayEvents = getEventsByDate(dateStr);
    const dayReservations = getReservationsByDate(dateStr);
    let tagsHtml = '';
    dayEvents.slice(0,2).forEach(e => { tagsHtml += `<div class="cal-tag cal-tag-event" title="${e.title}">📅 ${e.title.length>12?e.title.substring(0,10)+'…':e.title}</div>`; });
    if(dayEvents.length > 2) tagsHtml += `<div class="cal-tag cal-tag-event">+${dayEvents.length-2} more</div>`;
    dayReservations.slice(0,1).forEach(r => { 
      const name = `${r.first_name} ${r.last_name}`;
      tagsHtml += `<div class="cal-tag cal-tag-reservation" title="${name} - Seat ${r.seat_label}">📖 ${name.length>12?name.substring(0,10)+'…':name}</div>`; 
    });
    if(dayReservations.length > 1) tagsHtml += `<div class="cal-tag cal-tag-reservation">+${dayReservations.length-1} more</div>`;
    g.innerHTML += `<div class="cal-day${isTodayFlag?' today':''}" data-date="${dateStr}"><strong>${d}</strong>${tagsHtml}</div>`;
  }
}

function renderWeeklyView(g) {
  g.innerHTML = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(d=>`<div class="cal-head">${d}</div>`).join('');
  let d = new Date(currentWeekStart);
  for (let i = 0; i < 7; i++) {
    const dateStr = d.toISOString().split('T')[0];
    const isTodayFlag = isToday(dateStr);
    const dayEvents = getEventsByDate(dateStr);
    const dayReservations = getReservationsByDate(dateStr);
    let tagsHtml = '';
    dayEvents.forEach(e => { tagsHtml += `<div class="cal-tag cal-tag-event" title="${e.title}">📅 ${e.title}</div>`; });
    dayReservations.forEach(r => { 
      const name = `${r.first_name} ${r.last_name}`;
      tagsHtml += `<div class="cal-tag cal-tag-reservation" title="${name} - Seat ${r.seat_label}">📖 ${name} - Seat ${r.seat_label}</div>`; 
    });
    
    g.innerHTML += `
      <div class="cal-day${isTodayFlag?' today':''}" data-date="${dateStr}">
        <div style="font-size: 14px; margin-bottom: 5px;"><strong>${d.getDate()}</strong> <span style="font-size: 10px; color: #64748b;">${MN[d.getMonth()]}</span></div>
        ${tagsHtml}
      </div>`;
    d.setDate(d.getDate() + 1);
  }
}

function renderYearlyView(g) {
  g.innerHTML = '';
  for (let m = 0; m < 12; m++) {
    const first = new Date(yr, m, 1).getDay();
    const days = new Date(yr, m + 1, 0).getDate();
    let monthHtml = `
      <div class="year-month-box">
        <div class="year-month-title">${MN[m]}</div>
        <div class="year-month-grid">
          ${['S','M','T','W','T','F','S'].map(d=>`<div style="font-size:7px; font-weight:700; text-align:center; opacity:0.5;">${d}</div>`).join('')}
    `;
    
    for(let i=0; i<first; i++) monthHtml += '<div></div>';
    for(let d=1; d<=days; d++) {
      const dateStr = `${yr}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const hasEvent = getEventsByDate(dateStr).length > 0;
      const hasRes = getReservationsByDate(dateStr).length > 0;
      const isTodayFlag = isToday(dateStr);
      
      let cls = 'year-day';
      if (hasEvent) cls += ' has-event';
      else if (hasRes) cls += ' has-reservation';
      if (isTodayFlag) cls += ' today';
      
      monthHtml += `<div class="${cls}" title="${dateStr}" onclick="showDayDetails('${dateStr}')">${d}</div>`;
    }
    monthHtml += '</div></div>';
    g.innerHTML += monthHtml;
  }
}

function showDayDetails(date) {
  currentCalView = 'monthly';
  const d = new Date(date);
  yr = d.getFullYear();
  mo = d.getMonth();
  document.getElementById('calViewFilter').value = 'monthly';
  renderCal();
  showScheduleModal(date);
}

function changeMonth(dir){
  navigateCal(dir);
}

async function handleCreateEvent(){
  const nameInput = document.getElementById('ev-name');
  const dateInput = document.getElementById('ev-date');
  const locInput = document.getElementById('ev-loc');
  const timeInput = document.getElementById('ev-time');
  const descInput = document.getElementById('ev-desc');
  const imageDataInput = document.getElementById('ev-image-data');

  if (!nameInput || !dateInput) return;

  const name = nameInput.value.trim();
  const date = dateInput.value;
  const loc = locInput ? locInput.value : 'Default';
  const time = timeInput ? (timeInput.value || '00:00') : '00:00';
  const desc = descInput ? descInput.value : '';
  const imageData = imageDataInput ? imageDataInput.value : null;

  console.log('Attempting to create event:', {name, date, loc, time});
  
  if(!name || !date){ 
      alert('Event Name and Date are required'); 
      return; 
  }
  
  const payload = {
      title: name,
      description: desc,
      date: `${date} ${time}:00`,
      location: loc,
      price: 0,
      maxAttendees: 100,
      image: imageData && imageData.trim() !== '' ? imageData : null
  };
  
  try {
      const res = await fetch('/api/events', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
      });
      
      const data = await res.json();
      console.log('Server response:', data);
      
      if(data.success) {
          alert('Event created successfully!');
          closeModal('createEventModal');
          
          // Reset form fields
          nameInput.value = '';
          dateInput.value = '';
          if(timeInput) timeInput.value = '';
          if(descInput) descInput.value = '';
          if(document.getElementById('ev-image-preview')) {
              document.getElementById('ev-image-preview').src = '';
              document.getElementById('ev-image-preview').classList.remove('show');
          }
          if(imageDataInput) imageDataInput.value = '';
          
          loadAllData();
      } else {
          alert('Error from server: ' + (data.error || 'Unknown error occurred'));
      }
  } catch (e) { 
      console.error('Network or Parse error:', e); 
      alert('Failed to create event. Network or server error occurred.'); 
  }
}

function escapeHtml(str){ if(!str)return ''; return String(str).replace(/[&<>]/g,function(m){if(m==='&')return '&amp;';if(m==='<')return '&lt;';if(m==='>')return '&gt;';return m;}); }

renderCal(); switchView();
</script>

