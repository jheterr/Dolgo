<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Door Management' %>

<%- contentFor('style') %>
<style>

        .door-control-box {
      text-align: center;
      padding: 25px;
      background: #f1f5f9;
      border-radius: 12px;
      border: 1px dashed #cbd5e1;
    }

    .door-status-label {
      font-size: 0.7rem;
      font-weight: 700;
      color: #64748b;
      text-transform: uppercase;
      margin-bottom: 5px;
    }

    .door-status-value {
      font-family: 'Poppins', sans-serif;
      font-size: 2.5rem;
      font-weight: 900;
      color: #1e293b;
      transition: 0.3s;
      margin-bottom: 15px;
    }

    .door-status-value.unlocked {
      color:#8C8636 ;
      text-shadow: 0 0 15px rgba(16, 185, 129, 0.2);
    }

    .door-status-value.locked {
      color: #DC6037;
    }

    .door-action-row {
      display: flex;
      gap: 15px;
      justify-content: center;
      margin-top: 10px;
      flex-wrap: wrap;
    }

    .door-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 30px;
      border: none;
      border-radius: 8px;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.75rem;
      font-weight: 800;
      cursor: pointer;
      transition: 0.3s;
    }

    .door-btn:active {
      transform: scale(0.95);
    }

    .door-btn-open {
      background: #8C8636 ;
      color: #fff;
      box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3);
    }

    .door-btn-close {
      background: #DC6037;
      color: #fff;
      box-shadow: 0 4px 10px rgba(239, 68, 68, 0.3);
    }

    /* Table Styles */
    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.75rem;
    }

    .data-table th {
      background-color: #f8fafc;
      padding: 12px 15px;
      text-align: left;
      color: #475569;
      font-weight: 700;
      border-bottom: 2px solid #e2e8f0;
    }

    .data-table td {
      padding: 12px 15px;
      border-bottom: 1px solid #f1f5f9;
      font-weight: 600;
      color: #334155;
    }

    /* Mobile Card View */
    .table-wrap {
      width: 100%;
    }

    @media (min-width: 769px) {
      .mobile-card-view {
        display: none;
      }
      .desktop-table-view {
        display: block;
      }
    }

    @media (max-width: 768px) {
      .desktop-table-view {
        display: none;
      }
      .mobile-card-view {
        display: block;
      }
      
      .activity-timeline {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-height: 450px;
        overflow-y: auto;
      }

      .activity-card {
        background: white;
        border-radius: 12px;
        padding: 12px 14px;
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
      }

      .activity-card:hover {
        background: #fafcff;
        border-color: #cbd5e1;
      }

      .activity-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 8px;
      }

      .activity-user {
        font-weight: 800;
        font-size: 0.85rem;
        color: #1e293b;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }

      .role-badge {
        font-size: 0.55rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        background: #f1f5f9;
        color: #475569;
      }

      .role-badge.staff {
        background: #dbeafe;
        color: #1e40af;
      }

      .role-badge.customer {
        background: #fef3c7;
        color: #92400e;
      }

      .activity-time {
        font-size: 0.6rem;
        color: #94a3b8;
        font-weight: 500;
      }

      .activity-detail {
        font-size: 0.65rem;
        color: #64748b;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 4px;
      }

      .method-tag {
        background: #f1f5f9;
        padding: 2px 8px;
        border-radius: 20px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.6rem;
      }

      .activity-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 30px;
        font-size: 0.6rem;
        font-weight: 700;
      }

      .activity-badge.success {
        background: #d1fae5;
        color: #065f46;
      }

      .activity-badge.danger {
        background: #fee2e2;
        color: #991b1b;
      }

      .empty-logs {
        text-align: center;
        padding: 30px;
        color: #94a3b8;
      }

      .mobile-menu-btn {
        display: flex;
      }
      .content {
        padding-top: 75px;
      }
      .door-action-row {
        flex-direction: column;
        align-items: center;
      }
      .door-btn {
        width: 100%;
        justify-content: center;
      }
      .table-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    .badge {
      padding: 4px 10px;
      border-radius: 12px;
      font-size: 0.65rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    .badge-green {
      background: #d1fae5;
      color: #8C8636;
    }

    .badge-red {
      background: #fee2e2;
      color: #DC6037;
    }

    .rfid-tag {
      font-family: 'Montserrat', sans-serif;
      background: #e2e8f0;
      padding: 2px 6px;
      border-radius: 4px;
      color: #475569;
      font-size: 0.7rem;
    }

    .method-system {
      color: #64748b;
      font-style: italic;
      font-weight: 500;
      font-size: 0.7rem;
    }

    .filter-group {
      display: flex;
      gap: 8px;
    }

    .filter-btn {
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 700;
      cursor: pointer;
      border: 1.5px solid #e2e8f0;
      background: white;
      color: #64748b;
      transition: 0.2s;
    }

    .filter-btn.active {
      background: #CF6322;
      color: white;
      border-color: #CF6322;
    }

    .table-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 18px;
      flex-wrap: wrap;
      gap: 12px;
    }

    /* Fixed Mobile Menu Button - Right Side */
    .mobile-menu-btn {
      position: fixed;
      top: 18px;
      right: 18px;
      z-index: 200;
      width: 42px;
      height: 42px;
      background: var(--orange);
      color: white;
      border: none;
      border-radius: var(--radius-sm);
      display: none;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      box-shadow: var(--shadow);
    }

    .page-header {
      color: var(--orange);
      font-size: 1.65rem;
      font-weight: 800;
      margin-bottom: 28px;
      font-family: 'Poppins', sans-serif;
    }

    @media (max-width: 768px) {
      .table-header {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
      }
      .filter-group {
        gap: 6px;
      }
      .filter-btn {
        padding: 5px 12px;
        font-size: 0.65rem;
      }
    }

    @media (max-width: 480px) {
      .table-header {
        flex-direction: row;
        flex-wrap: wrap;
      }
      .filter-group {
        gap: 5px;
      }
      .filter-btn {
        padding: 4px 10px;
        font-size: 0.6rem;
      }
    }
  
</style>

<div class="app">

  <%- include('../partials/admin_sidebar', { active: 'Door Management' }) %>

  <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>

  <!-- Main Content -->
  <main class="content">
    <!-- Fixed Mobile Menu Button - Right Side -->
    <button class="mobile-menu-btn" onclick="openSidebar()">
      <i class="fa-solid fa-bars"></i>
    </button>

    <div class="page-header">
      <h1 class="page-title">Door Management</h1>
    </div>

    <div class="card">
      <h3 class="section-title">Manual System Override</h3>
      <div class="door-control-box">
        <div class="door-status-label">Magnetic Lock Status</div>
        <div class="door-status-value locked" id="doorVal">LOCKED</div>
        <div class="door-action-row">
          <button class="door-btn door-btn-open" onclick="triggerDoor('UNLOCKED', 'Admin', 'Manual Console')">
            <i class="fa-solid fa-lock-open"></i> OPEN DOOR
          </button>
          <button class="door-btn door-btn-close" onclick="triggerDoor('LOCKED', 'Admin', 'Manual Console')">
            <i class="fa-solid fa-lock"></i> CLOSE DOOR
          </button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="table-header">
        <h3 class="section-title" style="margin-bottom:0">Access & Activity Logs</h3>
        <div class="filter-group" id="desktopFilterGroup">
          <div class="search-container" style="position:relative; margin-right:10px;">
            <i class="fa-solid fa-magnifying-glass" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:12px;"></i>
            <input type="text" id="logSearchInput" placeholder="Search name or door..." 
                   style="padding:6px 14px 6px 34px; border:1.5px solid #e2e8f0; border-radius:20px; font-size:0.7rem; outline:none;"
                   oninput="handleSearch()">
          </div>
          <button class="filter-btn active" data-filter="all" onclick="filterLogs('all', this)">All Activity</button>
          <button class="filter-btn" data-filter="granted" onclick="filterLogs('granted', this)">Granted</button>
          <button class="filter-btn" data-filter="unlocked" onclick="filterLogs('unlocked', this)">Unlocked</button>
          <button class="filter-btn" data-filter="denied" onclick="filterLogs('denied', this)">Denied</button>
        </div>
      </div>
      
      <!-- DESKTOP TABLE VIEW -->
      <div class="desktop-table-view">
        <div class="table-wrap">
          <table class="data-table" id="desktopLogTable">
            <thead>
              <tr>
                <th>Name</th>
                <th>Role</th>
                <th>Time</th>
                <th>RFID / Method</th>
                <th>Activity</th>
              </tr>
            </thead>
            <tbody id="desktopLogBody"></tbody>
          </table>
        </div>
      </div>

      <!-- MOBILE CARD VIEW (No large icons) -->
      <div class="mobile-card-view">
        <div class="activity-timeline" id="mobileActivityTimeline"></div>
      </div>
    </div>
  </main>
</div>

<%- contentFor('script') %>
<script>
// Current User Data
const currentUser = <%- JSON.stringify(locals.user || {}) %>;

// Activity Logs Data
let activityLogs = [];
let filteredLogs = [];
let currentFilter = "all";
let searchTerm = "";

async function fetchLogs() {
  try {
    const res = await fetch('/api/door-logs');
    const data = await res.json();
    activityLogs = data.logs || [];
    applyFilters();
  } catch (err) {
    console.error('Error fetching logs:', err);
  }
}

function applyFilters() {
  filteredLogs = [...activityLogs];
  
  if (currentFilter !== "all") {
    filteredLogs = filteredLogs.filter(log => log.status === currentFilter);
  }
  
  if (searchTerm) {
    const term = searchTerm.toLowerCase();
    filteredLogs = filteredLogs.filter(log => 
      (log.first_name && log.first_name.toLowerCase().includes(term)) ||
      (log.last_name && log.last_name.toLowerCase().includes(term)) ||
      (log.door_name && log.door_name.toLowerCase().includes(term)) ||
      (log.method && log.method.toLowerCase().includes(term))
    );
  }
  
  renderDesktopLogs();
  renderMobileLogs();
}

function handleSearch() {
  searchTerm = document.getElementById('logSearchInput').value;
  applyFilters();
}

// Helper: Escape HTML
function escapeHtml(str) {
  if (!str) return '';
  return String(str).replace(/[&<>]/g, function(m) {
    if (m === '&') return '&amp;';
    if (m === '<') return '&lt;';
    if (m === '>') return '&gt;';
    return m;
  });
}

// ========== DESKTOP RENDER ==========
function renderDesktopLogs() {
  const tbody = document.getElementById('desktopLogBody');
  if (!tbody) return;
  
  tbody.innerHTML = filteredLogs.map(log => {
    const status = (log.status || 'denied').toLowerCase();
    const isUnlock = status === 'unlock' || status === 'unlocked' || status === 'granted';
    const badgeClass = isUnlock ? 'badge-green' : 'badge-red';
    const icon = isUnlock ? 'fa-lock-open' : 'fa-lock';
    const name = log.first_name ? `${log.first_name} ${log.last_name}` : 'Unknown';
    const time = new Date(log.access_time).toLocaleString([], { hour: '2-digit', minute: '2-digit', month: 'short', day: 'numeric' });
    
    return `
      <tr>
        <td>${escapeHtml(name)}</td>
        <td><span class="role-badge ${log.role === 'customer' ? 'customer' : 'staff'}">${escapeHtml(log.role || 'N/A')}</span></td>
        <td>${escapeHtml(time)}</td>
        <td><span class="method-tag"><i class="fa-solid fa-door-open"></i> ${escapeHtml(log.method || log.door_name)}</span></td>
        <td><span class="badge ${badgeClass}"><i class="fa-solid ${icon}"></i> ${status.toUpperCase()}</span></td>
      </tr>
    `;
  }).join('');
}

// ========== MOBILE CARD VIEW RENDER ==========
function getMobileCardHTML(log) {
  const status = (log.status || 'denied').toLowerCase();
  const isUnlock = status === 'unlock' || status === 'unlocked' || status === 'granted';
  const badgeClass = isUnlock ? 'success' : 'danger';
  const badgeIcon = isUnlock ? 'fa-lock-open' : 'fa-lock';
  const name = log.first_name ? `${log.first_name} ${log.last_name}` : 'Unknown';
  const time = new Date(log.access_time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  
  let roleBadgeClass = log.role === "customer" ? "customer" : "staff";
  
  return `
    <div class="activity-card">
      <div class="activity-header">
        <div class="activity-user">
          <span>${escapeHtml(name)}</span>
          <span class="role-badge ${roleBadgeClass}">${escapeHtml(log.role || 'N/A')}</span>
        </div>
        <div class="activity-time">
          <i class="fa-regular fa-clock"></i> ${escapeHtml(time)}
        </div>
      </div>
      <div class="activity-detail">
        <span class="method-tag"><i class="fa-solid fa-door-open"></i> ${escapeHtml(log.method || log.door_name)}</span>
        <span class="activity-badge ${badgeClass}">
          <i class="fa-solid ${badgeIcon}"></i> ${status.toUpperCase()}
        </span>
      </div>
    </div>
  `;
}

function renderMobileLogs() {
  const container = document.getElementById('mobileActivityTimeline');
  if (!container) return;
  
  if (filteredLogs.length === 0) {
    container.innerHTML = `<div class="empty-logs"><i class="fa-regular fa-folder-open"></i><p>No activity logs found</p></div>`;
  } else {
    container.innerHTML = filteredLogs.map(log => getMobileCardHTML(log)).join('');
  }
}

// ========== FILTER FUNCTION ==========
function filterLogs(filterType, btn) {
  currentFilter = filterType;
  
  const desktopGroup = document.getElementById('desktopFilterGroup');
  if (desktopGroup) {
    desktopGroup.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  }
  btn.classList.add('active');
  
  applyFilters();
}

// ========== DOOR TRIGGER FUNCTION ==========
async function triggerDoor(status, role, method) {
  // UI Feedback
  const el = document.getElementById('doorVal');
  el.textContent = status;
  el.className = 'door-status-value ' + (status === 'UNLOCKED' ? 'unlocked' : 'locked');
  
  // Submit log to backend
  try {
    await fetch('/api/door-logs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        user_id: currentUser.id || 1, // Fallback to admin if not found
        door_name: 'Main Door',
        status: status.toLowerCase(), // 'unlocked' or 'locked'
        method: method
      })
    });
    
    // Refresh the logs
    fetchLogs();
  } catch (err) {
    console.error('Error logging door action:', err);
  }
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
  fetchLogs();
  
  const doorVal = document.getElementById('doorVal');
  if (doorVal && doorVal.textContent === 'LOCKED') {
    doorVal.className = 'door-status-value locked';
  }
});
</script>

