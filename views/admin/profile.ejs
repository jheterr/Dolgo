<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Profile' %>

<%- contentFor('head') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">

<%- contentFor('style') %>
<style>
  /* ── Layout ── */
  .profile-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 20px;
  }
  @media(max-width:800px){ .profile-layout{ grid-template-columns:1fr; } }

  /* ── Profile Card ── */
  .profile-card {
    border-radius: 20px;
    padding: 32px 20px;
    background: #fff;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 20px rgba(0,0,0,.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
  }
  .avatar-wrapper {
    position: relative;
    cursor: pointer;
    width: 110px;
    height: 110px;
    margin-bottom: 4px;
  }
  .avatar {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: linear-gradient(135deg,#254b7a,#2E6098);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Poppins',sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: #fff;
    box-shadow: 0 6px 20px rgba(30,58,95,.25);
    overflow: hidden;
    transition: filter .2s;
  }
  .avatar img { width:100%; height:100%; object-fit:cover; }
  .avatar-wrapper:hover .avatar { filter: brightness(.85); }
  .cam-badge {
    position: absolute;
    bottom: 2px;
    right: 2px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--orange,#e47a2e);
    border: 3px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 13px;
    box-shadow: 0 2px 8px rgba(0,0,0,.2);
    transition: transform .2s;
  }
  .avatar-wrapper:hover .cam-badge { transform: scale(1.1); }
  .profile-name { font-family:'Poppins',sans-serif; font-size:1.05rem; font-weight:800; color:#1e293b; }
  .profile-email { font-size:12px; color:#64748b; }
  .role-tag {
    background: var(--orange,#e47a2e);
    color:#fff;
    padding:3px 14px;
    border-radius:20px;
    font-size:11px;
    font-weight:700;
    letter-spacing:.06em;
  }

  /* ── Info Card ── */
  .info-card {
    border-radius: 20px;
    padding: 24px;
    background: #fff;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 20px rgba(0,0,0,.06);
  }
  .info-title {
    font-family:'Poppins',sans-serif;
    font-size:.9rem;
    font-weight:700;
    padding-bottom:12px;
    border-bottom:2px solid #f1f5f9;
    margin-bottom:4px;
  }
  .info-field { display:flex; align-items:center; gap:14px; padding:12px 0; border-bottom:1px solid #f1f5f9; }
  .info-field:last-child { border-bottom:none; }
  .info-icon {
    width:36px; height:36px; border-radius:9px;
    background:#fff7ed; display:flex; align-items:center;
    justify-content:center; color:var(--orange,#e47a2e); font-size:.85rem; flex-shrink:0;
  }
  .info-lbl { font-size:10px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:.05em; margin-bottom:2px; }
  .info-val { font-size:13px; font-weight:700; color:#1e293b; }

  /* ── Base Modal ── */
  .modal-overlay {
    position:fixed; inset:0;
    background:rgba(15,23,42,.55);
    display:none; align-items:center; justify-content:center;
    z-index:1000; padding:16px;
    backdrop-filter: blur(4px);
  }
  .modal-overlay.open { display:flex; }

  /* Standard modal (edit profile) */
  .modal-std {
    background:#fff; border-radius:20px; padding:28px;
    width:100%; max-width:480px;
    box-shadow:0 25px 60px rgba(0,0,0,.18);
    display:flex; flex-direction:column; gap:16px;
    max-height:90vh; overflow-y:auto;
  }
  .modal-header { display:flex; align-items:center; justify-content:space-between; }
  .modal-title { font-family:'Poppins',sans-serif; font-size:1rem; font-weight:800; }
  .modal-close { background:none; border:none; font-size:1.4rem; color:#94a3b8; cursor:pointer; line-height:1; }
  .modal-close:hover { color:#1e293b; }
  .modal-body { display:flex; flex-direction:column; gap:14px; }
  .modal-footer { display:flex; justify-content:flex-end; gap:10px; }

  /* ── Photo Choice Modal ── */
  .photo-modal {
    background:#fff; border-radius:24px; padding:36px 32px 28px;
    width:100%; max-width:500px;
    box-shadow:0 30px 60px rgba(0,0,0,.18);
    position:relative; text-align:center;
  }
  .photo-modal-close {
    position:absolute; top:18px; right:20px;
    background:#f1f5f9; border:none; border-radius:50%;
    width:32px; height:32px; display:flex; align-items:center;
    justify-content:center; cursor:pointer; color:#64748b;
    font-size:16px; transition:all .2s;
  }
  .photo-modal-close:hover { background:#e2e8f0; color:#1e293b; }
  .photo-modal-icon {
    width:64px; height:64px; border-radius:50%;
    background:linear-gradient(135deg,#fff7ed,#fee2c3);
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 16px; font-size:28px; color:var(--orange,#e47a2e);
  }
  .photo-modal-title { font-family:'Poppins',sans-serif; font-size:1.3rem; font-weight:800; color:#0f172a; margin-bottom:6px; }
  .photo-modal-sub { font-size:13px; color:#94a3b8; margin-bottom:24px; }


  /* Choice row */
  .choice-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px; }
  .choice-card {
    display:flex; flex-direction:column; align-items:center; gap:10px;
    padding:20px 12px; border-radius:16px; border:1.5px solid #e2e8f0;
    background:#fafafa; cursor:pointer; transition:all .2s;
  }
  .choice-card:hover {
    border-color:var(--orange,#e47a2e);
    background:#fff7ed;
    transform:translateY(-3px);
    box-shadow:0 6px 20px rgba(228,122,46,.12);
  }
  .choice-card-icon {
    width:48px; height:48px; border-radius:14px;
    display:flex; align-items:center; justify-content:center;
    font-size:20px; transition:.2s;
  }
  .choice-card-icon.upload { background:#eff6ff; color:#3b82f6; }
  .choice-card-icon.camera { background:#f0fdf4; color:#22c55e; }
  .choice-card:hover .choice-card-icon.upload { background:#dbeafe; }
  .choice-card:hover .choice-card-icon.camera { background:#dcfce7; }
  .choice-card span { font-size:12px; font-weight:700; color:#475569; }

  /* ── Camera Modal ── */
  .camera-modal {
    background: #fff; border-radius: 24px; padding: 28px;
    width: 100%; max-width: 460px;
    box-shadow: 0 30px 60px rgba(0,0,0,.18);
    position: relative; text-align: center;
  }
  .camera-modal-title { font-family: 'Poppins', sans-serif; font-size: 1.1rem; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
  .camera-modal-sub { font-family: 'Poppins', sans-serif; font-size: 12px; color: #64748b; margin-bottom: 20px; }
  .camera-viewport {
    position: relative; border-radius: 16px; overflow: hidden;
    background: #000; aspect-ratio: 1; width: 100%;
    box-shadow: 0 0 0 3px rgba(226, 232, 240, 1);
  }
  #video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .camera-ring {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 70%; height: 70%;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,.6);
    box-shadow: 0 0 0 9999px rgba(0,0,0,.45);
    pointer-events: none;
  }
  canvas#canvas { display: none; }
  .shutter-row { display: flex; align-items: center; justify-content: center; gap: 20px; margin-top: 22px; }
  .shutter-btn {
    width: 68px; height: 68px; border-radius: 50%;
    background: #fff; border: 5px solid #e2e8f0;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all .15s;
    box-shadow: 0 4px 16px rgba(0,0,0,.1);
  }
  .shutter-btn:hover { transform: scale(1.08); border-color: var(--orange, #e47a2e); }
  .shutter-btn i { font-size: 26px; color: var(--orange, #e47a2e); }
  .camera-modal-close {
    position:absolute; top:18px; right:20px;
    background:#f1f5f9; border:none; border-radius:50%;
    width:32px; height:32px; display:flex; align-items:center;
    justify-content:center; cursor:pointer; color:#64748b;
    font-size:16px; transition:all .2s;
    z-index: 100;
  }
  .camera-modal-close:hover { background:#e2e8f0; color:#1e293b; }

  /* Camera Preview State */
  .camera-modal.preview-mode .camera-ring,
  .camera-modal.preview-mode .shutter-row { display:none; }
  
  .camera-preview-img {
    width: 100%; height: 100%; object-fit: cover; display: none;
    border-radius: 16px;
    position: absolute;
    top: 0; left: 0;
    z-index: 10;
  }
  .camera-modal.preview-mode .camera-preview-img { display: block; }
  .camera-modal.preview-mode .camera-viewport { box-shadow: 0 0 0 3px rgba(255,255,255,.05); }
  
  .preview-controls { display:none; gap:12px; margin-top:22px; justify-content:center; }
  .camera-modal.preview-mode .preview-controls { display:flex; }
  
  .btn-approve {
    background: var(--orange, #e47a2e); color:#fff; border:none; padding:12px 24px;
    border-radius:10px; font-family: 'Poppins', sans-serif; font-weight:800; cursor:pointer; font-size:14px;
    display:flex; align-items:center; gap:8px; transition:.2s;
  }
  .btn-approve:hover { background: #d96f26; transform:translateY(-2px); box-shadow: 0 4px 12px rgba(228,122,46,.3); }
  
  .btn-retake {
    background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0;
    padding: 12px 24px; border-radius: 10px; font-family: 'Poppins', sans-serif; font-weight: 700; cursor: pointer; font-size: 14px;
    transition: .2s;
  }
  .btn-retake:hover { background: #e2e8f0; color: #1e293b; }

  /* ── Crop Modal ── */
  .crop-modal {
    background:#fff; border-radius:24px; padding:28px;
    width:100%; max-width:580px;
    box-shadow:0 30px 60px rgba(0,0,0,.18);
    display:flex; flex-direction:column; gap:16px;
  }
  .crop-container { border-radius:12px; overflow:hidden; background:#0f172a; max-height:380px; }
  #cropImage { max-width:100%; display:block; }
  .crop-hint { font-size:12px; color:#94a3b8; text-align:center; margin-top:-8px; }
</style>

<%- contentFor('body') %>
<%
  const initials = (user.firstName && user.lastName) ? (user.firstName[0]+user.lastName[0]).toUpperCase() : 'LM';
  const fullName = (user.firstName && user.lastName) ? `${user.firstName} ${user.lastName}` : 'Admin User';
%>
<div class="app">
  <%- include('../partials/admin_sidebar', { active: 'Profile' }) %>
  <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>
  <main class="content">
    <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>
    <h1 class="page-title">Profile</h1>

    <div class="profile-layout">
      <!-- Left Card -->
      <div class="profile-card">
        <div class="avatar-wrapper" onclick="openModal('photoChoiceModal')">
          <div class="avatar" id="profileAvatar">
            <% if (user.profile_picture) { %>
              <img src="<%= user.profile_picture %>" alt="Profile" id="avatarImg">
            <% } else { %>
              <span id="avatarInitials"><%= initials %></span>
            <% } %>
          </div>
          <div class="cam-badge"><i class="fa-solid fa-camera"></i></div>
        </div>
        <input type="file" id="profileInput" style="display:none" accept="image/*" onchange="handleFileSelect(this)">

        <div class="profile-name" id="profileName"><%= fullName %></div>
        <div class="profile-email" id="profileEmail"><%= user.email %></div>
        <div class="role-tag"><%= user.role.toUpperCase() %></div>
        <button class="btn btn-ghost" style="margin-top:6px" onclick="openModal('editProfileModal')">
          <i class="fa-solid fa-pen"></i> Edit Profile
        </button>
      </div>

      <!-- Right Info Card -->
      <div class="info-card">
        <div class="info-title">Account Information</div>
        <div class="info-field">
          <div class="info-icon"><i class="fa-solid fa-user"></i></div>
          <div><div class="info-lbl">Full Name</div><div class="info-val" id="infoName"><%= fullName %></div></div>
        </div>
        <div class="info-field">
          <div class="info-icon"><i class="fa-solid fa-envelope"></i></div>
          <div><div class="info-lbl">Email Address</div><div class="info-val" id="infoEmail"><%= user.email %></div></div>
        </div>
        <div class="info-field">
          <div class="info-icon"><i class="fa-solid fa-shield-halved"></i></div>
          <div><div class="info-lbl">Role</div><div class="info-val"><%= user.role.charAt(0).toUpperCase()+user.role.slice(1) %></div></div>
        </div>
        <div class="info-field">
          <div class="info-icon"><i class="fa-solid fa-circle-check"></i></div>
          <div><div class="info-lbl">Account Status</div><div class="info-val" style="color:#16a34a">Active</div></div>
        </div>
        <div class="info-field">
          <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
          <div><div class="info-lbl">Contact Number</div><div class="info-val" id="infoPhone"><%= user.phone || 'Not set' %></div></div>
        </div>
        <div class="info-field">
          <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
          <div><div class="info-lbl">Location</div><div class="info-val" id="infoLocation"><%= user.location || 'Philippines' %></div></div>
        </div>
      </div>
    </div>

    <!-- ── Edit Profile Modal ── -->
    <div class="modal-overlay" id="editProfileModal">
      <div class="modal-std">
        <div class="modal-header">
          <div class="modal-title"><i class="fa-solid fa-pen"></i> Edit Profile</div>
          <button class="modal-close" onclick="closeModal('editProfileModal')">&times;</button>
        </div>
        <div class="modal-body">
          <div class="form-group"><label class="form-label">Full Name</label><input class="form-control" id="ep-name" type="text" value="<%= fullName %>"></div>
          <div class="form-group"><label class="form-label">Email</label><input class="form-control" type="email" value="<%= user.email %>" disabled></div>
          <div class="form-group"><label class="form-label">Contact Number</label><input class="form-control" id="ep-phone" type="tel" value="<%= user.phone||'' %>" placeholder="09xxxxxxxxx"></div>
          <div class="form-group"><label class="form-label">Location</label><input class="form-control" id="ep-loc" type="text" value="<%= user.location||'' %>" placeholder="City, Country"></div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-ghost" onclick="closeModal('editProfileModal')">Cancel</button>
          <button class="btn btn-primary" onclick="saveProfile()"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
        </div>
      </div>
    </div>

    <!-- ── Photo Choice Modal ── -->
    <div class="modal-overlay" id="photoChoiceModal">
      <div class="photo-modal">
        <button class="photo-modal-close" onclick="closeModal('photoChoiceModal')"><i class="fa-solid fa-xmark"></i></button>

        <div class="photo-modal-icon"><i class="fa-solid fa-image"></i></div>
        <div class="photo-modal-title">Change Profile Photo</div>
        <div class="photo-modal-sub">Upload from your device or snap a selfie</div>


        <!-- Choice buttons -->
        <div class="choice-row">
          <div class="choice-card" onclick="triggerFileUpload()">
            <div class="choice-card-icon upload"><i class="fa-solid fa-cloud-arrow-up"></i></div>
            <span>Upload Photo</span>
          </div>
          <div class="choice-card" onclick="startCamera()">
            <div class="choice-card-icon camera"><i class="fa-solid fa-camera"></i></div>
            <span>Take a Selfie</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Camera Modal ── -->
    <div class="modal-overlay" id="cameraModal">
      <div class="camera-modal">
        <button class="camera-modal-close" onclick="stopCamera()"><i class="fa-solid fa-xmark"></i></button>
        <div class="camera-modal-title">Take a Selfie</div>
        <div class="camera-modal-sub">Center your face, then press the shutter button</div>

        <div class="camera-viewport">
          <video id="video" autoplay playsinline></video>
          <img id="cameraPreview" class="camera-preview-img">
          <div class="camera-ring"></div>
        </div>
        <canvas id="canvas"></canvas>

        <div class="shutter-row">
          <div class="shutter-btn" onclick="takeSnapshot()"><i class="fa-solid fa-camera"></i></div>
        </div>

        <div class="preview-controls">
          <button class="btn-retake" onclick="retakePhoto()">Retake</button>
          <button class="btn-approve" onclick="approvePhoto()" id="btnApprove">
            <i class="fa-solid fa-floppy-disk"></i> Save Image
          </button>
        </div>
      </div>
    </div>

    <!-- ── Crop Modal ── -->
    <div class="modal-overlay" id="cropModal">
      <div class="crop-modal">
        <div class="modal-header">
          <div class="modal-title"><i class="fa-solid fa-crop-simple"></i> Crop Photo</div>
          <button class="modal-close" onclick="closeModal('cropModal')">&times;</button>
        </div>
        <div class="crop-container">
          <img id="cropImage" src="">
        </div>
        <div class="crop-hint"><i class="fa-solid fa-arrows-up-down-left-right"></i> Drag to reposition · Scroll to zoom</div>
        <div class="modal-footer">
          <button class="btn btn-ghost" onclick="closeModal('cropModal')">Cancel</button>
          <button class="btn btn-primary" onclick="applyCrop()"><i class="fa-solid fa-check"></i> Apply &amp; Save</button>
        </div>
      </div>
    </div>

  </main>
</div>

<%- contentFor('script') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<script>
  /* ── Helpers ── */
  function openSidebar(){ document.getElementById('sidebar').classList.add('mobile-open'); document.getElementById('mobileOverlay').classList.add('show'); }
  function closeSidebar(){ document.getElementById('sidebar').classList.remove('mobile-open'); document.getElementById('mobileOverlay').classList.remove('show'); }
  function openModal(id){ document.getElementById(id).classList.add('open'); }
  function closeModal(id){ document.getElementById(id).classList.remove('open'); }


  /* ── File Upload ── */
  function triggerFileUpload(){ document.getElementById('profileInput').click(); }
  function handleFileSelect(input){ if(input.files && input.files[0]) loadImageForCrop(input.files[0]); }

  /* ── Load image into cropper ── */
  function loadImageForCrop(file){
    closeModal('photoChoiceModal');
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.getElementById('cropImage');
      img.src = e.target.result;
      openModal('cropModal');
      if(cropper) cropper.destroy();
      cropper = new Cropper(img, { aspectRatio: 1, viewMode: 2, autoCropArea: 0.9 });
    };
    reader.readAsDataURL(file);
  }

  /* ── Camera ── */
  let cropper, videoStream;

  async function startCamera(){
    closeModal('photoChoiceModal');
    openModal('cameraModal');
    try {
      videoStream = await navigator.mediaDevices.getUserMedia({ video: { width:640, height:640, facingMode:'user' }, audio: false });
      document.getElementById('video').srcObject = videoStream;
    } catch(err){
      alert('Could not access camera. Check browser permissions.');
      closeModal('cameraModal');
    }
  }

  function stopCamera(){
    if(videoStream) videoStream.getTracks().forEach(t => t.stop());
    videoStream = null;
    document.querySelector('.camera-modal').classList.remove('preview-mode');
    closeModal('cameraModal');
  }

  let capturedImageBase64 = null;

  function takeSnapshot(){
    const video = document.getElementById('video');
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    
    // Proportional center crop based on the 70% guide ring
    const size = Math.min(video.videoWidth, video.videoHeight);
    const cropSize = size * 0.7;
    const startX = (video.videoWidth - cropSize) / 2;
    const startY = (video.videoHeight - cropSize) / 2;
    
    canvas.width = 400; // Standard save size
    canvas.height = 400;
    
    ctx.drawImage(video, startX, startY, cropSize, cropSize, 0, 0, 400, 400);
    
    capturedImageBase64 = canvas.toDataURL('image/jpeg', 0.9);
    
    const preview = document.getElementById('cameraPreview');
    preview.src = capturedImageBase64;
    document.querySelector('.camera-modal').classList.add('preview-mode');
    
    // Prevent accidental double-click by adding a tiny delay before button is 'ready'
    const btn = document.getElementById('btnApprove');
    btn.disabled = true;
    btn.style.opacity = '0.5';
    setTimeout(() => {
      btn.disabled = false;
      btn.style.opacity = '1';
    }, 500);
  }

  function retakePhoto() {
    document.querySelector('.camera-modal').classList.remove('preview-mode');
    capturedImageBase64 = null;
  }

  async function approvePhoto() {
    if(!capturedImageBase64) return;
    
    const btn = document.getElementById('btnApprove');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
    
    try {
      const res = await fetch('/api/users/profile-picture', {
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ image: capturedImageBase64 })
      });
      const data = await res.json();
      if(data.success){
        document.getElementById('profileAvatar').innerHTML = `<img src="${capturedImageBase64}" alt="Profile" id="avatarImg">`;
        // Also update the sidebar if it exists
        const sidebarAvatar = document.querySelector('.sidebar-user-img img');
        if(sidebarAvatar) sidebarAvatar.src = capturedImageBase64;
        
        stopCamera();
        alert('Profile picture updated successfully!');
      } else {
        alert('Error: ' + (data.error || 'Unknown error'));
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Image';
      }
    } catch(e){
      alert('Failed to save profile picture.');
      btn.disabled = false;
      btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Image';
    }
  }

  /* ── Apply Crop & Save ── */
  async function applyCrop(){
    if(!cropper) return;
    const canvas = cropper.getCroppedCanvas({ width: 320, height: 320 });
    const base64 = canvas.toDataURL('image/jpeg', 0.85);

    const btn = document.querySelector('#cropModal .btn-primary');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving…';

    try {
      const res = await fetch('/api/users/profile-picture', {
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ image: base64 })
      });
      const data = await res.json();
      if(data.success){
        document.getElementById('profileAvatar').innerHTML = `<img src="${base64}" alt="Profile" id="avatarImg">`;
        closeModal('cropModal');
      } else {
        alert('Error: ' + (data.error || 'Unknown error'));
      }
    } catch(e){
      alert('Failed to save profile picture.');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fa-solid fa-check"></i> Apply & Save';
    }
  }

  /* ── Save Profile Info ── */
  async function saveProfile(){
    const name = document.getElementById('ep-name').value.trim();
    const phone = document.getElementById('ep-phone').value.trim();
    const loc = document.getElementById('ep-loc').value.trim();
    if(!name){ alert('Full Name is required'); return; }

    try {
      const parts = name.split(' ');
      const res = await fetch('/api/users/profile', {
        method:'PUT',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ firstName: parts[0], lastName: parts.slice(1).join(' '), phone, location: loc })
      });
      const data = await res.json();
      if(data.success){
        document.getElementById('profileName').textContent = name;
        document.getElementById('infoName').textContent = name;
        document.getElementById('infoPhone').textContent = phone || 'Not set';
        document.getElementById('infoLocation').textContent = loc || 'Philippines';
        if(!document.getElementById('avatarImg')){
          document.getElementById('avatarInitials').textContent = parts.map(w=>w[0]).join('').substring(0,2).toUpperCase();
        }
        closeModal('editProfileModal');
      }
    } catch(e){ alert('Failed to update profile.'); }
  }
</script>
