<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Profile' %>

<%- contentFor('style') %>
<style>

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .45);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 16px;
    }

    .modal-overlay.open {
      display: flex;
    }

    .modal {
      background: var(--white);
      border-radius: var(--radius);
      padding: 28px;
      width: 100%;
      max-width: 480px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
      display: flex;
      flex-direction: column;
      gap: 16px;
      max-height: 90vh;
      overflow-y: auto;
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .modal-title {
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 700;
    }

    .modal-close {
      background: none;
      border: none;
      font-size: 1.3rem;
      color: var(--text-sm);
      cursor: pointer;
    }

    .modal-body {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .profile-layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 16px;
    }

    .profile-card {
      border-radius: var(--radius);
      padding: 28px 20px;
      background: var(--white);
      border: 1px solid rgba(226, 232, 240, .8);
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
    }

    .avatar {
      width: 90px;
      height: 90px;
      border-radius: 50%;
      background: linear-gradient(135deg, #254b7a, #2E6098);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Poppins', sans-serif;
      font-size: 1.7rem;
      font-weight: 800;
      color: #fff;
      box-shadow: 0 4px 14px rgba(30, 58, 95, .2);
    }

    .profile-name {
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 700;
    }

    .profile-email {
      font-size: 12px;
      color: var(--text-sm);
    }

    .role-tag {
      background: var(--orange);
      color: #fff;
      padding: 3px 14px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .06em;
    }

    .info-card {
      border-radius: var(--radius);
      padding: 22px;
      background: var(--white);
      border: 1px solid rgba(226, 232, 240, .8);
      box-shadow: var(--shadow);
    }

    .info-title {
      font-family: 'Poppins', sans-serif;
      font-size: .9rem;
      font-weight: 700;
      padding-bottom: 12px;
      border-bottom: 2px solid var(--border);
      margin-bottom: 4px;
    }

    .info-field {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }

    .info-field:last-child {
      border-bottom: none;
    }

    .info-icon {
      width: 36px;
      height: 36px;
      border-radius: 9px;
      background: var(--cream-lt);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--orange);
      font-size: .9rem;
      flex-shrink: 0;
    }

    .info-lbl {
      font-size: 10px;
      font-weight: 700;
      color: var(--text-sm);
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 2px;
    }

    .info-val {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
    }

    @media(max-width:800px) {
      .profile-layout {
        grid-template-columns: 1fr;
      }
    }
  
</style>

<%- contentFor('body') %>
<% 
  const initials = (user.firstName && user.lastName) ? (user.firstName[0] + user.lastName[0]).toUpperCase() : 'LM';
  const fullName = (user.firstName && user.lastName) ? `${user.firstName} ${user.lastName}` : 'Admin User';
%>
<div class="toast-stack" id="toastStack"></div>
  <div class="app">
    <%- include('../partials/admin_sidebar', { active: 'Profile' }) %>
    <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>
    <main class="content">
      <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>

      <h1 class="page-title">Profile</h1>
      <div class="profile-layout">
        <div class="profile-card">
          <div class="avatar" id="avatarInitials"><%= initials %></div>
          <div class="profile-name" id="profileName"><%= fullName %></div>
          <div class="profile-email" id="profileEmail"><%= user.email %></div>
          <div class="role-tag"><%= user.role.toUpperCase() %></div>
          <button class="btn btn-ghost" style="margin-top:6px" onclick="openModal('editProfileModal')"><i
              class="fa-solid fa-pen"></i> Edit Profile</button>
        </div>
        <div class="info-card">
          <div class="info-title">Account Information</div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-user"></i></div>
            <div>
              <div class="info-lbl">Full Name</div>
              <div class="info-val" id="infoName"><%= fullName %></div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-envelope"></i></div>
            <div>
              <div class="info-lbl">Email Address</div>
              <div class="info-val" id="infoEmail"><%= user.email %></div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-shield-halved"></i></div>
            <div>
              <div class="info-lbl">Role</div>
              <div class="info-val"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-calendar"></i></div>
            <div>
              <div class="info-lbl">Account Status</div>
              <div class="info-val" style="color:#166534; font-weight:800;">Active</div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
            <div>
              <div class="info-lbl">Contact Number</div>
              <div class="info-val" id="infoPhone"><%= user.phone || 'Not set' %></div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
            <div>
              <div class="info-lbl">Location</div>
              <div class="info-val" id="infoLocation"><%= user.location || 'Philippines' %></div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-overlay" id="editProfileModal">
        <div class="modal">
          <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-pen"></i> Edit Profile</div><button class="modal-close"
              onclick="closeModal('editProfileModal')">&times;</button>
          </div>
          <div class="modal-body">
            <div class="form-group"><label class="form-label">Full Name</label><input class="form-control" id="ep-name"
                type="text" value="<%= fullName %>"></div>
            <div class="form-group"><label class="form-label">Email Address</label><input class="form-control"
                id="ep-email" type="email" value="<%= user.email %>" readonly disabled></div>
            <div class="form-group"><label class="form-label">Contact Number</label><input class="form-control"
                id="ep-phone" type="tel" value="<%= user.phone || '' %>" placeholder="09xxxxxxxxx"></div>
            <div class="form-group"><label class="form-label">Location</label><input class="form-control" id="ep-loc"
                type="text" value="<%= user.location || '' %>" placeholder="City, Country"></div>
          </div>
          <div class="modal-footer"><button class="btn btn-ghost"
              onclick="closeModal('editProfileModal')">Cancel</button><button class="btn btn-primary"
              onclick="saveProfile()"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button></div>
        </div>
      </div>
    </main>
  </div>

<%- contentFor('script') %>
<script>
    function openSidebar() {
      document.getElementById('sidebar').classList.add('mobile-open');
      document.getElementById('mobileOverlay').classList.add('show');
    }

    function closeSidebar() {
      document.getElementById('sidebar').classList.remove('mobile-open');
      document.getElementById('mobileOverlay').classList.remove('show');
    }

    function openModal(id) {
      document.getElementById(id).classList.add('open');
    }

    function closeModal(id) {
      document.getElementById(id).classList.remove('open');
    }

    function saveProfile() {
      // For now, this is a UI update only until we add the /api/profile update route
      const name = document.getElementById('ep-name').value.trim();
      const phone = document.getElementById('ep-phone').value.trim();
      const loc = document.getElementById('ep-loc').value.trim();

      if (!name) {
        alert('Full Name is required');
        return;
      }

      document.getElementById('profileName').textContent = name;
      document.getElementById('infoName').textContent = name;
      document.getElementById('infoPhone').textContent = phone || 'Not set';
      document.getElementById('infoLocation').textContent = loc || 'Philippines';

      const initials = name.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
      document.getElementById('avatarInitials').textContent = initials;

      alert('Profile updated successfully (UI Only)');
      closeModal('editProfileModal');
    }
  </script>
