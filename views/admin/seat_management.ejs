    async function loadTransferRequests() {
        try {
            const res = await fetch('/api/transfer-requests');
            const data = await res.json();
            const container = document.querySelector('.transfer-card');
            const info = container.querySelector('.transfer-info');
            
            if (data.requests && data.requests.length > 0) {
                container.style.display = 'block';
                const r = data.requests[0]; // Show first pending
                info.innerHTML = `
                    <div class="transfer-name">${r.first_name} ${r.last_name}</div>
                    <div class="transfer-sub">Current: ${r.current_label} → Requested: ${r.requested_label}</div>
                    <div class="transfer-btns">
                        <button class="btn btn-success btn-sm" onclick="acceptTransfer(${r.id})" style="flex:1"><i class="fa-solid fa-check"></i> Accept</button>
                        <button class="btn btn-danger btn-sm" onclick="declineTransfer(${r.id})" style="flex:1"><i class="fa-solid fa-xmark"></i> Decline</button>
                    </div>
                `;
            } else {
                container.style.display = 'none';
            }
        } catch(e) { console.error(e); }
    }

    let allCustomers = [];
    async function fetchCustomersForSelect() {
      try {
        const res = await fetch('/api/users?role=customer');
        const data = await res.json();
        allCustomers = data.users || [];
        
        // Sort descending: active > pending > inactive
        const statusOrder = { 'active': 1, 'pending': 2, 'inactive': 3 };
        allCustomers.sort((a, b) => (statusOrder[a.status] || 99) - (statusOrder[b.status] || 99));

        filterCustomers();
      } catch (e) { console.error('Error fetching customers:', e); }
    }

    function filterCustomers() {
      const searchTerm = document.getElementById('custSearchInput').value.toLowerCase();
      const typeFilter = document.getElementById('custTypeFilter').value;
      const container = document.getElementById('custResultsContainer');
      
      container.style.display = 'block';

      const filtered = allCustomers.filter(c => {
        const fullName = `${c.first_name || ''} ${c.last_name || ''}`.toLowerCase();
        const matchesName = fullName.includes(searchTerm) || (c.email && c.email.toLowerCase().includes(searchTerm));
        const matchesType = typeFilter === 'all' || (c.type && c.type.toLowerCase().includes(typeFilter));
        return matchesName && matchesType;
      });

      if (filtered.length === 0) {
        container.innerHTML = '<div style="padding: 10px; font-size: 12px; color: #94a3b8; text-align: center;">No customers found</div>';
        return;
      }

      container.innerHTML = filtered.map(c => `
        <div onclick="selectCustomerForAssign(${c.id}, '${c.first_name} ${c.last_name}')" 
             style="padding: 10px 14px; border-bottom: 1px solid #f1f5f9; cursor: pointer; transition: 0.2s;"
             class="cust-result-item"
             onmouseover="this.style.background='#f1f5f9'"
             onmouseout="this.style.background='transparent'">
          <div style="font-weight: 700; font-size: 12px; color: #1e293b; display: flex; justify-content: space-between;">
            <span>${c.first_name} ${c.last_name}</span>
            <span style="font-size: 9px; padding: 2px 6px; border-radius: 4px; background: ${c.status === 'active' ? '#dcfce7' : '#fee2e2'}; color: ${c.status === 'active' ? '#166534' : '#991b1b'};">${c.status.toUpperCase()}</span>
          </div>
          <div style="font-size: 10px; color: #64748b; display: flex; justify-content: space-between;">
            <span>${c.email || ''}</span>
            <span style="text-transform: uppercase; font-weight: 800; color: var(--orange);">${c.type || 'Member'}</span>
          </div>
        </div>
      `).join('');
    }

    window.selectCustomerForAssign = function(id, name) {
      document.getElementById('assignCustId').value = id;
      document.getElementById('assignCustName').value = name;
      document.getElementById('custSearchInput').value = name;
      document.getElementById('custResultsContainer').style.display = 'none';

      const btn = document.getElementById('confirmAssignBtn');
      btn.disabled = false;
      btn.style.opacity = '1';
      
      document.getElementById('custSearchInput').style.borderColor = '#10b981';
      document.getElementById('custSearchInput').style.background = '#f0fdf4';
    };

    async function loadData() {
      try {
        const res = await fetch('/api/layout');
        const data = await res.json();
        if (data && data.items && data.items.length > 0) {
          items = data.items;
          nextId = Math.max(...items.map(i => i.id)) + 1;
        } else {
          items = [...defaultItems]; nextId = 60;
        }
        render();
        renderTimers(); // Immediate update to prevent flicker
        await buildCustList();
        updateCustListTimers(); // Immediate update to prevent flicker
        fetchCustomersForSelect();
      } catch (e) {
        console.error(e);
      }
    }

    function hasUnsavedChanges() {
      if (!isEditMode || !originalItems) return false;
      return JSON.stringify(items) !== JSON.stringify(originalItems);
    }

    let pendingMode = null;
    
    function setAppMode(m) {
      if (!isEditMode && m === 'edit') {
        originalItems = JSON.parse(JSON.stringify(items));
      }

      if (isEditMode && m === 'track') {
        if (hasUnsavedChanges()) {
          pendingMode = m;
          document.getElementById('unsavedModal').classList.add('show');
          return;
        }
        originalItems = null;
      }

      isEditMode = (m === 'edit');
      document.body.classList.toggle('edit-mode', isEditMode);
      
      const btnTrack = document.getElementById('btnTrackMode');
      const btnEdit = document.getElementById('btnEditMode');
      
      if (isEditMode) {
        btnEdit.style.background = 'var(--orange)';
        btnEdit.style.color = 'white';
        btnTrack.style.background = 'transparent';
        btnTrack.style.color = 'var(--text)';
        if (trackInterval) clearInterval(trackInterval);
        document.getElementById('hintText').innerHTML = '<i class="fa-regular fa-hand-pointer"></i> Edit mode: Drag items to move. Click to cycle status.';
      } else {
        btnTrack.style.background = 'var(--orange)';
        btnTrack.style.color = 'white';
        btnEdit.style.background = 'transparent';
        btnEdit.style.color = 'var(--text)';
        selectedId = null;
        hideProps();
        document.getElementById('hintText').innerHTML = '<i class="fa-solid fa-radar"></i> Live Tracking: Auto-refreshing statuses every 5s.';
        
        if (trackInterval) clearInterval(trackInterval);
        trackInterval = setInterval(() => {
          loadData();
          loadTransferRequests();
        }, 5000);

        // Update timers every second for smooth countdown
        setInterval(() => {
            if (!isEditMode) {
                renderTimers();
                updateCustListTimers();
                updateDetailTimer();
            }
        }, 1000);
      }
      render();
    }

    function renderTimers() {
        items.forEach(item => {
            if ((item.status === 'taken' || item.status === 'idle') && (item.endTime || item.remainingSeconds)) {
                const el = document.querySelector(`[data-id="${item.id}"]`);
                if (el) {
                    let tag = el.querySelector('.timer-tag');
                    if (!tag) {
                        tag = document.createElement('div');
                        tag.className = 'timer-tag';
                        tag.style.position = 'absolute';
                        tag.style.bottom = '-18px';
                        tag.style.left = '50%';
                        tag.style.transform = 'translateX(-50%)';
                        tag.style.fontSize = '8px';
                        tag.style.fontWeight = '800';
                        tag.style.color = 'white';
                        tag.style.padding = '1px 4px';
                        tag.style.borderRadius = '4px';
                        tag.style.whiteSpace = 'nowrap';
                        tag.style.zIndex = '20';
                        el.appendChild(tag);
                    }
                    const timeLeft = formatTimeLeft(item.endTime, item.isPaused, item.remainingSeconds);
                    tag.textContent = timeLeft + (item.isPaused ? ' (P)' : '');
                    tag.style.background = item.isPaused ? '#facc15' : (timeLeft === 'Expired' ? '#ef4444' : '#1e293b');
                    tag.style.color = item.isPaused ? '#1e293b' : 'white';
                }
            }
        });
    }

    function updateCustListTimers() {
        const rows = document.querySelectorAll('.cust-row-sub');
        rows.forEach(row => {
            // Find the time span. We need to be careful with the structure.
            // Earlier I added: <span style="color: ...">${timeStr}</span>
            const span = row.querySelector('span');
            if (span && (span.dataset.endTime || span.dataset.remainingSeconds)) {
                const isPaused = span.dataset.isPaused === '1';
                const remainingSeconds = parseInt(span.dataset.remainingSeconds || 0);
                const timeLeft = formatTimeLeft(span.dataset.endTime, isPaused, remainingSeconds);
                
                span.textContent = timeLeft + (isPaused ? ' (Paused)' : '');
                const isUrgent = !isPaused && timeLeft && (timeLeft.includes('s') && !timeLeft.includes('m'));
                span.style.color = isPaused ? '#f59e0b' : (isUrgent ? '#ef4444' : 'inherit');
                span.style.fontWeight = (isUrgent || isPaused) ? '700' : 'normal';
            }
        });
    }

    function updateDetailTimer() {
        const panel = document.getElementById('sideDetailPanel');
        if (panel.style.display === 'block') {
            const item = items.find(i => i.id === currentSelectedElementId);
            if (item && item.status === 'taken' || item.status === 'idle') {
                const timeLeft = formatTimeLeft(item.endTime, item.isPaused, item.remainingSeconds);
                const badge = document.getElementById('detailStatusBadge');
                badge.textContent = item.isPaused ? `Paused (${timeLeft})` : `Occupied (${timeLeft || 'Expired'})`;
                badge.style.background = item.isPaused ? '#fef9c3' : '#fee2e2';
                badge.style.color = item.isPaused ? '#854d0e' : '#ef4444';
            }
        }
    }

    function closeUnsavedModal() {
      document.getElementById('unsavedModal').classList.remove('show');
      pendingMode = null;
    }

    async function handleUnsavedSave() {
      await saveLayout();
      closeUnsavedModal();
    }

    function handleUnsavedDiscard() {
      items = JSON.parse(JSON.stringify(originalItems));
      originalItems = null;
      isEditMode = false;
      document.body.classList.toggle('edit-mode', false);
      setAppMode('track');
      closeUnsavedModal();
    }

    // Browser navigation guard
    window.onbeforeunload = function(e) {
      if (hasUnsavedChanges()) {
        const msg = "You have unsaved layout changes!";
        e.returnValue = msg;
        return msg;
      }
    };

    function render() {
      canvas.innerHTML = '';
      items.forEach(item => {
        const el = document.createElement('div');
        el.className = 'fp-item' + (item.id === selectedId ? ' selected' : '');
        el.dataset.id = item.id;
        el.style.left = item.x + 'px';
        el.style.top = item.y + 'px';
        el.style.width = item.w + 'px';
        el.style.height = item.h + 'px';
        el.style.zIndex = (item.type === 'chair' || item.type === 'chair-sq') ? 5 : item.type.startsWith('block') ? 2 : 3;

        const visual = document.createElement('div');
        visual.className = 'item-visual';
        visual.style.transform = 'rotate(' + (item.rot || 0) + 'deg)';

        if (item.type === 'chair') {
          if (isEditMode) {
            visual.style.backgroundImage = 'url(/images/chair.png)';
            visual.style.backgroundSize = 'contain';
            visual.style.backgroundRepeat = 'no-repeat';
            visual.style.backgroundPosition = 'center';
          } else {
            visual.classList.add('chair-icon');
            visual.style.webkitMaskImage = 'url(/images/chair.png)';
            visual.style.maskImage = 'url(/images/chair.png)';
            const status = (item.statuses && item.statuses[0]) || item.status || 'open';
            const isPaused = !!item.isPaused;
            if (isPaused || status === 'idle') visual.style.backgroundColor = '#facc15';
            else if (status === 'taken') visual.style.backgroundColor = '#d65c29';
            else if (status === 'reserved') visual.style.backgroundColor = '#1e293b';
            else visual.style.backgroundColor = '#10b981';
          }
          el.onclick = (e) => { e.stopPropagation(); handleItemClick(e, item.id) };
        } else if (item.type === 'chair-sq') {
          const status = (item.statuses && item.statuses[0]) || item.status || 'open';
          const isPaused = !!item.isPaused;
          const sqColor = isEditMode ? '#faecd4' : ((isPaused || status === 'idle') ? '#facc15' : status === 'taken' ? '#d65c29' : status === 'reserved' ? '#1e293b' : '#10b981');
          visual.style.background = sqColor;
          visual.style.borderRadius = '6px';
          visual.style.border = '2px solid #8B4513';
          el.onclick = (e) => { e.stopPropagation(); handleItemClick(e, item.id) };
        } else if (item.type === 'round-table') {
          visual.style.background = item.color;
          visual.style.borderRadius = '50%';
          visual.style.border = '2px solid #f97316';
        } else if (item.type === 'rect-table') {
          visual.style.background = item.color;
          visual.style.borderRadius = '8px';
          visual.style.border = '2px solid #f97316';
        } else if (item.type === 'room') {
          const status = (item.statuses && item.statuses[0]) || item.status || 'open';
          const roomColor = status === 'taken' ? '#9ca3af' : status === 'reserved' ? '#ef4444' : item.color;
          visual.style.background = roomColor;
          visual.style.borderRadius = '8px';
          visual.style.border = '2px solid #16a34a';
          el.onclick = (e) => { e.stopPropagation(); handleItemClick(e, item.id) };
        } else {
          visual.style.background = item.color;
          visual.style.borderRadius = '4px';
          if (item.color === '#22c55e') visual.style.border = '2px solid #16a34a';
          else if (item.color === '#fde68a') visual.style.border = '1.5px solid #f59e0b';
        }
        el.appendChild(visual);

        if (item.label || item.type === 'room') {
          const lbl = document.createElement('span');
          lbl.className = 'item-label';
          if (item.type !== 'chair' && item.type !== 'chair-sq') {
            lbl.classList.add('center');
            const status = (item.statuses && item.statuses[0]) || item.status || 'open';
            const isDark = (item.color === '#22c55e' || status === 'taken' || status === 'reserved');
            lbl.style.color = isDark ? '#fff' : '#1e293b';
          } else if (item.type === 'chair-sq') {
            lbl.classList.add('center');
            const status = (item.statuses && item.statuses[0]) || item.status || 'open';
            const isDark = (status === 'taken' || status === 'reserved');
            lbl.style.color = isDark ? '#fff' : '#1e293b';
          }
          lbl.textContent = item.label || (item.type === 'room' ? 'Room' : '');
          el.appendChild(lbl);
        }

        // Add Timer for Taken seats
        const status = (item.statuses && item.statuses[0]) || item.status || 'open';
        if ((status === 'taken' || status === 'idle') && item.endTime && !isEditMode) {
            const timeLeft = formatTimeLeft(item.endTime, item.isPaused, item.remainingSeconds);
            if (timeLeft) {
                const timerTag = document.createElement('div');
                timerTag.style.position = 'absolute';
                timerTag.style.bottom = '-18px';
                timerTag.style.left = '50%';
                timerTag.style.transform = 'translateX(-50%)';
                timerTag.style.fontSize = '8px';
                timerTag.style.fontWeight = '800';
                timerTag.style.background = item.isPaused ? '#facc15' : (timeLeft === 'Expired' ? '#ef4444' : '#1e293b');
                timerTag.style.color = item.isPaused ? '#1e293b' : 'white';
                timerTag.style.padding = '1px 4px';
                timerTag.style.borderRadius = '4px';
                timerTag.style.whiteSpace = 'nowrap';
                timerTag.style.zIndex = '20';
                timerTag.textContent = timeLeft + (item.isPaused ? ' (P)' : '');
                el.appendChild(timerTag);
            }
        }

        const del = document.createElement('button');
        del.className = 'delete-btn';
        del.innerHTML = '<i class="fa-solid fa-xmark"></i>';
        del.onmousedown = e => { e.stopPropagation(); deleteItem(item.id) };
        el.appendChild(del);
        canvas.appendChild(el);
      });
    }

    function handleItemClick(e, itemId) {
      if (isEditMode) {
        if (mode === 'select') canvasDown(e);
        return;
      }
      const item = items.find(i => i.id === itemId);
      if (!item) return;
      const status = item.status || 'open';
      showDetail(item.label || 'Seat', item.label || 'ID: ' + itemId, 'Now', status === 'open', item.id, item.image);
    }

    let currentSelectedElementId = null;
    let currentSelectedElementLabel = null;
    function showDetail(name, seatLabel, time, isAvailable = false, elementId, image) {
      currentSelectedElementId = elementId;
      currentSelectedElementLabel = seatLabel;
      
      const item = items.find(i => i.id === elementId);
      const status = (item && item.status) || (isAvailable ? 'open' : 'taken');
      const isReallyAvailable = status === 'open';

      // If occupied or idle, show user name if we have it
      if (!isReallyAvailable && item && item.userName) {
          document.getElementById('detailName').textContent = item.userName;
          const timeLeft = formatTimeLeft(item.endTime, item.isPaused, item.remainingSeconds);
          const badge = document.getElementById('detailStatusBadge');
          if (item.isPaused) {
              badge.textContent = `Paused (${timeLeft})`;
              badge.style.background = '#fef9c3';
              badge.style.color = '#854d0e';
          } else {
              badge.textContent = `Taken (${timeLeft || 'Expired'})`;
              badge.style.background = '#fee2e2';
              badge.style.color = '#ef4444';
          }
      } else {
          document.getElementById('detailName').textContent = name;
          const badge = document.getElementById('detailStatusBadge');
          badge.textContent = isReallyAvailable ? 'Available' : 'Taken';
          badge.style.background = isReallyAvailable ? '#dcfce7' : '#fee2e2';
          badge.style.color = isReallyAvailable ? '#16a34a' : '#ef4444';
      }

      const detailImg = document.getElementById('detailImg');
      detailImg.src = image || 'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=400';

      document.getElementById('activeCustCard').style.display = 'none';
      document.getElementById('sideDetailPanel').style.display = 'block';
      document.getElementById('propsPanel').classList.remove('show');
      cancelAssignment();
      document.getElementById('btnAssign').style.display = isReallyAvailable ? 'flex' : 'none';
      document.getElementById('btnTransfer').style.display = isReallyAvailable ? 'none' : 'flex';
    }

    async function changeSeatImage(event) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = async (e) => {
            const imageData = e.target.result;
            try {
                const res = await fetch('/api/floor-elements/image', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ label: currentSelectedElementLabel, image: imageData })
                });
                const data = await res.json();
                if (data.success) {
                    document.getElementById('detailImg').src = imageData;
                    // Update local items array too
                    const item = items.find(i => i.id === currentSelectedElementId);
                    if (item) item.image = imageData;
                }
            } catch (err) {
                console.error('Error uploading image:', err);
            }
        };
        reader.readAsDataURL(file);
    }

    function closeDetail() {
      document.getElementById('sideDetailPanel').style.display = 'none';
      document.getElementById('activeCustCard').style.display = 'block';
    }

    function showAssignForm() {
      document.getElementById('assignForm').style.display = 'block';
      document.getElementById('detailActions').style.display = 'none';
    }

    function cancelAssignment() {
      document.getElementById('assignForm').style.display = 'none';
      document.getElementById('detailActions').style.display = 'flex';

      // Reset search fields
      document.getElementById('custSearchInput').value = '';
      document.getElementById('custSearchInput').style.borderColor = 'var(--border)';
      document.getElementById('custSearchInput').style.background = 'white';
      document.getElementById('assignCustId').value = '';
      document.getElementById('assignCustName').value = '';
      
      const btn = document.getElementById('confirmAssignBtn');
      if (btn) {
        btn.disabled = true;
        btn.style.opacity = '0.6';
      }
      
      if (allCustomers.length > 0) filterCustomers();
    }

    async function confirmAssignment() {
      const customerId = document.getElementById('assignCustId').value;
      const customerName = document.getElementById('assignCustName').value;
      const planSelect = document.getElementById('assignPlan');
      const hours = parseInt(planSelect.value);
      
      if (!customerId) { alert('Please select a customer'); return; }
      
      if (confirm(`Assign ${customerName} to this seat for ${hours} hour(s)?`)) {
        try {
            console.log('Sending assignment request:', { userId: customerId, elementId: currentSelectedElementId, hours });
            const res = await fetch('/api/session/start', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: customerId, elementId: currentSelectedElementId, hours })
            });
            
            const data = await res.json();
            console.log('Assignment response:', data);
            
            if (data.success) {
                alert('Assignment successful!');
                cancelAssignment(); 
                closeDetail();
                await loadData(); // Wait for data to load
            } else {
                alert('Error: ' + (data.error || 'Unknown error occurred'));
            }
        } catch(e) { 
            console.error('Assignment Fetch Error:', e);
            alert('Failed to connect to server. Please check your connection.');
        }
      }
    }

    function setMode(m) {
      mode = m;
      document.querySelectorAll('.tb-btn').forEach(b => b.classList.remove('active'));
      const map = { select: 'btnSelect', chair: 'btnChair', 'chair-sq': 'btnChairSq', 'round-table': 'btnRound', 'rect-table': 'btnRect', 'room': 'btnRoom', 'block-gray': 'btnGray', 'block-yellow': 'btnYellow' };
      if (map[m]) document.getElementById(map[m]).classList.add('active');
      canvas.classList.toggle('mode-select', m === 'select');
      if (m !== 'select') { selectedId = null; render(); hideProps() }
    }

    function canvasDown(e) {
      if (!isEditMode) return;
      const rect = canvas.getBoundingClientRect();
      const mx = e.clientX - rect.left, my = e.clientY - rect.top;

      if (mode === 'select') {
        const el = e.target.closest('.fp-item');
        if (el) {
          const id = +el.dataset.id;
          selectedId = id;
          const item = items.find(i => i.id === id);
          dragOff = { x: mx - item.x, y: my - item.y };
          dragging = id;
          render(); showProps(item);
        } else { selectedId = null; render(); hideProps() }
      } else {
        const defs = {
          chair: { w: 28, h: 32, color: '#faecd4' },
          'chair-sq': { w: 28, h: 28, color: '#faecd4' },
          'round-table': { w: 44, h: 44, color: '#fdba74' },
          'rect-table': { w: 90, h: 60, color: '#fdba74' },
          'room': { w: 120, h: 80, color: '#22c55e', seats: 8 },
          'block-gray': { w: 60, h: 30, color: '#b0b8c0' },
          'block-yellow': { w: 80, h: 30, color: '#fde68a' },
        };
        const d = defs[mode] || defs['block-gray'];
        const item = { id: nextId++, type: mode, x: Math.round(mx - d.w / 2), y: Math.round(my - d.h / 2), w: d.w, h: d.h, rot: 0, color: d.color, label: '' };
        items.push(item);
        selectedId = item.id;
        render(); showProps(item);
        setMode('select');
      }
    }

    function canvasMove(e) {
      if (!dragging || !isEditMode) return;
      const rect = canvas.getBoundingClientRect();
      const item = items.find(i => i.id === dragging);
      if (!item) return;
      item.x = Math.max(0, Math.min(800 - item.w, e.clientX - rect.left - dragOff.x));
      item.y = Math.max(0, Math.min(450 - item.h, e.clientY - rect.top - dragOff.y));
      const el = canvas.querySelector(`[data-id="${dragging}"]`);
      if (el) { el.style.left = item.x + 'px'; el.style.top = item.y + 'px' }
    }

    function canvasUp() { dragging = null }

    function showProps(item) {
      if (!isEditMode) return;
      const p = document.getElementById('propsPanel');
      p.classList.add('show');
      document.getElementById('propLabel').value = item.label || '';
      document.getElementById('propW').value = item.w;
      document.getElementById('propH').value = item.h;
      document.getElementById('propRot').value = item.rot;
      document.getElementById('propColor').value = item.color;
      const seatsGroup = document.getElementById('propSeatsGroup');
      if (item.type === 'room') {
        seatsGroup.style.display = 'block';
        document.getElementById('propSeats').value = item.seats || 0;
      } else {
        seatsGroup.style.display = 'none';
      }
    }
    function hideProps() { document.getElementById('propsPanel').classList.remove('show') }

    function updateProp(key, val) {
      const item = items.find(i => i.id === selectedId);
      if (!item) return;
      item[key] = val;
      render();
    }

    function deleteItem(id) {
      items = items.filter(i => i.id !== id);
      if (selectedId === id) { selectedId = null; hideProps() }
      render();
    }
    function deleteSelected() { if (selectedId) deleteItem(selectedId) }

    async function saveLayout() {
      try {
        const res = await fetch('/api/layout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items })
        });
        if (res.ok) {
          alert('Layout saved!');
          originalItems = JSON.parse(JSON.stringify(items));
          setAppMode('track');
        }
        else alert('Error saving layout');
      } catch (e) { console.error(e); alert('Error saving layout'); }
    }

    async function clearAll() {
      if (!confirm('Clear all items?')) return;
      items = []; selectedId = null; hideProps(); render();
      await saveLayout();
    }

    async function buildCustList() {
      const el = document.getElementById('custList'); el.innerHTML = '';
      try {
          const res = await fetch('/api/active-customers');
          const data = await res.json();
          if (data.customers && data.customers.length > 0) {
              data.customers.forEach(c => {
                  const d = document.createElement('div'); d.className = 'cust-row';
                  const now = new Date();
                  const end = new Date(c.end_time);
                  const diffMs = end - now;
                  let timeStr = 'Expired';
                  
                  if (diffMs > 0) {
                      const diffHrs = Math.floor(diffMs / 3600000);
                      const diffMins = Math.round((diffMs % 3600000) / 60000);
                      timeStr = diffHrs > 0 ? `${diffHrs}h ${diffMins}m left` : `${diffMins}m left`;
                  }
                  
                  d.innerHTML = `
                    <div style="flex:1" onclick="highlightUserSeat('${c.seat_label}', '${c.first_name} ${c.last_name}', '${c.id}')">
                        <div class="cust-row-name">${c.first_name} ${c.last_name}</div>
                        <div class="cust-row-sub">
                          <i class="fa-solid fa-couch" style="font-size:10px"></i> ${c.seat_label || 'No Seat'} · 
                          <span data-end-time="${c.end_time}" data-is-paused="${c.is_paused}" data-remaining-seconds="${c.remaining_seconds}" style="color: ${!c.is_paused && diffMs < 900000 ? '#ef4444' : 'inherit'}; font-weight: ${!c.is_paused && diffMs < 900000 ? '700' : 'normal'}">
                            ${timeStr}${c.is_paused ? ' (Paused)' : ''}
                          </span>
                        </div>
                    </div>
                    <button class="btn btn-ghost btn-icon" onclick="startManualTransferFromList(${JSON.stringify(c).replace(/"/g, '&quot;')})" title="Transfer Seat">
                        <i class="fa-solid fa-arrow-right-arrow-left"></i>
                    </button>
                  `;
                  el.appendChild(d);
              });
          } else {
              el.innerHTML = '<div style="text-align:center; padding:20px; font-size:11px; color:#94a3b8;">No active customers</div>';
          }
      } catch(e) { console.error(e); }
    }

    function highlightUserSeat(label, name, userId) {
        const item = items.find(i => i.label === label);
        if (item) {
            selectedId = item.id;
            render();
            showDetail(name, label, '', false, item.id);
        }
    }

    let manualTransferSource = null;

    function startManualTransfer() {
        // This is called from the detail panel when an occupied seat is selected
        const item = items.find(i => i.id === currentSelectedElementId);
        // We need the user's name. Currently showDetail doesn't store the full user object.
        // Let's assume we can find them from the active customers list if needed, or just use the name from the title.
        const name = document.getElementById('detailName').textContent;
        
        manualTransferSource = {
            elementId: currentSelectedElementId,
            label: item.label,
            userName: name
        };
        
        toast(`Transferring ${name}. Select a new seat on the floor plan.`, "info");
        closeDetail();
    }

    function startManualTransferFromList(customer) {
        const item = items.find(i => i.label === customer.seat_label);
        manualTransferSource = {
            elementId: item ? item.id : null,
            label: customer.seat_label,
            userName: `${customer.first_name} ${customer.last_name}`,
            userId: customer.id
        };
        toast(`Transferring ${manualTransferSource.userName}. Select a new seat on the floor plan.`, "info");
    }

    // Update handleItemClick to handle manual transfer target selection
    function handleItemClick(e, itemId) {
      if (isEditMode) {
        if (mode === 'select') canvasDown(e);
        return;
      }
      
      const item = items.find(i => i.id === itemId);
      if (!item) return;

      if (manualTransferSource) {
          const status = (item.statuses && item.statuses[0]) || 'open';
          if (status !== 'open') {
              toast("Seat is not available!", "error");
              return;
          }
          confirmManualTransfer(item);
          return;
      }

      const status = (item.statuses && item.statuses[0]) || 'open';
      showDetail(item.label || 'Seat', item.label || 'ID: ' + itemId, 'Now', status === 'open', item.id);
    }

    async function confirmManualTransfer(targetItem) {
        if (!confirm(`Transfer ${manualTransferSource.userName} from ${manualTransferSource.label} to ${targetItem.label}?`)) {
            manualTransferSource = null;
            return;
        }

        try {
            // We need the userId. If we don't have it, we might need to fetch it or ensure it's passed.
            // Let's check if we have it.
            let userId = manualTransferSource.userId;
            if (!userId) {
                // Try to find in active customers if we only have the name
                const res = await fetch('/api/active-customers');
                const data = await res.json();
                const cust = data.customers.find(c => c.seat_label === manualTransferSource.label);
                if (cust) userId = cust.id;
            }

            if (!userId) { toast("User session not found!", "error"); manualTransferSource = null; return; }

            const res = await fetch('/api/transfer-requests/manual', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    userId, 
                    currentElementId: manualTransferSource.elementId, 
                    newElementId: targetItem.id 
                })
            });

            if ((await res.json()).success) {
                toast("Seat transferred successfully!", "success");
                manualTransferSource = null;
                loadData();
            }
        } catch(e) { console.error(e); }
    }

    window.onload = init;

    // Close search results when clicking outside
    window.addEventListener('click', function(e) {
      const container = document.getElementById('custResultsContainer');
      const searchInput = document.getElementById('custSearchInput');
      if (container && !container.contains(e.target) && e.target !== searchInput) {
        container.style.display = 'none';
      }
    });
  </script>
<% if (locals.scripts) { %>
    <%- locals.scripts %>
<% } %>
</body>
</html>

