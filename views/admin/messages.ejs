<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Messages' %>

<%- contentFor('style') %>
<style>

    .msg-layout {
      display: grid;
      grid-template-columns: 380px 1fr;
      gap: 20px;
    }

    /* Recipient Modal */
    .recipient-modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.5);
      display: none; align-items: center; justify-content: center; z-index: 1000;
    }
    .recipient-modal-overlay.show { display: flex; }

    .recipient-modal {
      background: var(--white); border-radius: var(--radius); width: 100%; max-width: 520px;
      max-height: 85vh; display: flex; flex-direction: column; box-shadow: var(--shadow-md);
    }

    .recipient-modal-header {
      padding: 20px 24px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }

    .recipient-modal-title { font-family: 'Poppins', sans-serif; font-size: 1.05rem; font-weight: 700; }

    .recipient-modal-body { flex: 1; overflow-y: auto; padding: 20px 24px; }

    .search-container { position: relative; margin-bottom: 16px; }
    .search-container i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #94a3b8; }

    .search-container input {
      width: 100%; padding: 10px 12px; padding-left: 40px;
      border: 1.5px solid var(--border); border-radius: 30px; font-size: 13px;
    }

    .user-list-modal {
      max-height: 380px; overflow-y: auto; border: 1px solid var(--border); border-radius: var(--radius-sm);
    }

    .user-row-modal {
      display: flex; align-items: center; gap: 12px; padding: 12px 14px;
      border-bottom: 1px solid var(--border); cursor: pointer;
    }
    .user-row-modal:hover { background: var(--cream-lt); }

    .user-name { flex: 1; font-size: 13.5px; font-weight: 600; }
    .user-type {
      font-size: 10.5px; padding: 3px 9px; border-radius: 20px;
      background: #f1f5f9; color: #475569;
    }
    .user-type.member { background: #dbeafe; color: #1e40af; }
    .user-type.walkin { background: #fef3c7; color: #92400e; }
    .user-type.staff { background: #dcfce7; color: #166534; }

    .char-counter {
      font-size: 11px;
      text-align: right;
      color: var(--text-sm);
      margin-top: 4px;
    }
    .char-counter.limit { color: #dc2626; font-weight: 700; }

    @media (max-width: 768px) {
      .msg-layout { grid-template-columns: 1fr; }
    }
  
</style>

<div class="app">

  <!-- Consistent Sidebar (Same as Door & Seat) -->
  <%- include('../partials/admin_sidebar', { active: 'Message' }) %>

  <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>

  <main class="content">
    <button class="mobile-menu-btn" onclick="openSidebar()">
      <i class="fa-solid fa-bars"></i>
    </button>

    <div class="page-header">
      <h1 class="page-title">Messages</h1>
    </div>

    <div class="msg-layout">
      <!-- Send Message -->
      <div class="card">
        <div class="card-title">Send Message</div>
        <div style="display:flex;flex-direction:column;gap:16px;">
          <div class="form-group">
            <label class="form-label">Audience</label>
            <select class="form-control" id="msg-audience">
              <option value="all">All Users</option>
              <option value="members">Members Only</option>
              <option value="walkins">Walk-ins Only</option>
              <option value="staff">Staff Only</option>
              <option value="specific">Specific Customers</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Recipient(s)</label>
            <input class="form-control" id="msg-recipients" type="text" placeholder="Enter emails or select audience...">
          </div>
          <div class="form-group">
            <label class="form-label">Subject</label>
            <input class="form-control" id="msg-subject" type="text" placeholder="Enter subject...">
          </div>
          <div class="form-group">
            <label class="form-label">Message</label>
            <textarea class="form-control" id="msg-body" rows="4" maxlength="165" placeholder="Type your message here..." oninput="updateCharCount()"></textarea>
            <div class="char-counter" id="char-count">0 / 165</div>
          </div>
          <button class="btn btn-primary" onclick="prepareAndSend()">
            <i class="fa-solid fa-bell"></i> Send to Accounts
          </button>
        </div>
      </div>

      <!-- History -->
      <div class="card">
        <div class="card-title">Sent Messages History</div>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>Audience</th><th>Subject</th><th>Date</th><th>Action</th></tr>
            </thead>
            <tbody id="msgHistory"></tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Recipient Modal -->
<div class="recipient-modal-overlay" id="recipientModal">
  <div class="recipient-modal">
    <div class="recipient-modal-header">
      <div class="recipient-modal-title">Select Recipients</div>
      <button onclick="closeRecipientModal()" style="background:none;border:none;font-size:1.6rem;cursor:pointer;">×</button>
    </div>
    <div class="recipient-modal-body">
      <div class="search-container">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="recipientSearch" placeholder="Search users..." oninput="renderRecipientList()">
      </div>
      <div class="user-list-modal" id="recipientList"></div>
    </div>
    <div class="recipient-modal-footer" style="padding:16px 24px; border-top:1px solid var(--border); display:flex; justify-content:flex-end; gap:10px;">
      <button class="btn btn-ghost" onclick="closeRecipientModal()">Cancel</button>
      <button class="btn btn-primary" onclick="sendToSpecificRecipients()">
        <i class="fa-solid fa-paper-plane"></i> Send
      </button>
    </div>
  </div>
</div>

<%- contentFor('script') %>
<script>
let dbUsers = [];
let messageHistory = [];
let selectedRecipients = [];
let pendingSubject = ''; let pendingBody = '';

async function loadInitialData() {
    try {
        const [uRes, mRes] = await Promise.all([
            fetch('/api/users').then(res => res.json()),
            fetch('/api/messages').then(res => res.json())
        ]);
        dbUsers = uRes.users || [];
        messageHistory = (mRes.messages || []).map(m => ({
            id: m.id,
            audience: m.audience,
            subject: m.subject,
            date: new Date(m.created_at).toLocaleString()
        }));
        renderMessageHistory();
    } catch (e) { console.error('Error loading data:', e); }
}

function renderMessageHistory() {
  const tbody = document.getElementById('msgHistory');
  tbody.innerHTML = messageHistory.map(msg => `
    <tr>
      <td>${escapeHtml(msg.audience)}</td>
      <td><strong>${escapeHtml(msg.subject)}</strong></td>
      <td style="font-size:11px;color:var(--text-sm)">${msg.date}</td>
      <td><button class="btn btn-ghost btn-sm" onclick="viewMessage(${msg.id})">View</button></td>
    </tr>
  `).join('');
}

function updateCharCount() {
  const body = document.getElementById('msg-body');
  const count = body.value.length;
  const counter = document.getElementById('char-count');
  counter.textContent = `${count} / 165`;
  if (count >= 150) counter.classList.add('limit');
  else counter.classList.remove('limit');
}

async function prepareAndSend() {
  const recipientsStr = document.getElementById('msg-recipients').value.trim();
  const subject = document.getElementById('msg-subject').value.trim();
  const body = document.getElementById('msg-body').value.trim();
  const audience = document.getElementById('msg-audience').value;

  if (!subject || !body) return alert("Please fill Subject and Message");

  if (audience === 'specific') {
    pendingSubject = subject;
    pendingBody = body;
    selectedRecipients = [];
    renderRecipientList();
    document.getElementById('recipientModal').classList.add('show');
  } else {
    let targetEmails = recipientsStr;
    if (!targetEmails) {
      if (audience === 'all') targetEmails = dbUsers.map(u => u.email).join(', ');
      else if (audience === 'members') targetEmails = dbUsers.filter(u => u.status === 'approved' && u.role === 'customer').map(u => u.email).join(', ');
      else if (audience === 'walkins') targetEmails = dbUsers.filter(u => u.status === 'pending' && u.role === 'customer').map(u => u.email).join(', ');
      else if (audience === 'staff') targetEmails = dbUsers.filter(u => u.role === 'staff').map(u => u.email).join(', ');
    }
    
    await sendMessage(subject, body, audience, targetEmails);
  }
}

function renderRecipientList() {
  const container = document.getElementById('recipientList');
  const search = (document.getElementById('recipientSearch').value || '').toLowerCase();
  const filtered = dbUsers.filter(u => `${u.first_name} ${u.last_name}`.toLowerCase().includes(search));

  container.innerHTML = filtered.map(u => `
    <div class="user-row-modal" onclick="toggleRecipient(${u.id}, '${u.first_name} ${u.last_name}', '${u.role}')">
      <input type="checkbox" ${selectedRecipients.some(r => r.id === u.id) ? 'checked' : ''}>
      <span class="user-name">${escapeHtml(u.first_name)} ${escapeHtml(u.last_name)}</span>
      <span class="user-type ${u.role}">${u.role}</span>
    </div>
  `).join('');
}

function toggleRecipient(id, name, type) {
  const index = selectedRecipients.findIndex(r => r.id === id);
  if (index === -1) selectedRecipients.push({id, name, type});
  else selectedRecipients.splice(index, 1);
  renderRecipientList();
}

async function sendToSpecificRecipients() {
  if (selectedRecipients.length === 0) return alert("Please select at least one recipient");
  const emails = selectedRecipients.map(r => {
    const u = dbUsers.find(user => user.id === r.id);
    return u ? u.email : '';
  }).filter(e => e !== '').join(', ');
  
  const audienceLabel = "Specific: " + selectedRecipients.map(r => r.name).join(", ");
  await sendMessage(pendingSubject, pendingBody, audienceLabel, emails);
  closeRecipientModal();
}

async function sendMessage(subject, body, audience, recipients) {
  try {
      // 1. Save to DB history and send internal notifications
      const res = await fetch('/api/messages', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ audience, recipients, subject, body })
      });
      const data = await res.json();

      if (data.success) {
          alert('Message sent successfully to user accounts!');
          // 2. Update local state
          loadInitialData();

          // Clear inputs
          document.getElementById('msg-subject').value = '';
          document.getElementById('msg-body').value = '';
          document.getElementById('msg-recipients').value = '';
          updateCharCount();
      } else {
          alert('Error sending message: ' + data.error);
      }
  } catch (e) { console.error('Error sending message:', e); alert('Failed to connect to server'); }
}

function closeRecipientModal() {
  document.getElementById('recipientModal').classList.remove('show');
}

function viewMessage(id) {
  const msg = messageHistory.find(m => m.id === id);
  if (msg) alert(`Subject: ${msg.subject}\nAudience: ${msg.audience}\nDate: ${msg.date}`);
}

function openSidebar() {
  document.getElementById('sidebar').classList.add('mobile-open');
  document.getElementById('mobileOverlay').classList.add('show');
}

function closeSidebar() {
  document.getElementById('sidebar').classList.remove('mobile-open');
  document.getElementById('mobileOverlay').classList.remove('show');
}

function escapeHtml(str){ if(!str)return ''; return String(str).replace(/[&<>]/g,function(m){if(m==='&')return '&amp;';if(m==='<')return '&lt;';if(m==='>')return '&gt;';return m;}); }

loadInitialData();
</script>

