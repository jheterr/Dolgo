<!-- title passed to layout function -->
<% locals.title='The Last Muster | Analytics & Reports' %>

  <%- contentFor('style') %>
    <style>
      .analytics-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 4px;
      }

      .stat-grid-4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
      }

      .stat-grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
      }

      .an-card {
        border-radius: var(--radius);
        padding: 20px;
        background: var(--white);
        box-shadow: var(--shadow);
        text-align: center;
      }

      .an-icon {
        font-size: 1.4rem;
        margin-bottom: 6px;
      }

      .an-val {
        font-family: 'Poppins', sans-serif;
        font-size: 2.1rem;
        font-weight: 800;
      }

      .an-lbl {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-sm);
        margin-top: 3px;
      }

      .chart-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 20px;
        box-shadow: var(--shadow);
        margin-bottom: 24px;
      }

      .chart-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 20px;
      }

      .chart-title {
        font-family: 'Poppins', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .chart-controls {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
      }

      .chart-controls select {
        padding: 6px 12px;
        border-radius: 6px;
        border: 1px solid var(--border);
        font-size: 12px;
      }

      .chart-box {
        height: 260px;
      }

      .two-col-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
      }

      .three-col-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-bottom: 24px;
      }

      .top-customer-list {
        max-height: 280px;
        overflow-y: auto;
      }

      .top-customer-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
      }

      .top-customer-name {
        font-weight: 700;
        font-size: 13px;
      }

      .top-customer-hours {
        font-weight: 800;
        color: var(--orange);
        font-size: 13px;
      }

      .badge-type {
        background: var(--cream-lt);
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 10px;
        font-weight: 600;
      }

      .summary-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 20px;
        box-shadow: var(--shadow);
      }

      .summary-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
      }

      .summary-row:last-child {
        border-bottom: none;
      }

      .summary-label {
        font-weight: 600;
        color: var(--text-md);
      }

      .summary-value {
        font-weight: 800;
        font-size: 1.1rem;
      }

      .total-revenue {
        background: var(--green);
        color: white;
        padding: 8px 12px;
        border-radius: 8px;
        margin-top: 10px;
      }

      .loss-amount {
        background: #dc2626;
        color: white;
        padding: 8px 12px;
        border-radius: 8px;
        margin-top: 10px;
      }

      .pending-badge {
        background: #fef3c7;
        color: #92400e;
        padding: 4px 8px;
        border-radius: 20px;
        font-size: 11px;
        display: inline-block;
      }

      .income-overview-card {
        background: linear-gradient(135deg, #1e293b, #0f172a);
        color: white;
        border-radius: var(--radius);
        padding: 20px;
        margin-bottom: 24px;
      }

      .income-overview-card .chart-title {
        color: white;
      }

      .income-stats {
        display: flex;
        justify-content: space-around;
        margin-top: 15px;
        flex-wrap: wrap;
        gap: 15px;
      }

      .income-stat-item {
        text-align: center;
      }

      .income-stat-value {
        font-size: 28px;
        font-weight: 800;
        color: #fbbf24;
      }

      .income-stat-label {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 5px;
      }

      .history-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
      }

      .history-table th,
      .history-table td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid var(--border);
        font-size: 12px;
      }

      .history-table th {
        background: var(--cream-lt);
        font-weight: 700;
        color: var(--text);
      }

      .history-table tr:hover td {
        background: var(--cream-lt);
      }

      .badge-transaction {
        background: #dbeafe;
        color: #1e40af;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 10px;
        font-weight: 600;
      }

      .badge-activity {
        background: #f1f5f9;
        color: #475569;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 10px;
        font-weight: 600;
      }

      .section-header {
        margin-bottom: 16px;
        border-left: 4px solid var(--orange);
        padding-left: 12px;
      }

      .section-header h2 {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text);
      }

      .total-customers-badge {
        background: var(--orange);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        margin-left: 10px;
      }

      .establishment-card {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
        border-radius: var(--radius);
        padding: 20px;
        margin-bottom: 24px;
        text-align: center;
      }

      .establishment-stats {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
        margin-top: 10px;
      }

      .establishment-stat {
        text-align: center;
      }

      .establishment-value {
        font-size: 32px;
        font-weight: 800;
        color: #fbbf24;
      }

      .establishment-label {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 5px;
      }

      /* income logs table styles function */
      .income-logs-section {
        margin-top: 24px;
      }

      .income-logs-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        flex-wrap: wrap;
        gap: 12px;
      }

      .income-period-log-select {
        padding: 8px 16px;
        border-radius: 30px;
        border: 1px solid #cbd5e1;
        background: white;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
      }

      .logs-table {
        width: 100%;
        border-collapse: collapse;
      }

      .logs-table th,
      .logs-table td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #e2e8f0;
        font-size: 12px;
      }

      .logs-table th {
        background: #f8fafc;
        font-weight: 700;
        color: #1e293b;
        cursor: pointer;
        user-select: none;
        position: relative;
      }

      .logs-table th:hover {
        background: #f1f5f9;
      }

      .logs-table tr:hover td {
        background: #f8fafc;
      }

      .badge-income {
        background: #dcfce7;
        color: #166534;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 10px;
        font-weight: 600;
        display: inline-block;
      }

      .search-wrapper {
        position: relative;
        margin-bottom: 15px;
      }

      .search-wrapper i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-sm);
        font-size: 13px;
      }

      .search-input {
        width: 100%;
        padding: 8px 12px 8px 35px;
        border-radius: 8px;
        border: 1px solid var(--border);
        font-size: 13px;
        outline: none;
        transition: 0.2s;
      }

      .search-input:focus {
        border-color: var(--orange);
        box-shadow: 0 0 0 3px rgba(207, 99, 34, 0.1);
      }

      .sort-icon {
        font-size: 10px;
        margin-left: 5px;
        color: #94a3b8;
      }

      .th-sort-active .sort-icon {
        color: var(--orange);
      }

      @media(max-width:900px) {
        .stat-grid-4, .stat-grid-3, .two-col-grid, .three-col-grid {
          grid-template-columns: 1fr;
        }
        .establishment-stats {
          gap: 20px;
        }
      }

      @media print {
        .sidebar, .mobile-menu-btn, .btn, .chart-controls, .search-wrapper, .mobile-overlay, .modal-overlay {
          display: none !important;
        }
        .content {
          margin: 0 !important;
          padding: 0 !important;
          width: 100% !important;
        }
        .app {
          display: block !important;
        }
        .chart-card, .summary-card, .an-card, .establishment-card, .income-overview-card {
          box-shadow: none !important;
          border: 1px solid #eee !important;
          break-inside: avoid;
        }
      }

      /* modal styles function */
      .modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(30, 42, 56, 0.6);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        backdrop-filter: blur(4px);
        padding: 20px;
      }
      .modal-overlay.show { display: flex; }
      .modal-card {
        background: #fff;
        border-radius: 16px;
        width: 100%;
        max-width: 480px;
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.2);
        overflow: hidden;
        animation: modalIn 0.3s ease-out;
      }
      @keyframes modalIn { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
      .modal-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
      }
      .modal-header h3 { font-size: 1.1rem; margin: 0; color: #1e293b; font-weight: 700; }
      .modal-close { background: none; border: none; font-size: 24px; color: #94a3b8; cursor: pointer; transition: 0.2s; }
      .modal-close:hover { color: #1e293b; }
      .modal-body { padding: 24px; max-height: 70vh; overflow-y: auto; }
      .modal-section { margin-bottom: 24px; }
      .modal-section:last-child { margin-bottom: 0; }
      .modal-section label.section-title { display: block; margin-bottom: 10px; font-weight: 600; font-size: 0.9rem; color: #475569; text-transform: uppercase; letter-spacing: 0.5px; }
      .date-inputs { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 12px; }
      .date-inputs input { width: 100%; padding: 10px 12px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-family: inherit; font-size: 0.9rem; outline: none; }
      .date-inputs input:focus { border-color: var(--orange); }
      .checkbox-group { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      .checkbox-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; background: #f8fafc; border-radius: 8px; cursor: pointer; transition: 0.2s; border: 1.5px solid transparent; }
      .checkbox-item:hover { background: #f1f5f9; }
      .checkbox-item input { width: 18px; height: 18px; accent-color: var(--orange); cursor: pointer; }
      .checkbox-item span { font-size: 0.9rem; color: #1e293b; font-weight: 500; }
      .modal-footer {
        padding: 18px 24px;
        background: #f8fafc;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
      }
      .modal-btn-cancel { padding: 10px 20px; background: #fff; border: 1.5px solid #e2e8f0; border-radius: 8px; color: #64748b; font-weight: 600; cursor: pointer; transition: 0.2s; }
      .modal-btn-cancel:hover { background: #f1f5f9; color: #1e293b; }
    </style>

    <div class="app">

      <%- include('../partials/admin_sidebar', { active: 'Analytics & Reports' }) %>

        <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>

        <main class="content">
          <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>

          <div class="page-header">
            <h1 class="page-title">Analytics & Reports</h1>
          </div>

          <!-- since establishment cards function -->
          <div class="establishment-card">
            <div class="chart-title" style="justify-content:center;"><i class="fa-solid fa-building"
                style="color:#fbbf24;"></i> Since Establishment (January 2024)</div>
            <div class="establishment-stats">
              <div class="establishment-stat">
                <div class="establishment-value" id="totalCustomersSince">0</div>
                <div class="establishment-label">Total Customers</div>
              </div>
              <div class="establishment-stat">
                <div class="establishment-value" id="totalIncomeSince">₱0</div>
                <div class="establishment-label">Total Income</div>
              </div>
              <div class="establishment-stat">
                <div class="establishment-value" id="totalHoursConsumed">0</div>
                <div class="establishment-label">Total Hours Consumed</div>
              </div>
            </div>
          </div>

          <!-- stats cards function -->
          <div class="stat-grid-4" style="grid-template-columns: repeat(5, 1fr);">
            <div class="an-card">
              <div class="an-icon" style="color:var(--olive)"><i class="fa-solid fa-arrow-trend-up"></i></div>
              <div class="an-val" id="statPeak">0</div>
              <div class="an-lbl">Peak</div>
            </div>
            <div class="an-card">
              <div class="an-icon" style="color:var(--orange)"><i class="fa-solid fa-chart-bar"></i></div>
              <div class="an-val" id="statAvg">0</div>
              <div class="an-lbl">Average</div>
            </div>
            <div class="an-card">
              <div class="an-icon" style="color:#3498db"><i class="fa-solid fa-users"></i></div>
              <div class="an-val" id="statTotal">0</div>
              <div class="an-lbl">Total</div>
            </div>
            <div class="an-card">
              <div class="an-icon" style="color:var(--green)"><i class="fa-solid fa-arrow-trend-down"></i></div>
              <div class="an-val" id="statLow">0</div>
              <div class="an-lbl">Low</div>
            </div>
            <div class="an-card" style="border: 2px solid var(--orange);">
              <div class="an-icon" style="color:var(--orange)"><i class="fa-solid fa-chair"></i></div>
              <div class="an-val" id="statOccupied" style="color:var(--orange);">0</div>
              <div class="an-lbl">Occupied Now</div>
            </div>
          </div>

          <!-- customer traffic section function -->
          <div class="section-header">
            <h2><i class="fa-solid fa-chart-line"></i> Customer Traffic</h2>
          </div>
          <div class="chart-card">
            <div class="chart-header">
              <div class="chart-title">Customer Traffic Overview</div>
              <div class="chart-controls">
                <select id="trafficPeriodSelect" onchange="updateTrafficChart()">
                  <option value="today">Peak Hours (Today)</option>
                  <option value="week">Daily (This Week)</option>
                  <option value="month">Weekly (Last 4 Weeks)</option>
                  <option value="halfyear">Monthly (Last 6 Months)</option>
                </select>
              </div>
            </div>
            <div class="chart-box"><canvas id="trafficChart"></canvas></div>
          </div>

          <!-- income section function -->
          <div class="section-header">
            <h2><i class="fa-solid fa-coins"></i> Income</h2>
          </div>

          <!-- income overview card (linked to income breakdown dropdown) function -->
          <div class="income-overview-card">
            <div class="chart-title"><i class="fa-solid fa-chart-simple" style="color:#fbbf24;"></i> Income Overview
            </div>
            <div class="income-stats">
              <div class="income-stat-item">
                <div class="income-stat-value" id="incomeTotal">₱0</div>
                <div class="income-stat-label">Total Income</div>
              </div>
              <div class="income-stat-item">
                <div class="income-stat-value" id="incomeAvg">₱0</div>
                <div class="income-stat-label">Average per Day</div>
              </div>
              <div class="income-stat-item">
                <div class="income-stat-value" id="incomeProjected">₱0</div>
                <div class="income-stat-label">Projected (Month)</div>
              </div>
            </div>
          </div>

          <!-- income breakdown chart function -->
          <div class="chart-card">
            <div class="chart-header">
              <div class="chart-title">Income Breakdown</div>
              <div class="chart-controls">
                <select id="incomePeriodSelect" onchange="updateIncomeChart()">
                  <option value="today">Peak Hours (Today)</option>
                  <option value="week">Daily (This Week)</option>
                  <option value="month">Weekly (Last 4 Weeks)</option>
                  <option value="halfyear">Monthly (Last 6 Months)</option>
                </select>
              </div>
            </div>
            <div class="chart-box"><canvas id="incomeChart"></canvas></div>
          </div>

          <!-- income logs section (daily, weekly, monthly dropdown) function -->
          <div class="income-logs-section">
            <div class="income-logs-header">
              <div class="chart-title"><i class="fa-solid fa-receipt"></i> Income Logs & Transaction Details</div>
              <div class="chart-controls">
                <div class="search-wrapper" style="margin-bottom:0; width:200px;">
                  <i class="fa-solid fa-magnifying-glass"></i>
                  <input type="text" class="search-input" id="incomeLogSearch" placeholder="Search logs..."
                    oninput="renderIncomeLogs()">
                </div>
                <select id="incomeLogsPeriodSelect" class="income-period-log-select" onchange="renderIncomeLogs()">
                  <option value="daily">Daily (Today's Transactions)</option>
                  <option value="week">Weekly (Last 7 Days)</option>
                  <option value="month">Monthly (Last 4 Weeks)</option>
                </select>
              </div>
            </div>
            <div class="summary-card" style="overflow-x:auto;">
              <table class="logs-table">
                <thead>
                  <tr>
                    <th onclick="sortLogs('period')">Period <i class="fa-solid fa-sort sort-icon"></i></th>
                    <th onclick="sortLogs('totalIncome')">Total Income <i class="fa-solid fa-sort sort-icon"></i></th>
                    <th onclick="sortLogs('transactions')">Transactions <i class="fa-solid fa-sort sort-icon"></i></th>
                    <th>Reservations</th>
                    <th>WiFi Extensions</th>
                    <th>Plan Upgrades</th>
                    <th>Walk-ins</th>
                    <th>Payment Methods</th>
                  </tr>
                </thead>
                <tbody id="incomeLogsBody"></tbody>
              </table>
            </div>
          </div>

          <!-- customer breakdown section function -->
          <div class="section-header">
            <h2><i class="fa-solid fa-users"></i> Customer Breakdown</h2>
          </div>

          <!-- top customers (members vs walkins) function -->
          <div class="two-col-grid">
            <div class="summary-card">
              <div class="chart-title"><i class="fa-solid fa-crown"></i> Top Members by Hours</div>
              <div class="search-wrapper">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" class="search-input" id="memberSearch" placeholder="Search members..."
                  oninput="renderTopCustomers()">
              </div>
              <div class="top-customer-list" id="topMembersList"></div>
              <div
                style="margin-top:12px;text-align:center;font-size:12px;color:var(--text-sm);border-top:1px solid var(--border);padding-top:10px;">
                Total Member Hours: <strong id="totalMemberHours">0</strong> hrs
              </div>
            </div>
            <div class="summary-card">
              <div class="chart-title"><i class="fa-solid fa-person-walking"></i> Top Walk-ins by Hours</div>
              <div class="search-wrapper">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" class="search-input" id="walkinSearch" placeholder="Search walk-ins..."
                  oninput="renderTopCustomers()">
              </div>
              <div class="top-customer-list" id="topWalkinsList"></div>
              <div
                style="margin-top:12px;text-align:center;font-size:12px;color:var(--text-sm);border-top:1px solid var(--border);padding-top:10px;">
                Total Walk-in Hours: <strong id="totalWalkinHours">0</strong> hrs
              </div>
            </div>
          </div>

          <!-- customer type breakdown with total customers function -->
          <div class="summary-card" style="margin-bottom:24px;">
            <div class="chart-title"><i class="fa-solid fa-chart-pie"></i> Customer Type Breakdown</div>
            <div class="chart-box" style="height:200px"><canvas id="typeChart"></canvas></div>
            <div style="display:flex;justify-content:space-around;margin-top:16px;flex-wrap:wrap;gap:10px;">
              <div><span
                  style="background:#CF6322;display:inline-block;width:12px;height:12px;border-radius:50%;"></span>
                Members: <strong id="memberCount">0</strong></div>
              <div><span
                  style="background:#8A8636;display:inline-block;width:12px;height:12px;border-radius:50%;"></span>
                Walk-ins: <strong id="walkinCount">0</strong></div>
              <div><span
                  style="background:#4A7C59;display:inline-block;width:12px;height:12px;border-radius:50%;"></span>
                Premium: <strong id="premiumCount">0</strong></div>
              <div><span class="total-customers-badge"><i class="fa-solid fa-users"></i> Total: <span
                    id="totalCustomersCount">0</span></span></div>
            </div>
          </div>

          <!-- transaction & activity section function -->
          <div class="section-header">
            <h2><i class="fa-solid fa-receipt"></i> Transaction & Activity</h2>
          </div>

          <!-- transaction history table function -->
          <div class="summary-card" style="margin-bottom:24px;">
            <div class="search-wrapper">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input type="text" class="search-input" id="transSearch" placeholder="Search transactions..."
                oninput="renderTransactionHistory()">
            </div>
            <div style="overflow-x:auto;">
              <table class="history-table">
                <thead>
                  <tr>
                    <th onclick="sortTransactions('date')" style="cursor:pointer">Date <i
                        class="fa-solid fa-sort sort-icon"></i></th>
                    <th onclick="sortTransactions('customer')" style="cursor:pointer">Customer <i
                        class="fa-solid fa-sort sort-icon"></i></th>
                    <th>Type</th>
                    <th onclick="sortTransactions('amount')" style="cursor:pointer">Amount <i
                        class="fa-solid fa-sort sort-icon"></i></th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="transactionHistoryBody"></tbody>
              </table>
            </div>
          </div>

          <!-- activity history table function -->
          <div class="summary-card" style="margin-bottom:24px;">
            <div class="search-wrapper">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input type="text" class="search-input" id="activitySearch" placeholder="Search activities..."
                oninput="renderActivityHistory()">
            </div>
            <div style="overflow-x:auto;">
              <table class="history-table">
                <thead>
                  <tr>
                    <th onclick="sortActivity('timestamp')" style="cursor:pointer">Timestamp <i
                        class="fa-solid fa-sort sort-icon"></i></th>
                    <th onclick="sortActivity('user')" style="cursor:pointer">User <i
                        class="fa-solid fa-sort sort-icon"></i></th>
                    <th>Action</th>
                    <th>Details</th>
                  </tr>
                </thead>
                <tbody id="activityHistoryBody"></tbody>
              </table>
            </div>
          </div>

          <!-- financial summary section (with loss) function -->
          <div class="section-header">
            <h2><i class="fa-solid fa-chart-simple"></i> Financial Summary</h2>
          </div>

          <div class="three-col-grid">
            <div class="summary-card">
              <div class="chart-title"><i class="fa-solid fa-receipt"></i> Recent Transactions</div>
              <div class="summary-row"><span class="summary-label">Reservations</span><span class="summary-value"
                  id="revenueReservations">₱0</span></div>
              <div class="summary-row"><span class="summary-label">WiFi Extensions</span><span class="summary-value"
                  id="revenueWifi">₱0</span></div>
              <div class="summary-row"><span class="summary-label">Plan Upgrades</span><span class="summary-value"
                  id="revenueUpgrades">₱0</span></div>
              <div class="summary-row total-revenue"><span class="summary-label">Total Revenue</span><span
                  class="summary-value" id="totalRevenue">₱0</span></div>
              <div class="summary-row loss-amount"><span class="summary-label">Loss (Pending/Unpaid)</span><span
                  class="summary-value" id="lossAmount">₱0</span></div>
            </div>
            <div class="summary-card">
              <div class="chart-title"><i class="fa-solid fa-clock"></i> Payment Status</div>
              <div class="summary-row"><span class="summary-label">Pending Payments</span><span class="summary-value"
                  id="pendingPayments">₱0</span></div>
              <div class="summary-row"><span class="summary-label">Completed Payments</span><span class="summary-value"
                  id="completedPayments">₱0</span></div>
              <div class="summary-row"><span class="summary-label">Pending %</span><span class="pending-badge"
                  id="pendingPercent">0%</span></div>
              <div class="summary-row" style="margin-top:10px;"><span class="summary-label">Total Pending
                  Customers</span><span class="summary-value" id="pendingCustomers">0</span></div>
              <div class="summary-row"><span class="summary-label">Total Paid Customers</span><span
                  class="summary-value" id="paidCustomers">0</span></div>
            </div>
            <div class="summary-card">
              <div class="chart-title"><i class="fa-solid fa-calendar-week"></i> Weekly Customer Summary</div>
              <div class="summary-row"><span class="summary-label">Members (This Week)</span><span class="summary-value"
                  id="weeklyMembers">0</span></div>
              <div class="summary-row"><span class="summary-label">Walk-ins (This Week)</span><span
                  class="summary-value" id="weeklyWalkins">0</span></div>
              <div class="summary-row"><span class="summary-label">Premium (This Week)</span><span class="summary-value"
                  id="weeklyPremium">0</span></div>
              <div class="summary-row total-revenue" style="background:#3498db"><span class="summary-label">Total This
                  Week</span><span class="summary-value" id="weeklyTotal">0</span></div>
            </div>
          </div>

          <!-- global generate report buttons function -->
          <div style="display:flex;justify-content:flex-end;margin-top:16px;gap:12px;">
            <button class="btn btn-secondary" onclick="openReportModal('csv')" style="padding:12px 24px; background: #8A8636; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 8px;">
                <i class="fa-solid fa-file-csv"></i> Export CSV
            </button>
            <button class="btn btn-primary" onclick="openReportModal('pdf')" style="padding:12px 24px; display: flex; align-items: center; gap: 8px;">
                <i class="fa-solid fa-file-pdf"></i> Export PDF
            </button>
          </div>

          <!-- report config modal function -->
          <div id="reportModal" class="modal-overlay">
            <div class="modal-card">
              <div class="modal-header">
                <h3>Configure <span id="reportFormatType">CSV</span> Report</h3>
                <button class="modal-close" onclick="closeReportModal()">&times;</button>
              </div>
              <div class="modal-body">
                <div class="modal-section">
                  <label class="section-title">Date Range</label>
                  <div class="date-inputs">
                    <input type="date" id="reportStartDate">
                    <span style="color:#94a3b8; font-weight:600;">to</span>
                    <input type="date" id="reportEndDate">
                  </div>
                </div>
                <div class="modal-section">
                  <label class="section-title">Include Data Sections</label>
                  <div class="checkbox-group">
                    <label class="checkbox-item"><input type="checkbox" id="checkIncome" checked> <span>Income Logs</span></label>
                    <label class="checkbox-item"><input type="checkbox" id="checkTrans" checked> <span>Transactions</span></label>
                    <label class="checkbox-item"><input type="checkbox" id="checkActivity" checked> <span>Activity Logs</span></label>
                    <label class="checkbox-item"><input type="checkbox" id="checkCustomers" checked> <span>Top Members</span></label>
                  </div>
                </div>
                <!-- filter keywords removed as requested function -->

              </div>
              <div class="modal-footer">
                <button class="modal-btn-cancel" onclick="closeReportModal()">Cancel</button>
                <button class="btn btn-primary" id="finalExportBtn" onclick="executeExport()">
                  Generate <span id="reportFormatBtn">CSV</span>
                </button>
              </div>
            </div>
          </div>

        </main>
    </div>

    <%- contentFor('script') %>
      <!-- html2pdf.js for professional pdf reports function -->
      <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
      <script>

        /* global state function */
        let rawData = null;
        let trafficChart = null;
        let incomeChart = null;
        let typeChart = null;

        /* sort states function */
        let transSort = { key: 'date', dir: 'desc' };
        let activitySort = { key: 'timestamp', dir: 'desc' };
        let logsSort = { key: 'period', dir: 'desc' };

        /* fetch data function */
        async function loadAnalyticsData() {
          try {
            const res = await fetch('/api/analytics');
            rawData = await res.json();
            
            /* initial render function */
            updateDashboard();
          } catch (error) {
            console.error('Failed to load analytics:', error);
          }
        }

        function updateDashboard() {
          if (!rawData) return;

          updateSinceEstablishment();
          renderTypeChart();
          renderTopCustomers();
          renderTransactionHistory();
          renderActivityHistory();
          updateTrafficChart();
          updateIncomeChart();
          renderIncomeLogs();
          renderTransactionSummary();
        }

        /* render functions function */
        function formatPHP(amount) { 
          return '₱' + (amount || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); 
        }

        function updateSinceEstablishment() {
          const stats = rawData.statsSince;
          document.getElementById('totalCustomersSince').textContent = (Number(stats.totalCustomers) || 0).toLocaleString();
          document.getElementById('totalIncomeSince').innerHTML = formatPHP(Number(stats.totalIncome));
          document.getElementById('totalHoursConsumed').textContent = (Number(stats.totalHours) || 0).toLocaleString();
        }

        function updateTrafficChart() {
          const period = document.getElementById('trafficPeriodSelect').value;
          let labels = [];
          let dataset = [];

          if (period === 'today') {
            const hours = rawData.hourlyStats || [];
            labels = Array.from({length: 24}, (_, i) => `${i}:00`);
            dataset = Array.from({length: 24}, () => 0);
            hours.forEach(h => { dataset[h.hour] = Number(h.count); });
          } else if (period === 'week') {
            /* build dynamic 7day window ending today function */
            const dataMap = {};
            (rawData.dailyStats || []).forEach(d => {
              const key = new Date(d.date).toISOString().split('T')[0];
              dataMap[key] = Number(d.count);
            });
            for (let i = 6; i >= 0; i--) {
              const dt = new Date();
              dt.setDate(dt.getDate() - i);
              const key = dt.toISOString().split('T')[0];
              labels.push(dt.toLocaleDateString('en-US', { weekday: 'short' }));
              dataset.push(dataMap[key] || 0);
            }
          } else {
            const stats = rawData.dailyStats || [];
            labels = stats.map(d => new Date(d.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
            dataset = stats.map(d => Number(d.count));
          }

          if (trafficChart) trafficChart.destroy();
          const ctx = document.getElementById('trafficChart').getContext('2d');
          trafficChart = new Chart(ctx, {
            type: 'line',
            data: { 
              labels: labels, 
              datasets: [{ 
                label: 'Customers', 
                data: dataset, 
                borderColor: '#CF6322', 
                backgroundColor: 'rgba(207,99,34,.12)', 
                borderWidth: 2.5, 
                fill: true, 
                tension: 0.4, 
                pointBackgroundColor: '#CF6322', 
                pointRadius: 4 
              }] 
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
          });

          /* update top cards function */
          const peak = Math.max(...dataset, 0);
          const total = dataset.reduce((a, b) => a + Number(b), 0);
          const avg = dataset.length ? Math.round(total / dataset.length) : 0;
          const low = dataset.length ? Math.min(...dataset) : 0;

          document.getElementById('statPeak').textContent = peak;
          document.getElementById('statAvg').textContent = avg;
          document.getElementById('statTotal').textContent = total;
          document.getElementById('statLow').textContent = low;
          /* show occupied now if element exists function */
          const occEl = document.getElementById('statOccupied');
          if (occEl) occEl.textContent = rawData.occupiedSeats || 0;
        }

        function updateIncomeChart() {
          const period = document.getElementById('incomePeriodSelect').value;
          const stats = [...(rawData.dailyStats || [])];
          let labels = [];
          let dataset = [];

          if (period === 'today') {
            const hours = rawData.hourlyStats || [];
            labels = Array.from({length: 24}, (_, i) => `${i}:00`);
            dataset = Array.from({length: 24}, () => 0);
            hours.forEach(h => { dataset[h.hour] = Number(h.income || 0); });
          } else if (period === 'week') {
            /* build dynamic 7day window ending today function */
            const dataMap = {};
            stats.forEach(d => {
              const key = new Date(d.date).toISOString().split('T')[0];
              dataMap[key] = Number(d.income || 0);
            });
            for (let i = 6; i >= 0; i--) {
              const dt = new Date();
              dt.setDate(dt.getDate() - i);
              const key = dt.toISOString().split('T')[0];
              labels.push(dt.toLocaleDateString('en-US', { weekday: 'short' }));
              dataset.push(dataMap[key] || 0);
            }
          } else {
            labels = stats.map(d => new Date(d.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
            dataset = stats.map(d => Number(d.income || 0));
          }

          if (incomeChart) incomeChart.destroy();
          const ctx = document.getElementById('incomeChart').getContext('2d');
          incomeChart = new Chart(ctx, {
            type: 'bar',
            data: { labels: labels, datasets: [{ label: 'Income (Php)', data: dataset, backgroundColor: '#8A8636', borderRadius: 6 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => 'Php ' + Number(ctx.raw).toFixed(2) } } }, scales: { y: { beginAtZero: true, ticks: { callback: (val) => 'Php ' + val.toLocaleString() } } } }
          });

          /* overview stats: always use alltime paid income from incomelogs function */
          const allLogs = rawData.incomeLogs || [];
          const allTimeTotal = allLogs.reduce((a, l) => a + Number(l.paidAmount || 0), 0);
          const allTimeAvg = allLogs.length ? allTimeTotal / allLogs.length : 0;
          document.getElementById('incomeTotal').innerHTML = formatPHP(allTimeTotal);
          document.getElementById('incomeAvg').innerHTML = formatPHP(allTimeAvg);
          document.getElementById('incomeProjected').innerHTML = formatPHP(allTimeAvg * 30);
        }

        function renderIncomeLogs() {
          const period = document.getElementById('incomeLogsPeriodSelect').value;
          const q = (document.getElementById('incomeLogSearch').value || "").toLowerCase();
          let logs = [...rawData.incomeLogs];

          if (period === 'daily') logs = logs.slice(0, 1);
          else if (period === 'week') logs = logs.slice(0, 7);

          if (q) {
            logs = logs.filter(l => new Date(l.period).toDateString().toLowerCase().includes(q));
          }

          const tbody = document.getElementById('incomeLogsBody');
          tbody.innerHTML = logs.map(log => `
            <tr>
              <td><strong>${new Date(log.period).toLocaleDateString()}</strong></td>
              <td><span style="font-weight:800;color:#CF6322;">${formatPHP(Number(log.totalIncome))}</span></td>
              <td>${log.transactions} transactions</td>
              <td>${formatPHP(Number(log.paidAmount))} (Paid)</td>
              <td>${formatPHP(Number(log.unpaidAmount))} (Unpaid)</td>
              <td>-</td>
              <td>-</td>
              <td><span style="font-size:11px;">Detailed breakdown in report</span></td>
            </tr>
          `).join('');
        }

        function renderTypeChart() {
          const b = rawData.typeBreakdown;
          if (typeChart) typeChart.destroy();
          const ctx = document.getElementById('typeChart').getContext('2d');
          typeChart = new Chart(ctx, {
            type: 'doughnut',
            data: { labels: ['Members', 'Walk-ins', 'Premium'], datasets: [{ data: [Number(b.members), Number(b.walkins), Number(b.premium)], backgroundColor: ['#CF6322', '#8A8636', '#4A7C59'], borderWidth: 0, hoverOffset: 8 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } } } }
          });
          document.getElementById('memberCount').textContent = Number(b.members);
          document.getElementById('walkinCount').textContent = Number(b.walkins);
          document.getElementById('premiumCount').textContent = Number(b.premium);
          document.getElementById('totalCustomersCount').textContent = (Number(b.members) + Number(b.walkins));
        }

        function renderTopCustomers() {
          const top = rawData.topCustomers;
          const membersList = document.getElementById('topMembersList');
          const walkinsList = document.getElementById('topWalkinsList');

          const members = top.filter(u => u.type === 'member');
          const walkins = top.filter(u => u.type === 'walkin');

          membersList.innerHTML = members.map((u, i) => `
            <div class="top-customer-item">
              <div><span class="top-customer-name">${i+1}. ${u.first_name} ${u.last_name}</span></div>
              <div class="top-customer-hours">${Number(u.total_hours)} hrs</div>
            </div>
          `).join('');

          walkinsList.innerHTML = walkins.map((u, i) => `
            <div class="top-customer-item">
              <div><span class="top-customer-name">${i+1}. ${u.first_name} ${u.last_name}</span></div>
              <div class="top-customer-hours">${Number(u.total_hours)} hrs</div>
            </div>
          `).join('');

          document.getElementById('totalMemberHours').textContent = members.reduce((a, b) => a + Number(b.total_hours), 0);
          document.getElementById('totalWalkinHours').textContent = walkins.reduce((a, b) => a + Number(b.total_hours), 0);
        }

        function renderTransactionHistory() {
          const q = (document.getElementById('transSearch').value || "").toLowerCase();
          let trans = [...rawData.transactions];

          if (q) {
             trans = trans.filter(t => 
                (t.first_name + " " + t.last_name).toLowerCase().includes(q) || 
                t.payment_status.toLowerCase().includes(q)
             );
          }

          trans.sort((a, b) => {
             let valA, valB;
             if (transSort.key === 'date') { valA = new Date(a.start_time); valB = new Date(b.start_time); }
             else if (transSort.key === 'customer') { valA = (a.first_name + a.last_name).toLowerCase(); valB = (b.first_name + b.last_name).toLowerCase(); }
             else if (transSort.key === 'amount') { valA = Number(a.amount); valB = Number(b.amount); }
             else { valA = a[transSort.key]; valB = b[transSort.key]; }
             
             if (valA < valB) return transSort.dir === 'asc' ? -1 : 1;
             if (valA > valB) return transSort.dir === 'asc' ? 1 : -1;
             return 0;
          });

          const tbody = document.getElementById('transactionHistoryBody');
          tbody.innerHTML = trans.map(t => `
            <tr>
              <td>${new Date(t.start_time).toLocaleString()}</td>
              <td>${t.first_name} ${t.last_name}</td>
              <td><span class="badge-transaction">Reservation</span></td>
              <td>${formatPHP(Number(t.amount))}</td>
              <td><span class="${t.payment_status === 'paid' ? 'badge-income' : 'pending-badge'}">${t.payment_status}</span></td>
            </tr>
          `).join('');
        }

        function renderActivityHistory() {
          const q = (document.getElementById('activitySearch').value || "").toLowerCase();
          let logs = [...rawData.doorLogs];

          if (q) {
             logs = logs.filter(l => 
                (l.first_name + " " + l.last_name).toLowerCase().includes(q) || 
                l.door_name.toLowerCase().includes(q) ||
                l.status.toLowerCase().includes(q)
             );
          }

          logs.sort((a, b) => {
             let valA, valB;
             if (activitySort.key === 'timestamp') { valA = new Date(a.access_time); valB = new Date(b.access_time); }
             else if (activitySort.key === 'user') { valA = (a.first_name + a.last_name).toLowerCase(); valB = (b.first_name + b.last_name).toLowerCase(); }
             else { valA = a[activitySort.key]; valB = b[activitySort.key]; }
             
             if (valA < valB) return activitySort.dir === 'asc' ? -1 : 1;
             if (valA > valB) return activitySort.dir === 'asc' ? 1 : -1;
             return 0;
          });

          const tbody = document.getElementById('activityHistoryBody');
          tbody.innerHTML = logs.map(l => `
            <tr>
              <td>${new Date(l.access_time).toLocaleString()}</td>
              <td>${l.first_name} ${l.last_name}</td>
              <td><span class="badge-activity">${l.door_name}</span></td>
              <td>${l.method} Access - ${l.status}</td>
            </tr>
          `).join('');
        }

        function renderTransactionSummary() {
          const stats = rawData.incomeLogs[0] || {};
          const wifiRev = (rawData.wifiCount || 0) * 50; 
          const planRev = (rawData.planCount || 0) * 1000;
          const resRev = Number(stats.totalIncome) || 0;

          document.getElementById('revenueReservations').innerHTML = formatPHP(resRev);
          if(document.getElementById('revenueWifi')) document.getElementById('revenueWifi').innerHTML = formatPHP(wifiRev);
          if(document.getElementById('revenueUpgrades')) document.getElementById('revenueUpgrades').innerHTML = formatPHP(planRev);
          
          const totalRev = resRev + wifiRev + planRev;
          document.getElementById('totalRevenue').innerHTML = formatPHP(totalRev);
          document.getElementById('completedPayments').innerHTML = formatPHP(Number(stats.paidAmount) + wifiRev + planRev);
          document.getElementById('lossAmount').innerHTML = formatPHP(Number(stats.unpaidAmount));
          document.getElementById('pendingPayments').innerHTML = formatPHP(Number(stats.unpaidAmount));
          
          const total = totalRev || 1;
          const percent = ((Number(stats.unpaidAmount) / total) * 100).toFixed(1);
          document.getElementById('pendingPercent').innerHTML = `${percent}% of daily revenue`;

          const ws = rawData.weeklySummary || {};
          document.getElementById('weeklyMembers').textContent = ws.weeklyMembers || 0;
          document.getElementById('weeklyWalkins').textContent = ws.weeklyWalkins || 0;
          document.getElementById('weeklyPremium').textContent = ws.weeklyPremium || 0;
          document.getElementById('weeklyTotal').textContent = (ws.weeklyMembers || 0) + (ws.weeklyWalkins || 0) + (ws.weeklyPremium || 0);
        }

        /* sidebar and init function */
        function openSidebar() { document.getElementById('sidebar').classList.add('mobile-open'); document.getElementById('mobileOverlay').classList.add('show'); }
        function closeSidebar() { document.getElementById('sidebar').classList.remove('mobile-open'); document.getElementById('mobileOverlay').classList.remove('show'); }

        function init() {
          Chart.defaults.font.family = "'Montserrat', sans-serif";
          Chart.defaults.color = "#1E2A38";
          loadAnalyticsData();
        }

        init();

        function sortTransactions(k) {
          if (transSort.key === k) transSort.dir = transSort.dir === 'asc' ? 'desc' : 'asc';
          else { transSort.key = k; transSort.dir = 'asc'; }
          renderTransactionHistory();
        }

        function sortActivity(k) {
          if (activitySort.key === k) activitySort.dir = activitySort.dir === 'asc' ? 'desc' : 'asc';
          else { activitySort.key = k; activitySort.dir = 'asc'; }
          renderActivityHistory();
        }

        function sortLogs(k) {
          if (logsSort.key === k) logsSort.dir = logsSort.dir === 'asc' ? 'desc' : 'asc';
          else { logsSort.key = k; logsSort.dir = 'asc'; }
          renderIncomeLogs();
        }

        /* report modal logic function */
        let currentExportFormat = 'csv';

        function openReportModal(format) {
          currentExportFormat = format;
          document.getElementById('reportFormatType').textContent = format.toUpperCase();
          document.getElementById('reportFormatBtn').textContent = format.toUpperCase();
          
          const now = new Date();
          const thirtyDaysAgo = new Date();
          thirtyDaysAgo.setDate(now.getDate() - 30);
          
          document.getElementById('reportStartDate').value = thirtyDaysAgo.toISOString().split('T')[0];
          document.getElementById('reportEndDate').value = now.toISOString().split('T')[0];
          
          document.getElementById('reportModal').classList.add('show');
        }

        function closeReportModal() {
          document.getElementById('reportModal').classList.remove('show');
        }

        function executeExport() {
          /* use iso strings so json.stringify serializes them correctly function */
          const startVal = document.getElementById('reportStartDate').value;
          const endVal = document.getElementById('reportEndDate').value;
          /* end date: include the whole day function */
          const start = startVal + 'T00:00:00';
          const end = endVal + 'T23:59:59';
          
          const includeIncome = document.getElementById('checkIncome').checked;
          const includeTrans = document.getElementById('checkTrans').checked;
          const includeActivity = document.getElementById('checkActivity').checked;
          const includeCustomers = document.getElementById('checkCustomers').checked;

          closeReportModal();

          if (currentExportFormat === 'csv') {
            generateCSVReport({ start, end, includeIncome, includeTrans, includeActivity, includeCustomers });
          } else {
            generatePDFReport({ start, end, includeIncome, includeTrans, includeActivity, includeCustomers });
          }
        }

        async function generateCSVReport(filters) {
          const btn = document.getElementById('finalExportBtn');
          const originalText = btn.innerHTML;
          btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Generating CSV...';
          btn.disabled = true;

          try {
            const response = await fetch('/api/export/csv', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ filters })
            });

            if (!response.ok) throw new Error('Server-side CSV generation failed');

            const text = await response.text();
            const blob = new Blob([text], { type: 'text/csv;charset=utf-8;' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `TheLastMuster_Report_${new Date().toISOString().split('T')[0]}.csv`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);

          } catch (error) {
            console.error('CSV Export Error:', error);
            alert('Failed to generate CSV. Falling back to local data...');
            /* fallback to local generation if server fails function */
            localCSVFallback(filters);
          } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
          }
        }

        function localCSVFallback(filters) {
          let csv = "\uFEFF"; // BOM for Excel UTF-8 support
          csv += "THE LAST MUSTER - ANALYTICS REPORT (LOCAL FALLBACK)\n";
          csv += `Generated: ${new Date().toLocaleString()}\n`;
          csv += `Range: ${filters.start.toLocaleDateString()} to ${filters.end.toLocaleDateString()}\n\n`;
          
          if (filters.includeIncome) {
            csv += "INCOME LOGS\n";
            csv += "Date,Total Income,Paid,Unpaid,Transactions\n";
            rawData.incomeLogs.forEach(log => {
               csv += `"${new Date(log.period).toLocaleDateString()}",${log.totalIncome || 0},${log.paidAmount || 0},${log.unpaidAmount || 0},${log.transactions}\n`;
            });
            csv += "\n";
          }
          
          if (filters.includeTrans) {
            csv += "TRANSACTION HISTORY\n";
            csv += "Date,Customer,Type,Amount,Status\n";
            rawData.transactions.forEach(t => {
               csv += `"${new Date(t.start_time).toLocaleString()}","${t.first_name} ${t.last_name}","Reservation",${t.amount},${t.payment_status}\n`;
            });
            csv += "\n";
          }

          const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `TheLastMuster_Report_Fallback.csv`;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
        }

        async function generatePDFReport(filters) {
          const btn = document.getElementById('finalExportBtn');
          const originalText = btn.innerHTML;
          btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Generating PDF...';
          btn.disabled = true;

          try {
            /* 1. safely capture charts as base64 images function */
            const chartImages = {};
            try { chartImages.traffic = document.getElementById('trafficChart').toDataURL('image/png'); } catch(e) {}
            try { chartImages.type    = document.getElementById('typeChart').toDataURL('image/png'); }    catch(e) {}
            try { chartImages.income  = document.getElementById('incomeChart').toDataURL('image/png'); }  catch(e) {}

            /* 2. call serverside pdf api function */
            const response = await fetch('/api/export/pdf', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ filters, chartImages })
            });

            if (!response.ok) {
              const errText = await response.text();
              throw new Error('Server error: ' + errText);
            }

            /* 3. download the binary pdf function */
            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `TheLastMuster_Report_${new Date().toISOString().split('T')[0]}.pdf`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);

          } catch (error) {
            console.error('PDF Export Error:', error);
            alert('PDF generation failed: ' + error.message + '\n\nCheck the browser console for details.');
          } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
          }
        }
      </script>
