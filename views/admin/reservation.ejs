    const filter = document.getElementById('reservationFilter').value;
    const search = document.getElementById('reservationSearch').value;
    let filtered = reservations.filter(r => filter === 'all' || r.status === filter).filter(r => matchesSearch(r, search));
    const tbody = document.getElementById('reservationBody');
    if(filtered.length === 0) { tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:40px;">No reservations</td></tr>'; return; }
    
    tbody.innerHTML = filtered.map(r => {
      let actionButtons = '';
      if (r.status === 'pending') {
        if (r.payment_method === 'cashier') {
          actionButtons = `<button class="btn-icon btn-success" onclick="openCashierConfirmModal('reservation', ${r.id})" title="Confirm Reservation"><i class="fa-solid fa-check"></i></button>
                           <button class="btn-icon btn-danger" onclick="rejectItem('reservation', ${r.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
        } else {
          actionButtons = `<button class="btn-icon btn-success" onclick="markGcashPaid('reservation', ${r.id})" title="Mark as Paid"><i class="fa-solid fa-check-circle"></i></button>
                           <button class="btn-icon btn-danger" onclick="rejectItem('reservation', ${r.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
        }
      } else if (r.status === 'unpaid') {
        actionButtons = `<button class="btn-icon btn-warning" onclick="openCashierPaymentModal('reservation', ${r.id})" title="Process Payment"><i class="fa-solid fa-credit-card"></i></button>`;
