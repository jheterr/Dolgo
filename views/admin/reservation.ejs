  function getSeatStatus(seatId) {
    if (occupiedSeats.includes(seatId)) return 'occupied';
    if (reservedSeats.includes(seatId)) return 'reserved';
    return 'available';
  }

  function updateMacFieldsUI() {
    const container = document.getElementById('macFieldsContainer');
    container.innerHTML = '<div class="mac-input-group"><input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" style="display:none;"><i class="fa-solid fa-minus"></i></button></div>';
    currentMacCount = 1;
    document.getElementById('addMacBtn').style.display = 'inline-flex';
  }

  function addNewMacField() {
    if (currentMacCount >= 3) { alert("Maximum 3 MAC addresses allowed."); return; }
    const container = document.getElementById('macFieldsContainer');
    const div = document.createElement('div');
    div.className = 'mac-input-group';
    div.innerHTML = `<input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" onclick="this.parentElement.remove(); currentMacCount--; document.getElementById('addMacBtn').style.display = 'inline-flex';"><i class="fa-solid fa-minus"></i></button>`;
    container.appendChild(div);
    currentMacCount++;
    if (currentMacCount >= 3) document.getElementById('addMacBtn').style.display = 'none';
  }

  function renderModalSeatLayout() {
    const containers = [
      { map: document.getElementById('modalSeatMapWalk'), view: document.getElementById('viewportWalk'), prefix: '' },
      { map: document.getElementById('modalSeatMapRes'), view: document.getElementById('viewportRes'), prefix: 'Res' }
    ];

    containers.forEach(c => {
      if (!c.map) return;
      c.map.innerHTML = '';
      
      floorLayout.forEach(item => {
        const el = document.createElement('div');
        el.className = 'fp-item';
        el.style.left = item.x + 'px';
        el.style.top = item.y + 'px';
        el.style.width = item.w + 'px';
        el.style.height = item.h + 'px';
        el.style.zIndex = (item.type === 'chair' || item.type === 'chair-sq') ? 5 : item.type.startsWith('block') ? 2 : 3;

        const visual = document.createElement('div');
        visual.className = 'item-visual';
        visual.style.transform = 'rotate(' + (item.rot || 0) + 'deg)';

        const isSeat = (item.type === 'chair' || item.type === 'chair-sq');
        const status = (item.statuses && item.statuses[0]) || 'open';

        if (item.type === 'chair') {
          visual.classList.add('chair-icon');
          visual.style.webkitMaskImage = 'url(/images/chair.png)';
          visual.style.maskImage = 'url(/images/chair.png)';
          visual.style.backgroundColor = (status === 'taken') ? '#d65c29' : '#10b981';
        } else if (item.type === 'chair-sq') {
          visual.style.background = (status === 'taken') ? '#d65c29' : '#10b981';
          visual.style.borderRadius = '4px';
        } else if (item.type === 'round-table' || item.type === 'rect-table') {
          visual.style.background = 'white';
          visual.style.borderRadius = item.type === 'round-table' ? '50%' : '8px';
          visual.style.border = '2px solid #1e293b';
        } else if (item.type === 'room') {
          const status = item.statuses ? item.statuses[0] : 'open';
          if (status === 'open') {
            visual.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
            visual.style.boxShadow = 'inset 0 0 10px rgba(255,255,255,0.2)';
          } else {
            visual.style.background = '#e11d48';
          }
          visual.style.borderRadius = '12px';
          visual.style.border = '3px solid rgba(255,255,255,0.3)';
          el.onclick = () => selectSeat(item, c.prefix);
        } else {
          visual.style.background = item.color || '#cbd5e1';
          visual.style.borderRadius = '4px';
        }
        el.appendChild(visual);

        if (item.label || item.type === 'room') {
          const lbl = document.createElement('span');
          lbl.className = 'item-label' + (['chair', 'chair-sq'].includes(item.type) ? '' : ' center');
          const status = item.statuses ? item.statuses[0] : 'open';
          lbl.style.color = (item.type === 'room' || status !== 'open') ? '#fff' : '#475569';
          lbl.style.fontFamily = "'Poppins', sans-serif";
          lbl.style.textShadow = item.type === 'room' ? '0 1px 3px rgba(0,0,0,0.3)' : 'none';
          lbl.textContent = item.label || (item.type === 'room' ? 'Room' : '');
          el.appendChild(lbl);
        }

        if (isSeat) {
          el.onclick = () => {
            c.map.querySelectorAll('.fp-item').forEach(s => s.classList.remove('selected'));
            el.classList.add('selected');
            document.getElementById('selectedSeat' + c.prefix).value = item.label;
            document.getElementById('selectedSeatId' + c.prefix).value = item.id;
            document.getElementById('selectedSeatDisplay' + c.prefix).innerHTML = `Selected: <strong>${item.label}</strong>`;
            if(c.prefix === '') selectedSeatForWalkin = item.label; // For walkin logic compatibility
          };
        }

        c.map.appendChild(el);
      });

      // Scale to fit modal
      const vWidth = c.view.clientWidth || 450;
      const vHeight = c.view.clientHeight || 300;
      const scale = Math.min(vWidth / 800, vHeight / 450) * 0.95;
      c.map.style.transform = `scale(${scale})`;
      c.map.style.left = `${(vWidth - (800 * scale)) / 2}px`;
      c.map.style.top = `${(vHeight - (450 * scale)) / 2}px`;
    });
  }

  function searchUsersForRes() {
    const search = document.getElementById('res-cust-search').value.toLowerCase();
    const results = document.getElementById('res-cust-results');
    if (search.length < 2) { results.style.display = 'none'; return; }
    
    const filtered = allUsers.filter(u => 
        u.first_name.toLowerCase().includes(search) || 
        u.last_name.toLowerCase().includes(search) || 
        u.email.toLowerCase().includes(search)
    ).slice(0, 5);
    
    if (filtered.length === 0) {
        results.innerHTML = '<div style="padding:8px; font-size:12px; color:#94a3b8;">No customers found.</div>';
    } else {
        results.innerHTML = filtered.map(u => `
            <div style="padding:8px; font-size:12px; border-bottom:1px solid #f1f5f9; cursor:pointer;" onclick="selectUserForRes(${u.id}, '${u.first_name} ${u.last_name}')">
                <strong>${u.first_name} ${u.last_name}</strong><br>
                <span style="font-size:10px; color:#64748b;">${u.email}</span>
            </div>
        `).join('');
    }
    results.style.display = 'block';
  }

  function selectUserForRes(id, name) {
    document.getElementById('res-cust-id').value = id;
    document.getElementById('res-cust-search').value = name;
    document.getElementById('res-cust-results').style.display = 'none';
  }

  async function submitReservation() {
    const userId = document.getElementById('res-cust-id').value;
    const date = document.getElementById('res-date').value;
    const start = document.getElementById('res-start').value;
    const end = document.getElementById('res-end').value;
    const elementId = document.getElementById('selectedSeatIdRes').value;
    
    if (!userId || !date || !start || !end || !elementId) {
        alert("Please fill all required fields and select a seat.");
        return;
    }
    
    try {
        const res = await fetch('/api/reservations/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId, date, startTime: start, endTime: end, elementId })
        });
        const data = await res.json();
        if (data.success) {
            alert("Reservation scheduled successfully!");
            closeModal('reservationModal');
            loadAllData();
        } else {
            alert("Error: " + data.error);
        }
    } catch(e) { console.error(e); }
  }

  function formatPHP(amount) { return '₱' + amount.toLocaleString(); }
  function escapeHtml(str) { if (!str) return ''; return String(str).replace(/[&<>]/g, m => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;' }[m] || m)); }
  
  function getStatusBadge(status) {
    if (status === 'pending') return '<span class="badge-pending">Pending</span>';
    if (status === 'unpaid') return '<span class="badge-unpaid">Unpaid</span>';
    if (status === 'confirmed') return '<span class="badge-paid" style="background:#dcfce7; color:#15803d">Confirmed</span>';
    return '<span class="badge-paid">Paid</span>';
  }
  
  function getPaymentMethodBadge(method) {
    return method === 'gcash' ? '<span class="badge-gcash">GCash</span>' : '<span class="badge-cashier">Cashier</span>';
  }

  function matchesSearch(item, term) { 
    if(!term) return true; 
    const t=term.toLowerCase(); 
    const name = `${item.first_name || ''} ${item.last_name || ''}`.toLowerCase();
    const email = (item.email || '').toLowerCase();
    const seat = (item.seat_label || '').toLowerCase();
    return name.includes(t) || email.includes(t) || seat.includes(t); 
  }

