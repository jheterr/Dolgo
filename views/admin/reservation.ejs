<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Reservations & Walk-ins' %>

<%- contentFor('style') %>
<style>

        .badge-pending {
      background: #fef3c7;
      color: #92400e;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      display: inline-block;
    }
    .badge-unpaid {
      background: #fee2e2;
      color: #b91c1c;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      display: inline-block;
    }
    .badge-paid {
      background: #dcfce7;
      color: #166534;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      display: inline-block;
    }
    .badge-gcash {
      background: #dbeafe;
      color: #1e40af;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      display: inline-block;
    }
    .badge-cashier {
      background: #f1f5f9;
      color: #475569;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      display: inline-block;
    }
    .btn-icon {
      width: 28px;
      height: 28px;
      padding: 0;
      border-radius: 6px;
      font-size: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
    }
    .btn-icon:hover {
      transform: scale(1.05);
    }
    .btn-success {
      background: #10b981;
      color: white;
    }
    .btn-success:hover {
      background: #059669;
    }
    .btn-danger {
      background: #ef4444;
      color: white;
    }
    .btn-danger:hover {
      background: #dc2626;
    }
    .btn-warning {
      background: #f97316;
      color: white;
    }
    .btn-warning:hover {
      background: #ea580c;
    }
    .btn-primary {
      background: #CF6322;
      color: white;
      border: none;
      padding: 8px 20px;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
    }
    .btn-scan {
      background: #4A7C59;
      color: white;
      border: none;
      padding: 8px 16px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
    }
    .btn-scan:hover {
      background: #3d6a4a;
    }
    .rfid-input-group {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .action-group {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.45);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 16px;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: var(--white);
      border-radius: var(--radius);
      padding: 28px;
      width: 100%;
      max-width: 520px;
      box-shadow: 0 20px 60px rgba(0,0,0,.2);
      display: flex;
      flex-direction: column;
      gap: 16px;
      max-height: 90vh;
      overflow-y: auto;
    }
    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .modal-title {
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 700;
    }
    .modal-close {
      background: none;
      border: none;
      font-size: 1.3rem;
      color: var(--text-sm);
      cursor: pointer;
    }
    .modal-body {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 8px;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }
    .form-label {
      font-size: 12px;
      font-weight: 600;
      color: #475569;
    }
    .form-control {
      padding: 8px 12px;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      font-size: 13px;
    }
    .btn-ghost {
      background: transparent;
      border: 1px solid #cbd5e1;
      padding: 8px 16px;
      border-radius: 6px;
      cursor: pointer;
    }
    
    /* Payment Info Modal Styles */
    .payment-info-card {
      background: #f8fafc;
      border-radius: 20px;
      padding: 20px;
      margin: 8px 0;
    }
    .payment-amount-large {
      font-size: 28px;
      font-weight: 800;
      color: #CF6322;
      margin: 8px 0;
    }
    .reference-box {
      background: white;
      border-radius: 12px;
      padding: 12px;
      font-family: 'Montserrat', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: #0078b0;
      border: 1px dashed #0078b0;
      margin: 12px 0;
      text-align: center;
    }
    .proof-image {
      background: #f1f5f9;
      border-radius: 16px;
      padding: 16px;
      text-align: center;
      margin: 12px 0;
      border: 1px solid #e2e8f0;
    }
    .proof-placeholder {
      background: #e2e8f0;
      border-radius: 12px;
      height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #64748b;
      font-size: 12px;
    }
    .gcash-icon { color: #0078b0; font-size: 40px; }
    .cashier-icon { color: #10b981; font-size: 40px; }
    .customer-detail-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid #e2e8f0;
    }
    .customer-detail-label {
      font-weight: 600;
      color: #475569;
    }
    .method-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 2px solid #e2e8f0;
    }
    
    /* MAC Address fields */
    .mac-fields-container {
      background: #f8fafc;
      padding: 12px;
      border-radius: 20px;
      margin: 8px 0;
    }
    .mac-input-group {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      align-items: center;
    }
    .mac-input-group input { flex: 1; margin: 0; }
    .remove-mac-btn {
      background: #fee2e2;
      border: none;
      width: 32px;
      height: 32px;
      border-radius: 30px;
      cursor: pointer;
      color: #b91c1c;
    }
    .add-mac-btn {
      background: #f1f5f9;
      border: none;
      padding: 8px 16px;
      border-radius: 30px;
      font-size: 0.7rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 8px;
    }
    
    /* Seat Layout inside Modal */
    .modal-seat-layout {
      background: #f8fafc;
      border-radius: 20px;
      padding: 16px;
      margin: 12px 0;
    }
    .modal-seat-layout h4 {
      font-size: 0.9rem;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .modal-seat-grid {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .modal-seat-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .modal-row-label {
      width: 32px;
      font-weight: 800;
      background: #e2e8f0;
      border-radius: 20px;
      text-align: center;
      padding: 4px 0;
      font-size: 0.8rem;
    }
    .modal-seats {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .modal-seat {
      width: 50px;
      height: 50px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      font-size: 0.65rem;
      font-weight: 600;
      cursor: pointer;
      transition: 0.1s;
      border: 2px solid;
    }
    .modal-seat span:first-child { font-size: 0.7rem; font-weight: 800; }
    .modal-seat.available { background: #dcfce7; border-color: #86efac; color: #166534; }
    .modal-seat.occupied { background: #fee2e2; border-color: #fecaca; color: #991b1b; cursor: not-allowed; opacity: 0.7; }
    .modal-seat.reserved { background: #fef9c3; border-color: #fde047; color: #854d0e; cursor: not-allowed; opacity: 0.7; }
    .modal-seat.idle { background: #fed7aa; border-color: #fdba74; color: #9a3412; cursor: not-allowed; opacity: 0.7; }
    .modal-seat.selected { background: #4f46e5; border-color: #4f46e5; color: white; }
    .legend {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-top: 12px;
      font-size: 0.65rem;
    }
    .legend span { display: inline-flex; align-items: center; gap: 4px; }

    /* Section Header with Filter and Search */
    .section-header-with-filter {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 12px;
    }
    .section-header-with-filter .section-title {
      margin-bottom: 0;
    }
    .filter-search-group {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
    }
    .filter-dropdown {
      padding: 6px 14px;
      border-radius: 30px;
      border: 1px solid #cbd5e1;
      background: white;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      outline: none;
      transition: all 0.2s;
    }
    .filter-dropdown:hover {
      border-color: #CF6322;
    }
    .filter-dropdown:focus {
      border-color: #CF6322;
      box-shadow: 0 0 0 2px rgba(207,99,34,0.1);
    }
    .search-input {
      padding: 6px 14px;
      border-radius: 30px;
      border: 1px solid #cbd5e1;
      background: white;
      font-size: 12px;
      font-weight: 500;
      outline: none;
      transition: all 0.2s;
      width: 220px;
    }
    .search-input:focus {
      border-color: #CF6322;
      box-shadow: 0 0 0 2px rgba(207,99,34,0.1);
    }
    .search-input::placeholder {
      color: #94a3b8;
      font-weight: 400;
    }


    /* Data Table Styles */
    .data-table { 
      width: 100%; 
      border-collapse: collapse; 
    }
    .data-table th, 
    .data-table td { 
      padding: 12px 8px; 
      text-align: left; 
      border-bottom: 1px solid #e2e8f0; 
      vertical-align: top; 
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .modal { padding: 20px; }
      .form-row { grid-template-columns: 1fr; }
      .modal-seat { width: 40px; height: 40px; font-size: 0.55rem; }
      .action-group { flex-wrap: wrap; }
      .filter-search-group { width: 100%; }
      .search-input { flex: 1; width: auto; }
      .filter-dropdown { flex-shrink: 0; }
      .rfid-input-group { flex-direction: column; }
      .btn-scan { width: 100%; }
    }
  
</style>

<div class="app">

  <%- include('../partials/admin_sidebar', { active: 'Reservation' }) %>

  <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>

  <main class="content">
    <button class="mobile-menu-btn" onclick="openSidebar()">
      <i class="fa-solid fa-bars"></i>
    </button>

    <div class="page-header">
      <h1 class="page-title">Reservations & Walk-ins</h1>
      <button class="btn-primary" style="padding: 10px 22px; border-radius: 40px;" onclick="openModal('walkinModal')"><i class="fa-solid fa-user-plus"></i> Add Customer</button>
    </div>
    
    <div class="tabs-nav">
      <button class="tab-btn active" onclick="switchTab(event, 'tab-reservation')"><i class="fa-regular fa-calendar-check"></i> Reservation</button>
      <button class="tab-btn" onclick="switchTab(event, 'tab-wifi')"><i class="fa-solid fa-wifi"></i> WiFi Extension</button>
      <button class="tab-btn" onclick="switchTab(event, 'tab-upgrade')"><i class="fa-solid fa-arrow-up"></i> Plan Upgrade</button>
    </div>
    
    <!-- ========== TAB 1: RESERVATION ========== -->
    <div id="tab-reservation" class="tab-panel active">
      <div class="card">
        <div class="section-header-with-filter">
          <div class="section-title"><i class="fa-regular fa-clock"></i> Reservation Requests</div>
          <div class="filter-search-group">
            <input type="text" id="reservationSearch" class="search-input" placeholder="Search..." onkeyup="filterReservations()">
            <select id="reservationFilter" class="filter-dropdown" onchange="filterReservations()">
              <option value="all">All Status</option>
              <option value="pending">Pending</option>
              <option value="unpaid">Unpaid</option>
              <option value="paid">Paid</option>
            </select>
          </div>
        </div>
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr><th>Name</th><th>Email</th><th>Seat</th><th>Hours</th><th>Date</th><th>Time</th><th>Amount</th><th>Payment Method</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody id="reservationBody"></tbody>
          </table>
        </div>
      </div>
    </div>
    
    <!-- ========== TAB 2: WIFI EXTENSION ========== -->
    <div id="tab-wifi" class="tab-panel">
      <div class="card">
        <div class="section-header-with-filter">
          <div class="section-title"><i class="fa-regular fa-hourglass-half"></i> WiFi Extension Requests</div>
          <div class="filter-search-group">
            <input type="text" id="wifiSearch" class="search-input" placeholder="Search..." onkeyup="filterWifi()">
            <select id="wifiFilter" class="filter-dropdown" onchange="filterWifi()">
              <option value="all">All Status</option>
              <option value="pending">Pending</option>
              <option value="unpaid">Unpaid</option>
              <option value="paid">Paid</option>
            </select>
          </div>
        </div>
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr><th>Name</th><th>Email</th><th>Seat</th><th>Time Left</th><th>Requested Hours</th><th>Fee</th><th>Payment Method</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody id="wifiBody"></tbody>
          </table>
        </div>
      </div>
    </div>
    
    <!-- ========== TAB 3: PLAN UPGRADE ========== -->
    <div id="tab-upgrade" class="tab-panel">
      <div class="card">
        <div class="section-header-with-filter">
          <div class="section-title"><i class="fa-regular fa-star"></i> Plan Upgrade Requests</div>
          <div class="filter-search-group">
            <input type="text" id="upgradeSearch" class="search-input" placeholder="Search..." onkeyup="filterUpgrade()">
            <select id="upgradeFilter" class="filter-dropdown" onchange="filterUpgrade()">
              <option value="all">All Status</option>
              <option value="pending">Pending</option>
              <option value="unpaid">Unpaid</option>
              <option value="paid">Paid</option>
            </select>
          </div>
        </div>
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr><th>Name</th><th>Email</th><th>Seat</th><th>Current Plan</th><th>Requested Plan</th><th>Fee</th><th>Payment Method</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody id="upgradeBody"></tbody>
          </table>
        </div>
      </div>
    </div>
    
    <!-- PAYMENT CONFIRMATION MODAL -->
    <div class="modal-overlay" id="paymentConfirmModal">
      <div class="modal">
        <div class="modal-header">
          <div class="modal-title"><i class="fa-solid fa-credit-card"></i> Process Customer Payment</div>
          <button class="modal-close" onclick="closeModal('paymentConfirmModal')">&times;</button>
        </div>
        <div class="modal-body" id="paymentConfirmBody"></div>
        <div class="modal-footer">
          <button class="btn-ghost" onclick="closeModal('paymentConfirmModal')">Cancel</button>
          <button class="btn-primary" id="confirmPaymentFinalBtn" onclick="finalizePaymentConfirmation()">Confirm Payment</button>
        </div>
      </div>
    </div>
    
    <!-- Walk-in Modal with RFID SCAN button -->
    <div class="modal-overlay" id="walkinModal">
      <div class="modal">
        <div class="modal-header">
          <div class="modal-title"><i class="fa-solid fa-user-plus"></i> Add New Walk-in Customer</div>
          <button class="modal-close" onclick="closeModal('walkinModal')">&times;</button>
        </div>
        <div class="modal-body">
          <div class="form-group"><label class="form-label">Email *</label><input class="form-control" id="wi-email" type="email" placeholder="customer@example.com"></div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">First Name *</label><input class="form-control" id="wi-firstname" type="text" placeholder="First name"></div>
            <div class="form-group"><label class="form-label">Last Name *</label><input class="form-control" id="wi-lastname" type="text" placeholder="Last name"></div>
          </div>
          <div class="form-group"><label class="form-label">Phone Number</label><input class="form-control" id="wi-phone" type="tel" placeholder="+63 912 3456 789"></div>
          <div class="form-group"><label class="form-label">Customer Type</label><select class="form-control" id="wi-type"><option value="member">Member</option><option value="premium">Premium</option><option value="walkin">Walk-in</option></select></div>
          <div class="form-group">
            <label class="form-label">RFID UID <span style="color:#dc2626; font-size:10px;">(required for Member/Premium)</span></label>
            <div class="rfid-input-group">
              <input class="form-control" id="wi-rfid" type="text" placeholder="eg, 4A3F2B1C">
              <button type="button" class="btn-scan" onclick="simulateRFIDScan()"><i class="fa-solid fa-qrcode"></i> Scan RFID</button>
            </div>
          </div>
          <div class="form-group"><label class="form-label">WiFi Session Hours</label><input class="form-control" id="wi-hours" type="number" step="0.5" min="0" value="2"></div>
          <div class="form-group"><label class="form-label">MAC Addresses (up to 3 devices)</label>
            <div id="macFieldsContainer" class="mac-fields-container"><div class="mac-input-group"><input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" style="display:none;"><i class="fa-solid fa-minus"></i></button></div></div>
            <button type="button" id="addMacBtn" class="add-mac-btn"><i class="fa-solid fa-plus"></i> Add another MAC address</button>
          </div>
          <div class="form-group"><label class="form-label">Status</label><select class="form-control" id="wi-status"><option value="active">Active</option><option value="inactive">Inactive</option></select></div>
          <div class="form-group"><label class="form-label">Assign Seat * (Click on seat below)</label>
            <div class="modal-seat-layout" id="modalSeatLayout"></div>
            <input type="hidden" id="selectedSeat" value="">
            <div style="font-size:0.7rem; color:#4f46e5; margin-top:4px;" id="selectedSeatDisplay">No seat selected</div>
            <div class="legend"><span><span style="background:#dcfce7; width:14px; height:14px; display:inline-block; border-radius:4px;"></span> Available</span><span><span style="background:#fee2e2; width:14px; height:14px; display:inline-block; border-radius:4px;"></span> Occupied</span><span><span style="background:#fef9c3; width:14px; height:14px; display:inline-block; border-radius:4px;"></span> Reserved</span></div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn-ghost" onclick="closeModal('walkinModal')">Cancel</button>
          <button class="btn-primary" onclick="addWalkin()"><i class="fa-solid fa-plus"></i> Add Customer</button>
        </div>
      </div>
    </div>
  </main>
</div>

<%- contentFor('script') %>
<script>
  const rows = ['A', 'B', 'C', 'D'];
  const seatsPerRow = 7;
  let occupiedSeats = ["A3", "B2", "C5", "A7", "A2", "D3", "C1", "B4", "D6"];
  let reservedSeats = ["A3", "B2", "C5", "D3", "D6"];
  
  let reservations = [
    { id: 1, name: "Monkey D. Luffy", email: "luffy@example.com", seat: "A3", hours: 2, date: "2026-04-16", time: "10:00 AM", amount: 200, status: "pending", paymentMethod: "cashier", reference: null, proofImage: null },
    { id: 2, name: "Roronoa Zoro", email: "zoro@example.com", seat: "B2", hours: 3, date: "2026-04-17", time: "09:00 AM", amount: 300, status: "paid", paymentMethod: "gcash", reference: "GCASH-12345678", proofImage: "screenshot_zoro_payment.png" },
    { id: 4, name: "Nami Catburglar", email: "nami@example.com", seat: "C5", hours: 2, date: "2026-04-18", time: "02:00 PM", amount: 200, status: "unpaid", paymentMethod: "cashier", reference: null, proofImage: null }
  ];

  let wifiRequests = [
    { id: 1, name: "Sanji Vinsmoke", email: "sanji@example.com", seat: "A1", timeLeft: "00:12:20", requested: 1, fee: 50, status: "pending", paymentMethod: "cashier" },
    { id: 2, name: "Brook Musician", email: "brook@example.com", seat: "A7", timeLeft: "00:25:30", requested: 2, fee: 100, status: "unpaid", paymentMethod: "cashier" }
  ];

  let upgradeRequests = [
    { id: 1, name: "Jinbe Knight", email: "jinbe@example.com", seat: "A2", currentPlan: "Member", requestedPlan: "Premium", fee: 1199, status: "pending", paymentMethod: "cashier" },
    { id: 2, name: "Robin Nico", email: "robin@example.com", seat: "D3", currentPlan: "Member", requestedPlan: "Premium", fee: 1199, status: "unpaid", paymentMethod: "cashier" }
  ];

  let selectedSeatForWalkin = null;
  let currentMacCount = 1;
  let currentPaymentItem = null;
  let currentPaymentType = null;
  let currentModalContext = null;

  function simulateRFIDScan() {
    const mockRFID = "RFID_" + Math.random().toString(36).substring(2, 10).toUpperCase();
    document.getElementById('wi-rfid').value = mockRFID;
    alert(`✅ RFID Scanned Successfully!\nUID: ${mockRFID}`);
  }

  function getSeatStatus(seatId) {
    if (occupiedSeats.includes(seatId)) return 'occupied';
    if (reservedSeats.includes(seatId)) return 'reserved';
    return 'available';
  }

  function updateMacFieldsUI() {
    const container = document.getElementById('macFieldsContainer');
    container.innerHTML = '<div class="mac-input-group"><input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" style="display:none;"><i class="fa-solid fa-minus"></i></button></div>';
    currentMacCount = 1;
    document.getElementById('addMacBtn').style.display = 'inline-flex';
  }

  function addNewMacField() {
    if (currentMacCount >= 3) { alert("Maximum 3 MAC addresses allowed."); return; }
    const container = document.getElementById('macFieldsContainer');
    const div = document.createElement('div');
    div.className = 'mac-input-group';
    div.innerHTML = `<input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" onclick="this.parentElement.remove(); currentMacCount--; document.getElementById('addMacBtn').style.display = 'inline-flex';"><i class="fa-solid fa-minus"></i></button>`;
    container.appendChild(div);
    currentMacCount++;
    if (currentMacCount >= 3) document.getElementById('addMacBtn').style.display = 'none';
  }

  function renderModalSeatLayout() {
    const container = document.getElementById('modalSeatLayout');
    let html = '<div class="modal-seat-grid">';
    for (let r of rows) {
      html += `<div class="modal-seat-row"><div class="modal-row-label">${r}</div><div class="modal-seats">`;
      for (let i = 1; i <= seatsPerRow; i++) {
        const seatId = `${r}${i}`;
        const status = getSeatStatus(seatId);
        const isSelected = (selectedSeatForWalkin === seatId);
        html += `<div class="modal-seat ${status} ${isSelected ? 'selected' : ''}" data-seat="${seatId}" data-status="${status}"><span>${seatId}</span><span>${status === 'available' ? 'Free' : (status === 'occupied' ? 'Occ' : 'Res')}</span></div>`;
      }
      html += `</div></div>`;
    }
    html += '</div>';
    container.innerHTML = html;
    
    document.querySelectorAll('#modalSeatLayout .modal-seat').forEach(seatEl => {
      if (seatEl.getAttribute('data-status') === 'available') {
        seatEl.onclick = () => {
          document.querySelectorAll('#modalSeatLayout .modal-seat').forEach(s => s.classList.remove('selected'));
          seatEl.classList.add('selected');
          selectedSeatForWalkin = seatEl.getAttribute('data-seat');
          document.getElementById('selectedSeat').value = selectedSeatForWalkin;
          document.getElementById('selectedSeatDisplay').innerHTML = `Selected seat: <strong>${selectedSeatForWalkin}</strong>`;
        };
      }
    });
  }

  function formatPHP(amount) { return '₱' + amount.toLocaleString(); }
  function escapeHtml(str) { if (!str) return ''; return String(str).replace(/[&<>]/g, m => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;' }[m] || m)); }
  
  function getStatusBadge(status) {
    if (status === 'pending') return '<span class="badge-pending">Pending</span>';
    if (status === 'unpaid') return '<span class="badge-unpaid">Unpaid</span>';
    return '<span class="badge-paid">Paid</span>';
  }
  
  function getPaymentMethodBadge(method) {
    return method === 'gcash' ? '<span class="badge-gcash">GCash</span>' : '<span class="badge-cashier">Cashier</span>';
  }

  function matchesSearch(item, term) { if(!term) return true; const t=term.toLowerCase(); return item.name.toLowerCase().includes(t) || item.email.toLowerCase().includes(t) || (item.seat && item.seat.toLowerCase().includes(t)); }

  // ============ RESERVATIONS ============
  function renderReservations() {
    const filter = document.getElementById('reservationFilter').value;
    const search = document.getElementById('reservationSearch').value;
    let filtered = reservations.filter(r => filter === 'all' || r.status === filter).filter(r => matchesSearch(r, search));
    const tbody = document.getElementById('reservationBody');
    if(filtered.length === 0) { tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:40px;">No reservations</td></tr>'; return; }
    
    tbody.innerHTML = filtered.map(r => {
      let actionButtons = '';
      if (r.status === 'pending') {
        if (r.paymentMethod === 'cashier') {
          actionButtons = `<button class="btn-icon btn-success" onclick="openCashierConfirmModal('reservation', ${r.id})" title="Confirm Reservation"><i class="fa-solid fa-check"></i></button>
                           <button class="btn-icon btn-danger" onclick="rejectItem('reservation', ${r.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
        } else if (r.paymentMethod === 'gcash') {
          actionButtons = `<button class="btn-icon btn-success" onclick="markGcashPaid('reservation', ${r.id})" title="Mark as Paid"><i class="fa-solid fa-check-circle"></i></button>
                           <button class="btn-icon btn-danger" onclick="rejectItem('reservation', ${r.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
        }
      } else if (r.status === 'unpaid') {
        actionButtons = `<button class="btn-icon btn-warning" onclick="openCashierPaymentModal('reservation', ${r.id})" title="Process Payment"><i class="fa-solid fa-credit-card"></i></button>`;
      } else {
        actionButtons = '<span style="color:#94a3b8;">—</span>';
      }
      return `<tr><td class="td-bold">${escapeHtml(r.name)}</td><td>${escapeHtml(r.email)}</td><td>${r.seat}</td><td>${r.hours} Hrs</td><td>${r.date}</td><td>${r.time}</td><td>${formatPHP(r.amount)}</td><td>${getPaymentMethodBadge(r.paymentMethod)}</td><td>${getStatusBadge(r.status)}</td><td class="action-group">${actionButtons}</td></tr>`;
    }).join('');
  }
  
  // ============ WIFI EXTENSIONS ============
  function renderWifi() {
    const filter = document.getElementById('wifiFilter').value;
    const search = document.getElementById('wifiSearch').value;
    let filtered = wifiRequests.filter(w => filter === 'all' || w.status === filter).filter(w => matchesSearch(w, search));
    const tbody = document.getElementById('wifiBody');
    if(filtered.length === 0) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:40px;">No WiFi extension requests</td></tr>'; return; }
    
    tbody.innerHTML = filtered.map(w => {
      let actionButtons = '';
      if (w.status === 'pending') {
        if (w.paymentMethod === 'cashier') {
          actionButtons = `<button class="btn-icon btn-success" onclick="openCashierConfirmModal('wifi', ${w.id})" title="Confirm Extension"><i class="fa-solid fa-check"></i></button>
                           <button class="btn-icon btn-danger" onclick="rejectItem('wifi', ${w.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
        } else if (w.paymentMethod === 'gcash') {
          actionButtons = `<button class="btn-icon btn-success" onclick="markGcashPaid('wifi', ${w.id})" title="Mark as Paid"><i class="fa-solid fa-check-circle"></i></button>
                           <button class="btn-icon btn-danger" onclick="rejectItem('wifi', ${w.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
        }
      } else if (w.status === 'unpaid') {
        actionButtons = `<button class="btn-icon btn-warning" onclick="openCashierPaymentModal('wifi', ${w.id})" title="Process Payment"><i class="fa-solid fa-credit-card"></i></button>`;
      } else {
        actionButtons = '<span style="color:#94a3b8;">—</span>';
      }
      return `<tr><td class="td-bold">${escapeHtml(w.name)}</td><td>${escapeHtml(w.email)}</td><td>${w.seat}</td><td>${w.timeLeft || '—'}</td><td>${w.requested} hr(s)</td><td>${formatPHP(w.fee)}</td><td>${getPaymentMethodBadge(w.paymentMethod)}</td><td>${getStatusBadge(w.status)}</td><td class="action-group">${actionButtons}</td></tr>`;
    }).join('');
  }
  
  // ============ PLAN UPGRADES ============
  function renderUpgrade() {
    const filter = document.getElementById('upgradeFilter').value;
    const search = document.getElementById('upgradeSearch').value;
    let filtered = upgradeRequests.filter(u => filter === 'all' || u.status === filter).filter(u => matchesSearch(u, search));
    const tbody = document.getElementById('upgradeBody');
    if(filtered.length === 0) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:40px;">No plan upgrade requests</td></tr>'; return; }
    
    tbody.innerHTML = filtered.map(u => {
      let actionButtons = '';
      if (u.status === 'pending') {
        if (u.paymentMethod === 'cashier') {
          actionButtons = `<button class="btn-icon btn-success" onclick="openCashierConfirmModal('upgrade', ${u.id})" title="Confirm Upgrade"><i class="fa-solid fa-check"></i></button>
                           <button class="btn-icon btn-danger" onclick="rejectItem('upgrade', ${u.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
        } else if (u.paymentMethod === 'gcash') {
          actionButtons = `<button class="btn-icon btn-success" onclick="markGcashPaid('upgrade', ${u.id})" title="Mark as Paid"><i class="fa-solid fa-check-circle"></i></button>
                           <button class="btn-icon btn-danger" onclick="rejectItem('upgrade', ${u.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
        }
      } else if (u.status === 'unpaid') {
        actionButtons = `<button class="btn-icon btn-warning" onclick="openCashierPaymentModal('upgrade', ${u.id})" title="Process Payment"><i class="fa-solid fa-credit-card"></i></button>`;
      } else {
        actionButtons = '<span style="color:#94a3b8;">—</span>';
      }
      return `<tr><td class="td-bold">${escapeHtml(u.name)}</td><td>${escapeHtml(u.email)}</td><td>${u.seat}</td><td>${u.currentPlan}</td><td>${u.requestedPlan}</td><td>${formatPHP(u.fee)}</td><td>${getPaymentMethodBadge(u.paymentMethod)}</td><td>${getStatusBadge(u.status)}</td><td class="action-group">${actionButtons}</td></tr>`;
    }).join('');
  }
  
  // ============ PAYMENT HANDLERS ============
  function markGcashPaid(type, id) {
    let item;
    if (type === 'reservation') item = reservations.find(r => r.id === id);
    else if (type === 'wifi') item = wifiRequests.find(w => w.id === id);
    else item = upgradeRequests.find(u => u.id === id);
    
    if (item && item.status === 'pending' && item.paymentMethod === 'gcash') {
      item.status = 'paid';
      renderReservations();
      renderWifi();
      renderUpgrade();
      alert(`✓ Payment confirmed for ${item.name}. Amount: ${formatPHP(item.fee || item.amount)}. Status updated to PAID.`);
    }
  }
  
  function openCashierConfirmModal(type, id) {
    let item, amount, detailText;
    if (type === 'reservation') { 
      item = reservations.find(r => r.id === id); 
      amount = item.amount; 
      detailText = `${item.hours} hour(s)`;
    } else if (type === 'wifi') { 
      item = wifiRequests.find(w => w.id === id); 
      amount = item.fee; 
      detailText = `${item.requested} hour(s) extension`;
    } else { 
      item = upgradeRequests.find(u => u.id === id); 
      amount = item.fee; 
      detailText = `${item.currentPlan} → ${item.requestedPlan}`;
    }
    
    if (!item) return;
    currentPaymentItem = item;
    currentPaymentType = type;
    currentModalContext = 'confirm';
    
    const confirmBtn = document.getElementById('confirmPaymentFinalBtn');
    confirmBtn.textContent = 'Confirm Reservation';
    
    document.getElementById('paymentConfirmBody').innerHTML = `
      <div class="payment-info-card">
        <div class="method-header"><i class="fa-solid fa-cash-register cashier-icon"></i><h3 style="margin:0;">Cashier Payment</h3></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Customer:</span><span>${escapeHtml(item.name)}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Email:</span><span>${escapeHtml(item.email)}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Seat:</span><span>${item.seat}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Details:</span><span>${detailText}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Amount to Pay:</span><span class="payment-amount-large" style="margin:0;">${formatPHP(amount)}</span></div>
        <div style="background:#fef3c7; padding:12px; border-radius:12px;"><i class="fa-solid fa-info-circle"></i> Customer selected Cashier payment.<br>Customer will pay at the counter.<br><strong>Click "Confirm Reservation" - Status will remain UNPAID until cashier collects payment.</strong></div>
      </div>
    `;
    openModal('paymentConfirmModal');
  }
  
  function openCashierPaymentModal(type, id) {
    let item, amount, detailText;
    if (type === 'reservation') { 
      item = reservations.find(r => r.id === id); 
      amount = item.amount; 
      detailText = `${item.hours} hour(s)`;
    } else if (type === 'wifi') { 
      item = wifiRequests.find(w => w.id === id); 
      amount = item.fee; 
      detailText = `${item.requested} hour(s) extension`;
    } else { 
      item = upgradeRequests.find(u => u.id === id); 
      amount = item.fee; 
      detailText = `${item.currentPlan} → ${item.requestedPlan}`;
    }
    
    if (!item) return;
    currentPaymentItem = item;
    currentPaymentType = type;
    currentModalContext = 'payment';
    
    const confirmBtn = document.getElementById('confirmPaymentFinalBtn');
    confirmBtn.textContent = 'Confirm Payment';
    
    document.getElementById('paymentConfirmBody').innerHTML = `
      <div class="payment-info-card">
        <div class="method-header"><i class="fa-solid fa-cash-register cashier-icon"></i><h3 style="margin:0;">Cashier Payment</h3></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Customer:</span><span>${escapeHtml(item.name)}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Email:</span><span>${escapeHtml(item.email)}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Seat:</span><span>${item.seat}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Details:</span><span>${detailText}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Amount to Pay:</span><span class="payment-amount-large" style="margin:0;">${formatPHP(amount)}</span></div>
        <div style="background:#fef3c7; padding:12px; border-radius:12px;"><i class="fa-solid fa-info-circle"></i> Customer selected Cashier payment.<br>Customer will pay at the counter.<br><strong>Click "Confirm Payment" to mark as PAID.</strong></div>
      </div>
    `;
    openModal('paymentConfirmModal');
  }
  
  function finalizePaymentConfirmation() {
    if (!currentPaymentItem) { closeModal('paymentConfirmModal'); return; }
    
    if (currentModalContext === 'confirm') {
      if (currentPaymentItem.status === 'pending') {
        currentPaymentItem.status = 'unpaid';
        renderReservations();
        renderWifi();
        renderUpgrade();
        closeModal('paymentConfirmModal');
        alert(`💰 ${currentPaymentType} confirmed for ${currentPaymentItem.name}.\nAmount: ${formatPHP(currentPaymentItem.fee || currentPaymentItem.amount)}\nStatus: UNPAID - Customer will pay at the counter.`);
      }
    } else if (currentModalContext === 'payment') {
      if (currentPaymentItem.status === 'unpaid') {
        currentPaymentItem.status = 'paid';
        renderReservations();
        renderWifi();
        renderUpgrade();
        closeModal('paymentConfirmModal');
        alert(`✓ Payment confirmed for ${currentPaymentItem.name}.\nAmount: ${formatPHP(currentPaymentItem.fee || currentPaymentItem.amount)}\nStatus updated to PAID.`);
      }
    }
    
    currentPaymentItem = null;
    currentPaymentType = null;
    currentModalContext = null;
  }
  
  function rejectItem(type, id) {
    let item, name;
    if (type === 'reservation') { item = reservations.find(r => r.id === id); name = item?.name; }
    else if (type === 'wifi') { item = wifiRequests.find(w => w.id === id); name = item?.name; }
    else { item = upgradeRequests.find(u => u.id === id); name = item?.name; }
    
    if (item && confirm(`Reject ${type} for ${name}?`)) {
      if (type === 'reservation') reservations = reservations.filter(r => r.id !== id);
      else if (type === 'wifi') wifiRequests = wifiRequests.filter(w => w.id !== id);
      else upgradeRequests = upgradeRequests.filter(u => u.id !== id);
      renderReservations();
      renderWifi();
      renderUpgrade();
      alert(`✗ ${type} for ${name} rejected`);
    }
  }
  
  function filterReservations() { renderReservations(); }
  function filterWifi() { renderWifi(); }
  function filterUpgrade() { renderUpgrade(); }

  function addWalkin() {
    const email = document.getElementById('wi-email').value.trim();
    const firstName = document.getElementById('wi-firstname').value.trim();
    const lastName = document.getElementById('wi-lastname').value.trim();
    const seat = selectedSeatForWalkin;
    if (!firstName || !lastName || !email || !seat) { alert("Please fill required fields."); return; }
    if (!email.includes('@')) { alert("Valid email required."); return; }
    if (getSeatStatus(seat) !== 'available') { alert(`Seat ${seat} unavailable.`); renderModalSeatLayout(); return; }
    
    const wifiHours = parseFloat(document.getElementById('wi-hours').value) || 2;
    const now = new Date();
    const fullName = `${firstName} ${lastName}`;
    const method = prompt("Payment Method:\n1 - GCash (pay online - AUTO PAID)\n2 - Cashier (pay at counter)", "1");
    let paymentMethod, status;
    if (method === "1") { 
      paymentMethod = "gcash"; 
      status = "paid";
    } else { 
      paymentMethod = "cashier"; 
      status = "pending";
    }
    
    reservations.push({
      id: Date.now(), name: fullName, email: email, seat: seat, hours: wifiHours,
      date: now.toLocaleDateString(), time: now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      amount: wifiHours * 100, status: status, paymentMethod: paymentMethod, 
      reference: paymentMethod === 'gcash' ? "GCASH-" + Math.floor(Math.random()*100000000).toString().padStart(8,'0') : null, 
      proofImage: null
    });
    occupiedSeats.push(seat);
    renderReservations();
    
    document.getElementById('wi-email').value = ''; document.getElementById('wi-firstname').value = '';
    document.getElementById('wi-lastname').value = ''; document.getElementById('wi-phone').value = '';
    document.getElementById('wi-rfid').value = ''; document.getElementById('wi-hours').value = '2';
    selectedSeatForWalkin = null; document.getElementById('selectedSeatDisplay').innerHTML = "No seat selected";
    updateMacFieldsUI();
    closeModal('walkinModal');
    if (paymentMethod === 'gcash') {
      alert(`✓ ${fullName} added to seat ${seat}\nPayment: GCash - AUTO PAID\nAmount: ${formatPHP(wifiHours * 100)}`);
    } else {
      alert(`✓ ${fullName} added to seat ${seat}\nPayment: Cashier (Pending - needs confirmation)\nAmount: ${formatPHP(wifiHours * 100)}`);
    }
  }

  function confirmLogout() { if (confirm('Logout?')) alert('Logged out'); }
  function openSidebar() { document.getElementById('sidebar').classList.add('mobile-open'); document.getElementById('mobileOverlay').classList.add('show'); }
  function closeSidebar() { document.getElementById('sidebar').classList.remove('mobile-open'); document.getElementById('mobileOverlay').classList.remove('show'); }
  function openModal(id) { document.getElementById(id).classList.add('open'); if(id === 'walkinModal') { renderModalSeatLayout(); updateMacFieldsUI(); selectedSeatForWalkin = null; document.getElementById('selectedSeatDisplay').innerHTML = "No seat selected"; document.getElementById('wi-rfid').value = ''; } }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }
  function switchTab(event, tabId) { document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active')); document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active')); document.getElementById(tabId).classList.add('active'); event.currentTarget.classList.add('active'); }

  renderReservations();
  renderWifi();
  renderUpgrade();
  document.getElementById('addMacBtn').addEventListener('click', addNewMacField);
</script>
