<!-- Title passed to layout -->
<% locals.title='The Last Muster | Admin Dashboard' %>

  <%- contentFor('style') %>
    <style>
      .welcome-banner {
        background: linear-gradient(135deg, #f97316, #ea580c);
        color: white;
        padding: 20px 24px;
        border-radius: 12px;
        margin-bottom: 24px;
      }

      .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
      }

      .stat-card {
        border-radius: var(--radius);
        padding: 18px 20px;
        color: #fff;
        position: relative;
        overflow: hidden;
      }

      .stat-card::after {
        content: '';
        position: absolute;
        top: -16px;
        right: -16px;
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
      }

      .stat-icon {
        font-size: 1.3rem;
        opacity: 0.9;
        margin-bottom: 8px;
      }

      .stat-lbl {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        opacity: 0.85;
        margin-bottom: 6px;
      }

      .stat-val {
        font-family: 'Poppins', sans-serif;
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1;
      }

      /* Stat card backgrounds */
      .sc-gold {
        background: linear-gradient(135deg, #8A8636, #b0ac4a);
      }

      .sc-orange {
        background: linear-gradient(135deg, #CF6322, #e0793a);
      }

      .sc-teal {
        background: linear-gradient(135deg, #2a6b5e, #3a8a7a);
      }

      .sc-green {
        background: linear-gradient(135deg, #3d7a52, #5a9e6f);
      }

      .charts-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 24px;
      }

      .chart-card {
        background: white;
        border-radius: var(--radius);
        padding: 18px;
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
      }

      .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
      }

      .chart-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
      }

      .chart-select {
        font-size: 11px;
        font-weight: 600;
        padding: 4px 8px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--white);
        color: var(--text-sm);
        cursor: pointer;
        outline: none;
      }

      .chart-select:focus {
        border-color: var(--orange);
      }

      .chart-box {
        height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .dash-bottom {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 16px;
        margin-bottom: 24px;
      }

      .payments-section {
        margin-top: 8px;
      }

      .payments-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
      }

      .payment-card {
        background: white;
        border-radius: var(--radius);
        padding: 16px;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
      }

      /* Dynamic Seat Map Styles */
      .seat-map-container {
        width: 100%;
        height: 380px;
        background: #f8fafc;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
        border: 1px solid var(--border);
      }

      #dynamicSeatMap {
        position: absolute;
        width: 800px;
        height: 450px;
        transform-origin: 0 0;
        cursor: pointer;
        transition: transform 0.3s ease;
      }

      #dynamicSeatMap:hover {
        opacity: 0.9;
      }

      .fp-item {
        position: absolute;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .item-visual {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, background-color 0.3s ease;
      }

      .chair-icon {
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
      }

      .item-label {
        position: absolute;
        top: calc(100% + 2px);
        left: 50%;
        transform: translateX(-50%);
        font-size: 8px;
        font-weight: 700;
        color: #475569;
        white-space: nowrap;
      }

      .item-label.center {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 9px;
      }

      .payment-card .section-title {
        margin-bottom: 12px;
        font-size: 13px;
      }

      .payment-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-height: 280px;
        overflow-y: auto;
      }

      .payment-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 2px solid #CF6322;
      }

      .payment-item:last-child {
        border-bottom: none;
      }

      .payment-info {
        flex: 1;
      }

      .payment-name {
        font-weight: 700;
        font-size: 12px;
        margin-bottom: 2px;
      }

      .payment-detail {
        font-size: 10px;
        color: var(--text-sm);
      }

      .payment-amount {
        font-weight: 800;
        font-size: 13px;
        color: var(--orange);
        margin-right: 12px;
      }

      .pay-btn {
        background: var(--green);
        color: white;
        border: none;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 10px;
        font-weight: 600;
        cursor: pointer;
      }

      .pay-btn:hover {
        background: #2d5c3d;
      }

      .feed-list {
        display: flex;
        flex-direction: column;
        gap: 7px;
        max-height: 260px;
        overflow-y: auto;
      }

      .feed-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        background: var(--cream-lt);
        border-radius: 8px;
      }

      .feed-seat {
        font-size: 10px;
        font-weight: 700;
        color: #fff;
        border-radius: 4px;
        padding: 2px 7px;
        white-space: nowrap;
      }

      .feed-seat.in {
        background: var(--green);
      }

      .feed-seat.out {
        background: #e53e3e;
      }

      .feed-text {
        font-size: 11px;
        color: var(--text-md);
        flex: 1;
      }

      .feed-time {
        font-size: 10px;
        color: var(--text-sm);
      }

      @media(max-width:900px) {
        .stat-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .dash-bottom {
          grid-template-columns: 1fr;
        }

        .payments-grid {
          grid-template-columns: 1fr;
        }

        .charts-row {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <div class="app">
      <!-- Sidebar -->
      <%- include('../partials/admin_sidebar', { active: 'Dashboard' }) %>

        <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>

        <main class="content">
          <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>

          <!-- Welcome Banner -->
          <div class="welcome-banner">
            <h2>Welcome back, <strong>Admin</strong> 👋</h2>
            <p>Manage daily operations, monitor seat status, and assist customers</p>
          </div>

          <!-- Stats with backgrounds -->
          <div class="stat-grid">
            <div class="stat-card sc-gold">
              <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
              <div class="stat-lbl">TOTAL ACTIVE USERS</div>
              <div class="stat-val">3</div>
            </div>
            <div class="stat-card sc-orange">
              <div class="stat-icon"><i class="fa-solid fa-user"></i></div>
              <div class="stat-lbl">TOTAL CUSTOMERS</div>
              <div class="stat-val">100</div>
            </div>
            <div class="stat-card sc-teal">
              <div class="stat-icon"><i class="fa-solid fa-wifi"></i></div>
              <div class="stat-lbl">ACTIVE WI-FI SESSION</div>
              <div class="stat-val">100</div>
            </div>
            <div class="stat-card sc-green">
              <div class="stat-icon"><i class="fa-solid fa-couch"></i></div>
              <div class="stat-lbl">SEAT AVAILABLE</div>
              <div class="stat-val" id="statAvailable">0/0</div>
            </div>
          </div>

          <!-- Charts Row 1 -->
          <div class="charts-row">
            <div class="chart-card">
              <div class="chart-header">
                <div class="chart-title">Today's Traffic</div>
                <select class="chart-select" onchange="filterTraffic(this.value)">
                  <option value="today">Today</option>
                  <option value="yesterday">Yesterday</option>
                  <option value="week">This Week</option>
                </select>
              </div>
              <div class="chart-box" style="display:block;"><canvas id="trafficChart"></canvas></div>
            </div>
            <div class="chart-card">
              <div class="chart-header">
                <div class="chart-title">Seat Status Distribution</div>
                <select class="chart-select" onchange="filterSeatStatus(this.value)">
                  <option value="all">All Areas</option>
                  <option value="ground">Ground Floor</option>
                  <option value="mezzanine">Mezzanine</option>
                </select>
              </div>
              <div class="chart-box"><canvas id="seatChart" style="max-width:210px; max-height:210px;"></canvas></div>
            </div>
          </div>

          <!-- Charts Row 2 -->
          <div class="charts-row">
            <div class="chart-card">
              <div class="chart-header">
                <div class="chart-title">Weekly Booking Trend</div>
                <select class="chart-select" onchange="filterWeekly(this.value)">
                  <option value="7">Last 7 Days</option>
                  <option value="14">Last 14 Days</option>
                  <option value="30">This Month</option>
                </select>
              </div>
              <div class="chart-box" style="display:block;"><canvas id="weeklyChart"></canvas></div>
            </div>
            <div class="chart-card">
              <div class="chart-header">
                <div class="chart-title">Customer Type Distribution</div>
                <select class="chart-select" onchange="filterCustomer(this.value)">
                  <option value="all">All Time</option>
                  <option value="month">This Month</option>
                  <option value="week">This Week</option>
                </select>
              </div>
              <div class="chart-box"><canvas id="customerTypeChart" style="max-width:210px; max-height:210px;"></canvas>
              </div>
            </div>
          </div>

          <!-- Seat Map + Activity -->
          <div class="dash-bottom">
            <div class="card">
              <div class="chart-header">
                <div class="section-title" style="margin-bottom:0">Live Seat Status</div>
                <button class="chart-select" onclick="renderLiveSeatMap()" title="Sync with Seat Management">
                  <i class="fa-solid fa-rotate"></i> Sync
                </button>
              </div>
              <div class="map-legend" style="margin: 0 0 12px 0">
                <div class="legend-dot"><span style="background:#10b981"></span>Available</div>
                <div class="legend-dot"><span style="background:#d65c29"></span>Taken</div>
                <div class="legend-dot"><span style="background:#1e293b"></span>Reserved</div>
                <div class="legend-dot"><span style="background:#facc15"></span>Idle</div>
              </div>
              <div class="seat-map-container" id="seatMapViewport">
                <div id="dynamicSeatMap"></div>
              </div>
            </div>
            <div class="card">
              <div class="section-title">Recent Activity</div>
              <div class="feed-list" id="activityFeed"></div>
            </div>
          </div>

          <!-- Pending Payments -->
          <div class="payments-section">
            <div class="section-title" style="margin-bottom:16px;"><i class="fa-solid fa-credit-card"></i> Pending
              Payments
            </div>
            <div class="payments-grid">
              <div class="payment-card">
                <div class="section-title"><i class="fa-solid fa-calendar-check"></i> Reservations</div>
                <div class="payment-list" id="reservationPaymentsList"></div>
              </div>
              <div class="payment-card">
                <div class="section-title"><i class="fa-solid fa-wifi"></i> WiFi Extensions</div>
                <div class="payment-list" id="wifiPaymentsList"></div>
              </div>
              <div class="payment-card">
                <div class="section-title"><i class="fa-solid fa-star"></i> Plan Upgrades</div>
                <div class="payment-list" id="upgradePaymentsList"></div>
              </div>
            </div>
          </div>
        </main>
    </div>

    <%- contentFor('script') %>
      <script>
        // Sidebar functions
        function confirmLogout() { if (confirm('Are you sure you want to logout?')) location.reload(); }
        function openSidebar() { document.getElementById('sidebar').classList.add('mobile-open'); document.getElementById('mobileOverlay').classList.add('show'); }
        function closeSidebar() { document.getElementById('sidebar').classList.remove('mobile-open'); document.getElementById('mobileOverlay').classList.remove('show'); }

        // Pending Payments Data
        let pendingReservations = [
          { id: 1, name: "Monkey D. Luffy", seat: "A3", date: "2026-04-16", time: "10:00 AM", amount: 250, paid: false },
          { id: 2, name: "Roronoa Zoro", seat: "B2", date: "2026-04-17", time: "09:00 AM", amount: 300, paid: false }
        ];

        let pendingWifiExtensions = [
          { id: 1, name: "Sanji Vinsmoke", seat: "A1", hours: 1, amount: 50, paid: false },
          { id: 2, name: "Brook Musician", seat: "A7", hours: 2, amount: 100, paid: false }
        ];

        let pendingUpgrades = [
          { id: 1, name: "Jinbe Knight", seat: "A2", fromPlan: "Member", toPlan: "Premium", amount: 1199, paid: false },
          { id: 2, name: "Nami Catburglar", seat: "C5", fromPlan: "Member", toPlan: "Premium", amount: 1199, paid: false }
        ];

        function formatPHP(amount) { return '₱' + amount.toLocaleString(); }
        function escapeHtml(str) { return String(str).replace(/[&<>]/g, function (m) { if (m === '&') return '&amp;'; if (m === '<') return '&lt;'; if (m === '>') return '&gt;'; return m; }); }

        // Render Reservation Payments
        function renderReservationPayments() {
          const container = document.getElementById('reservationPaymentsList');
          const unpaid = pendingReservations.filter(item => !item.paid);
          if (unpaid.length === 0) { container.innerHTML = '<div class="empty-payments">No pending payments</div>'; return; }
          container.innerHTML = unpaid.map(item => `<div class="payment-item"><div class="payment-info"><div class="payment-name">${escapeHtml(item.name)}</div><div class="payment-detail">Seat ${item.seat} • ${item.date}</div></div><div class="payment-amount">${formatPHP(item.amount)}</div><button class="pay-btn" onclick="markPaymentPaid('reservation', ${item.id})">Pay Now</button></div>`).join('');
        }

        function renderWifiPayments() {
          const container = document.getElementById('wifiPaymentsList');
          const unpaid = pendingWifiExtensions.filter(item => !item.paid);
          if (unpaid.length === 0) { container.innerHTML = '<div class="empty-payments">No pending payments</div>'; return; }
          container.innerHTML = unpaid.map(item => `<div class="payment-item"><div class="payment-info"><div class="payment-name">${escapeHtml(item.name)}</div><div class="payment-detail">Seat ${item.seat} • +${item.hours} hr(s)</div></div><div class="payment-amount">${formatPHP(item.amount)}</div><button class="pay-btn" onclick="markPaymentPaid('wifi', ${item.id})">Pay Now</button></div>`).join('');
        }

        function renderUpgradePayments() {
          const container = document.getElementById('upgradePaymentsList');
          const unpaid = pendingUpgrades.filter(item => !item.paid);
          if (unpaid.length === 0) { container.innerHTML = '<div class="empty-payments">No pending payments</div>'; return; }
          container.innerHTML = unpaid.map(item => `<div class="payment-item"><div class="payment-info"><div class="payment-name">${escapeHtml(item.name)}</div><div class="payment-detail">Seat ${item.seat} • ${item.fromPlan} → ${item.toPlan}</div></div><div class="payment-amount">${formatPHP(item.amount)}</div><button class="pay-btn" onclick="markPaymentPaid('upgrade', ${item.id})">Pay Now</button></div>`).join('');
        }

        window.markPaymentPaid = function (type, id) {
          if (type === 'reservation') { let item = pendingReservations.find(i => i.id === id); if (item) item.paid = true; renderReservationPayments(); }
          else if (type === 'wifi') { let item = pendingWifiExtensions.find(i => i.id === id); if (item) item.paid = true; renderWifiPayments(); }
          else if (type === 'upgrade') { let item = pendingUpgrades.find(i => i.id === id); if (item) item.paid = true; renderUpgradePayments(); }
          alert('Payment marked as paid!');
        };

        // Render Activity Feed
        function renderActivityFeed() {
          const activityFeed = [
            { seat: "C1-S1", action: "occupied", time: "2m", type: "in" }, { seat: "C2-S1", action: "vacated", time: "5m", type: "out" },
            { seat: "T3-S2", action: "occupied", time: "8m", type: "in" }, { seat: "RT1-S3", action: "vacated", time: "11m", type: "out" },
            { seat: "C3-S1", action: "occupied", time: "14m", type: "in" }, { seat: "C3-S2", action: "occupied", time: "14m", type: "in" }
          ];
          document.getElementById('activityFeed').innerHTML = activityFeed.map(a => `<div class="feed-item"><span class="feed-seat ${a.type}">${a.seat}</span><span class="feed-text">Seat ${a.action}</span><span class="feed-time">${a.time}</span></div>`).join('');
        }

        // Chart data & instances
        const trafficLabels = ['8am', '9am', '10am', '11am', '12pm', '1pm', '2pm', '3pm', '4pm', '5pm', '6pm', '7pm'];
        const trafficData = [12, 24, 38, 52, 68, 84, 72, 58, 42, 28, 18, 10];
        let trafficChart, seatChart;


        function renderTrafficChart() {
          const ctx = document.getElementById('trafficChart').getContext('2d');
          if (trafficChart) trafficChart.destroy();
          trafficChart = new Chart(ctx, {
            type: 'line',
            data: { labels: trafficLabels, datasets: [{ label: 'Customers', data: trafficData, borderColor: '#CF6322', backgroundColor: 'rgba(207,99,34,.1)', borderWidth: 2.5, fill: true, tension: 0.3, pointBackgroundColor: '#CF6322', pointRadius: 4 }] },
            options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => `${ctx.raw} customers` } } }, scales: { y: { beginAtZero: true } } }
          });
        }

        function renderSeatChart() {
          const ctx = document.getElementById('seatChart').getContext('2d');
          if (seatChart) seatChart.destroy();
          seatChart = new Chart(ctx, {
            type: 'doughnut',
            data: { labels: ['Active', 'Idle', 'Inactive', 'Reserved'], datasets: [{ data: [15, 8, 7, 5], backgroundColor: ['#3d7a52', '#CF6322', '#e53e3e', '#8A8636'], borderWidth: 0 }] },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              plugins: {
                legend: { position: 'bottom', labels: { font: { size: 10 } } },
                tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${ctx.raw} seats` } }
              },
              cutout: '60%'
            }
          });
        }

        let weeklyChart, customerTypeChart;
        function renderNewCharts() {
          // Weekly Booking Trend (Bar)
          const ctxW = document.getElementById('weeklyChart').getContext('2d');
          if (weeklyChart) weeklyChart.destroy();
          weeklyChart = new Chart(ctxW, {
            type: 'bar',
            data: {
              labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
              datasets: [{
                label: 'Total Bookings',
                data: [65, 45, 75, 85, 95, 120, 110],
                backgroundColor: '#3a8a7a',
                borderRadius: 6,
                barThickness: 20
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              plugins: { legend: { display: false } },
              scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } }, x: { grid: { display: false } } }
            }
          });

          // Customer Type Distribution (Pie)
          const ctxC = document.getElementById('customerTypeChart').getContext('2d');
          if (customerTypeChart) customerTypeChart.destroy();
          customerTypeChart = new Chart(ctxC, {
            type: 'pie',
            data: {
              labels: ['New Customers', 'Returning Members'],
              datasets: [{
                data: [35, 65],
                backgroundColor: ['#f97316', '#2a6b5e'],
                borderWidth: 0
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              plugins: {
                legend: { position: 'bottom', labels: { font: { size: 10 } } }
              }
            }
          });
        }

        // Filter Handlers
        function filterTraffic(val) {
          if (val === 'yesterday') {
            trafficChart.data.datasets[0].data = [8, 15, 25, 45, 60, 75, 65, 50, 40, 25, 15, 5];
          } else if (val === 'week') {
            trafficChart.data.datasets[0].data = [40, 45, 55, 65, 75, 80, 85, 90, 80, 70, 60, 50];
          } else {
            trafficChart.data.datasets[0].data = trafficData;
          }
          trafficChart.update();
        }

        function filterSeatStatus(val) {
          if (val === 'ground') {
            seatChart.data.datasets[0].data = [10, 5, 5, 2];
          } else if (val === 'mezzanine') {
            seatChart.data.datasets[0].data = [5, 3, 2, 3];
          } else {
            seatChart.data.datasets[0].data = [15, 8, 7, 5];
          }
          seatChart.update();
        }

        function filterWeekly(val) {
          if (val === '14') {
            weeklyChart.data.labels = ['W1', 'W2'];
            weeklyChart.data.datasets[0].data = [450, 520];
            weeklyChart.data.datasets[0].barThickness = 40;
          } else if (val === '30') {
            weeklyChart.data.labels = ['Week 1', 'Week 2', 'Week 3', 'Week 4'];
            weeklyChart.data.datasets[0].data = [400, 480, 550, 600];
            weeklyChart.data.datasets[0].barThickness = 30;
          } else {
            weeklyChart.data.labels = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            weeklyChart.data.datasets[0].data = [65, 45, 75, 85, 95, 120, 110];
            weeklyChart.data.datasets[0].barThickness = 20;
          }
          weeklyChart.update();
        }

        function filterCustomer(val) {
          if (val === 'month') {
            customerTypeChart.data.datasets[0].data = [20, 80];
          } else if (val === 'week') {
            customerTypeChart.data.datasets[0].data = [45, 55];
          } else {
            customerTypeChart.data.datasets[0].data = [35, 65];
          }
          customerTypeChart.update();
        }

        // Dynamic Seat Map Rendering
        async function renderLiveSeatMap() {
          const container = document.getElementById('dynamicSeatMap');
          const viewport = document.getElementById('seatMapViewport');
          if (!container) return;

          container.innerHTML = '<div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-weight:600;">Loading live map...</div>';

          try {
            const res = await fetch('/api/layout');
            const data = await res.json();
            let items = data.items || [];
            
            container.innerHTML = '';

            if (items.length === 0) {
              container.innerHTML = '<div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-weight:600;">No layout found.</div>';
              return;
            }

            // Update stat counter
            const chairs = items.filter(i => (i.type === 'chair' || i.type === 'chair-sq'));
            const openChairs = chairs.filter(i => !i.statuses || i.statuses[0] === 'open');
            document.getElementById('statAvailable').textContent = `${openChairs.length}/${chairs.length}`;

            // Add click listener to navigate to management
            container.onclick = () => {
              window.location.href = '/admin/seat-management';
            };

            items.forEach(item => {
              const el = document.createElement('div');
              el.className = 'fp-item';
              el.style.left = item.x + 'px';
              el.style.top = item.y + 'px';
              el.style.width = item.w + 'px';
              el.style.height = item.h + 'px';
              el.style.zIndex = (item.type === 'chair' || item.type === 'chair-sq') ? 5 : item.type.startsWith('block') ? 2 : 3;

              const visual = document.createElement('div');
              visual.className = 'item-visual';
              visual.style.transform = 'rotate(' + (item.rot || 0) + 'deg)';

              if (item.type === 'chair') {
                visual.classList.add('chair-icon');
                visual.style.webkitMaskImage = 'url(/images/chair.png)';
                visual.style.maskImage = 'url(/images/chair.png)';
                const status = (item.statuses && item.statuses[0]) || 'open';
                
                if (status === 'taken') {
                  visual.style.backgroundColor = '#d65c29'; // Orange
                } else if (status === 'reserved') {
                  visual.style.backgroundColor = '#1e293b'; // Dark
                } else if (status === 'idle') {
                  visual.style.backgroundColor = '#facc15'; // Yellow
                } else {
                  visual.style.backgroundColor = '#10b981'; // Green
                }
              } else if (item.type === 'chair-sq') {
                const status = (item.statuses && item.statuses[0]) || 'open';
                const sqColor = status === 'taken' ? '#d65c29' : status === 'reserved' ? '#1e293b' : status === 'idle' ? '#facc15' : '#10b981';
                visual.style.background = sqColor;
                visual.style.borderRadius = '4px';
              } else if (item.type === 'round-table' || item.type === 'rect-table') {
                visual.style.background = item.color || '#fdba74';
                visual.style.border = '1.5px solid #f97316';
                visual.style.borderRadius = item.type === 'round-table' ? '50%' : '6px';
              } else if (item.type === 'room') {
                const status = (item.statuses && item.statuses[0]) || 'open';
                const roomColor = status === 'taken' ? '#d65c29' : status === 'reserved' ? '#1e293b' : item.color;
                visual.style.background = roomColor;
                visual.style.border = '2px solid #16a34a';
                visual.style.borderRadius = '8px';
              } else {
                visual.style.background = item.color || '#cbd5e1';
                visual.style.borderRadius = '4px';
              }
              el.appendChild(visual);

              if (item.label || item.type === 'room') {
                const lbl = document.createElement('span');
                lbl.className = 'item-label';
                if (item.type !== 'chair' && item.type !== 'chair-sq') {
                  lbl.classList.add('center');
                  const status = (item.statuses && item.statuses[0]) || 'open';
                  const isDark = (item.color === '#22c55e' || status === 'taken' || status === 'reserved');
                  lbl.style.color = isDark ? '#fff' : '#1e293b';
                }
                lbl.textContent = item.label || (item.type === 'room' ? 'Room' : '');
                el.appendChild(lbl);
              }
              container.appendChild(el);
            });

            // Auto-scale to fit dashboard card
            const rect = viewport.getBoundingClientRect();
            const vWidth = rect.width || viewport.clientWidth || viewport.offsetWidth || 600;
            const vHeight = rect.height || viewport.clientHeight || viewport.offsetHeight || 380;

            const scale = Math.min(vWidth / 800, vHeight / 450) * 0.95;
            container.style.transform = `scale(${scale})`;
            container.style.left = `${(vWidth - (800 * scale)) / 2}px`;
            container.style.top = `${(vHeight - (450 * scale)) / 2}px`;
          } catch (e) {
            console.error(e);
            container.innerHTML = '<div style="color:red; padding:20px;">Error loading live status.</div>';
          }
        }

        // Handle Resize
        window.addEventListener('resize', renderLiveSeatMap);

        // Initialize All
        function renderAll() {
          // Chart.js defaults — set here so Chart.js is guaranteed loaded
          Chart.defaults.font.family = "'Montserrat', sans-serif";
          Chart.defaults.color = "#1E2A38";
          Chart.defaults.plugins.tooltip.titleFont = { family: "'Poppins', sans-serif", weight: '700' };
          Chart.defaults.plugins.tooltip.bodyFont = { family: "'Montserrat', sans-serif" };

          renderReservationPayments();
          renderWifiPayments();
          renderUpgradePayments();
          renderActivityFeed();
          renderTrafficChart();
          renderSeatChart();
          renderNewCharts();
          // Delay slightly to ensure viewport dimensions are ready
          setTimeout(renderLiveSeatMap, 100);
        }

        document.addEventListener('DOMContentLoaded', renderAll);
      </script>