            const res = await fetch('/api/layout');
            const data = await res.json();
            const select = document.getElementById('seatSelect');
            if (data && data.items) {
                const chairs = data.items.filter(i => (i.type === 'chair' || i.type === 'chair-sq') && i.statuses[0] === 'open');
                select.innerHTML = chairs.map(c => `<option value="${c.label}">${c.label}</option>`).join('');
