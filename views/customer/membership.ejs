<!-- Title passed to layout -->
<% locals.title = 'The Last Muster • Membership' %>

<%- contentFor('style') %>
<style>

        /* Membership Page Specific Styles */
        .page-title {
            font-family: 'Poppins', sans-serif;
            font-size: 2.5rem;
            color: var(--orange, #d65c29);
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
        }

        .page-subtitle {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.3rem;
            color: #64748b;
            margin-bottom: 32px;
        }

        .plans-container {
            display: flex;
            flex-wrap: wrap;
            gap: 24px;
            justify-content: flex-start;
        }

        .plans-row-2 {
            display: flex;
            gap: 24px;
            justify-content: center;
            margin-top: 24px;
        }

        .plan-card {
            background: #fffafa;
            /* very slight warm tint */
            border-radius: 12px;
            padding: 32px;
            width: 320px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            display: flex;
            flex-direction: column;
            border: 1px solid #e2e8f0;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            font-family: 'Montserrat', sans-serif;
        }

        .plan-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        .plan-card.premium {
            border: 2px solid var(--orange, #d65c29);
            background: #fff;
        }

        .plan-title {
            font-family: 'Poppins', sans-serif;
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .plan-title.starter {
            color: #64748b;
        }

        .plan-title.regular {
            color: #f59e0b;
        }

        .plan-title.pro {
            color: #f43f5e;
        }

        .plan-title.executive {
            color: #ef4444;
        }

        .plan-title.premium {
            color: var(--orange, #d65c29);
        }

        .plan-price {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--orange, #d65c29);
            font-family: 'Poppins', sans-serif;
            display: flex;
            align-items: baseline;
            margin-bottom: 8px;
            letter-spacing: -0.02em;
        }

        .plan-price .period {
            font-size: 1rem;
            font-weight: 600;
            color: var(--orange, #d65c29);
            margin-left: 2px;
            font-family: 'Montserrat', sans-serif;
        }

        .plan-desc {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 24px;
            line-height: 1.5;
            font-weight: 500;
        }

        .plan-features {
            list-style: none;
            padding: 0;
            margin: 0 0 32px 0;
            flex-grow: 1;
        }

        .plan-features li {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.85rem;
            color: #475569;
            margin-bottom: 12px;
            display: flex;
            align-items: flex-start;
            font-weight: 600;
        }

        .plan-features li::before {
            content: "-";
            margin-right: 8px;
            color: #94a3b8;
            font-weight: 700;
        }

        .btn-subscribe {
            font-family: 'Montserrat', sans-serif;
            background: var(--orange, #d65c29);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 14px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: background 0.2s ease;
            width: 100%;
        }

        .btn-subscribe:hover {
            background: var(--orange-dk, #bf4d1f);
        }
    
</style>

<div class="app">
    <%- include('../partials/customer_sidebar', { active: 'Membership' }) %>

    <main class="content" style="background-color: #f4f6f9; overflow-y: auto;">
        <h1 class="page-title">Membership Plans</h1>
        <p class="page-subtitle">Choose the perfect plan for your study & coworking needs</p>

        <div class="plans-container" style="justify-content: center;">
            <!-- Starter -->
            <div class="plan-card">
                <div class="plan-title starter">Starter</div>
                <div class="plan-price">₱1,199<span class="period">/mo</span></div>
                <p class="plan-desc">Hot Desk Coworking Credits, Discounts, and Added Perks!</p>
                <ul class="plan-features">
                    <li>30 hrs Hot Desk</li>
                    <li>₱50 Printing Credit</li>
                    <li>₱100 Snack Pass</li>
                </ul>
                <button class="btn-subscribe">Subscribe Now</button>
            </div>

            <!-- Regular -->
            <div class="plan-card">
                <div class="plan-title regular">Regular</div>
                <div class="plan-price">₱1,499<span class="period">/mo</span></div>
                <p class="plan-desc">Hot Desk Coworking Credits, Discounts, and Added Perks!</p>
                <ul class="plan-features">
                    <li>45 hrs Hot Desk</li>
                    <li>10% Discount on Meeting Room</li>
                    <li>₱50 Printing Credit</li>
                </ul>
                <button class="btn-subscribe">Subscribe Now</button>
            </div>

            <!-- Pro -->
            <div class="plan-card">
                <div class="plan-title pro">Pro</div>
                <div class="plan-price">₱1,999<span class="period">/mo</span></div>
                <p class="plan-desc">All-Access Coworking Credits, Discounts, and Added Perks!</p>
                <ul class="plan-features">
                    <li>70 hrs All Access</li>
                    <li>₱75 Printing Credit</li>
                    <li>₱150 Snack Pass</li>
                    <li>10% Discount</li>
                </ul>
                <button class="btn-subscribe">Subscribe Now</button>
            </div>
        </div>

        <div class="plans-row-2">
            <!-- Executive -->
            <div class="plan-card">
                <div class="plan-title executive">Executive</div>
                <div class="plan-price">₱2,499<span class="period">/mo</span></div>
                <p class="plan-desc">All-Access Coworking Credits, Discounts, and Added Perks!</p>
                <ul class="plan-features">
                    <li>100 hrs All Access</li>
                    <li>1 Free Hour Meeting Room</li>
                    <li>₱100 Printing Credit</li>
                    <li>10% Discount</li>
                </ul>
                <button class="btn-subscribe">Subscribe Now</button>
            </div>

            <!-- Premium -->
            <div class="plan-card premium">
                <div class="plan-title premium">Premium</div>
                <div class="plan-price">₱3,499<span class="period">/mo</span></div>
                <p class="plan-desc">Premium Access, Discounts, and Added Perks!</p>
                <ul class="plan-features">
                    <li>Unlimited Access</li>
                    <li>3 Free Meeting Room Hours</li>
                    <li>₱150 Printing Credit</li>
                    <li>₱250 Snack Pass</li>
                    <li>10% Discount</li>
                </ul>
                <button class="btn-subscribe">Subscribe Now</button>
            </div>
        </div>

    </main>
</div>

<%- contentFor('script') %>
