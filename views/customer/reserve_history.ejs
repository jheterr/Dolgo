        /* Reserve History Page Specific Styles */
        .content {
            background-color: #f4f6f9;
            display: flex;
            flex-direction: column;
            height: 100vh;
            padding-bottom: 32px;
        }
        .page-title {
            font-family: 'Poppins', sans-serif; font-size: 2.2rem;
            color: #d65c29; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 24px;
        }
        
        .history-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }
        
        .history-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }
        
        .history-table th {
            background-color: #e2e8f0;
            padding: 16px 32px;
            font-size: 0.85rem;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid #cbd5e1;
        }
        
        .history-table td {
            padding: 20px 32px;
            font-size: 1rem;
            font-weight: 700;
            color: #1e293b;
            border-bottom: 1px solid #e2e8f0;
        }
        
        /* Fixed column widths */
        .history-table th:nth-child(1), .history-table td:nth-child(1) { width: 25%; }
        .history-table th:nth-child(2), .history-table td:nth-child(2) { width: 25%; }
        .history-table th:nth-child(3), .history-table td:nth-child(3) { width: 20%; }
        .history-table th:nth-child(4), .history-table td:nth-child(4) { width: 15%; }
        .history-table th:nth-child(5), .history-table td:nth-child(5) { width: 15%; text-align: center; }
        .history-table th:nth-child(5) { text-align: left; padding-left: 32px; }
        
        .status-pill {
            display: inline-block;
            background-color: #64748b;
            color: white;
            padding: 6px 16px;
            border-radius: 16px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* Empty rows to fill height */
        .empty-row td {
            height: 65px; /* approximate height of a normal row */
        }
    
