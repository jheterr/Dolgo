    function isToday(dateStr){
        const today = new Date();
        const todayStr = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
        return dateStr === todayStr;
    }

    function switchView(){
        const viewType = document.getElementById('viewSelect').value;
        const sortType = document.getElementById('sortSelect').value;
        const container = document.getElementById('cardsContainer');
        let items = [], isEvent = false;

        const todayStr = new Date().toISOString().split('T')[0];

        if(viewType === 'myReservations'){
            items = [...myReservations];
        } else if(viewType === 'upcomingEvents'){
            items = events.filter(e => e.date >= todayStr);
            isEvent = true;
        } else {
            items = events.filter(e => e.date < todayStr);
            isEvent = true;
        }

        // Sorting
        items.sort((a,b) => {
            const valA = isEvent ? a.name : a.seat;
            const valB = isEvent ? b.name : b.seat;
            if(sortType === 'date_asc') return a.date.localeCompare(b.date);
            if(sortType === 'date_desc') return b.date.localeCompare(a.date);
            if(sortType === 'name_asc') return valA.localeCompare(valB);
            if(sortType === 'name_desc') return valB.localeCompare(valA);
            return 0;
