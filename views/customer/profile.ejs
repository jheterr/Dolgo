<!-- Title passed to layout -->
<% locals.title = 'The Last Muster • Profile' %>

<%- contentFor('style') %>
<style>


        /* Profile Page Specific Styles */
        .content {
            background-color: #f4f6f9;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            padding-bottom: 32px;
        }
        .page-title {
            font-family: 'Poppins', sans-serif; font-size: 2.2rem;
            color: #d65c29; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 24px;
        }
        
        .profile-layout {
            display: flex; gap: 24px; align-items: flex-start;
        }
        .profile-card {
            background: white; border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            border: 1px solid #e2e8f0; padding: 40px;
        }
        
        /* Left Column */
        .profile-summary {
            flex: 0 0 320px; display: flex; flex-direction: column; align-items: center; padding: 48px 32px;
        }
        .profile-avatar {
            width: 140px; height: 140px; border-radius: 50%; object-fit: cover; margin-bottom: 24px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        .profile-name {
            font-family: 'Poppins', sans-serif; font-size: 1.4rem; font-weight: 800;
            color: #1e293b; margin-bottom: 4px; text-align: center; letter-spacing: -0.01em;
        }
        .profile-email {
            font-size: 0.9rem; color: #64748b; font-weight: 600; margin-bottom: 16px; text-align: center;
        }
        .profile-plan-pill {
            background-color: #d65c29; color: white; padding: 6px 24px; border-radius: 20px;
            font-size: 0.9rem; font-weight: 700; margin-bottom: 40px; box-shadow: 0 4px 6px -2px rgba(214, 92, 41, 0.3);
        }
        .btn-edit-profile {
            background: white; color: #1e293b; border: 1px solid #cbd5e1;
            padding: 10px 24px; border-radius: 24px; font-weight: 700; font-size: 0.95rem;
            cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all 0.2s;
        }
        .btn-edit-profile:hover {
            background: #f8fafc; border-color: #94a3b8;
        }
        
        /* Right Column */
        .account-info {
            flex: 1; padding: 48px;
        }
        .info-title {
            font-family: 'Poppins', sans-serif; font-size: 1.4rem; font-weight: 800;
            color: #1e293b; margin-bottom: 8px; padding-bottom: 16px; border-bottom: 1px solid #1e293b;
        }
        .info-list {
            display: flex; flex-direction: column;
        }
        .info-item {
            display: flex; align-items: center; gap: 24px; padding: 20px 0; border-bottom: 1px solid #e2e8f0;
        }
        .info-item:last-child {
            border-bottom: none; padding-bottom: 0;
        }
        .info-icon {
            width: 44px; height: 44px; background-color: #e0e7ff; color: #d65c29;
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
            font-size: 1.15rem; flex-shrink: 0;
        }
        .info-text {
            display: flex; flex-direction: column; gap: 4px;
        }
        .info-label {
            font-size: 0.8rem; font-weight: 600; color: #64748b;
        }
        .info-value {
            font-size: 1.05rem; font-weight: 700; color: #1e293b; line-height: 1.3;
        }
        
        /* Edit Profile Modal */
        .modal-overlay {
            display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.4); z-index: 1000; align-items: center; justify-content: center;
        }
        .modal-overlay.active { display: flex; }
        .modal-content {
            background: white; border-radius: 12px; padding: 32px; width: 90%; max-width: 480px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            max-height: 90vh; overflow-y: auto;
        }
        .edit-photo-container {
            display: flex; justify-content: center; margin-bottom: 24px;
        }
        .edit-photo-circle {
            width: 80px; height: 80px; background-color: #f1f5f9; border-radius: 50%;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            color: #475569; font-size: 0.65rem; font-weight: 700; text-align: center; cursor: pointer;
            transition: background 0.2s;
        }
        .edit-photo-circle:hover { background-color: #e2e8f0; }
        .edit-photo-circle i {
            font-size: 1.1rem; margin-bottom: 4px; color: #1e293b;
        }
        .edit-profile-form {
            display: flex; flex-direction: column; gap: 16px;
        }
        .form-row {
            display: flex; gap: 16px;
        }
        .form-group {
            display: flex; flex-direction: column; flex: 1;
        }
        .form-group label {
            font-size: 0.85rem; font-weight: 700; color: #1e293b; margin-bottom: 6px;
        }
        .form-input {
            padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 0.95rem;
            color: #64748b; font-family: inherit; outline: none; transition: border-color 0.2s; font-weight: 500;
        }
        .form-input:focus { border-color: #d65c29; }
        .form-actions {
            display: flex; justify-content: flex-end; gap: 12px; margin-top: 16px;
        }
        .btn-cancel {
            background: white; border: 1px solid #cbd5e1; color: #475569; padding: 8px 24px;
            border-radius: 6px; font-weight: 700; cursor: pointer; transition: background 0.2s; font-size: 0.95rem;
        }
        .btn-cancel:hover { background: #f8fafc; }
        .btn-save {
            background: #d65c29; border: none; color: white; padding: 8px 32px;
            border-radius: 6px; font-weight: 700; cursor: pointer; transition: background 0.2s; font-size: 0.95rem;
        }
        .btn-save:hover { background: #bf4d1f; }
    
</style>

<div class="app">
        <%- include('../partials/customer_sidebar') %>

        <main class="content">
            <h1 class="page-title">Profile</h1>
            
            <div class="profile-layout">
                <!-- Left Column: User Summary -->
                <div class="profile-card profile-summary">
                    <img src="/images/anime_avatar.png" alt="Profile Avatar" class="profile-avatar">
                    <h2 class="profile-name">Sanji Vinsmoke</h2>
                    <p class="profile-email">luffy@thelastmuster.com</p>
                    <div class="profile-plan-pill">Premium</div>
                    <button class="btn-edit-profile" onclick="openEditModal()"><i class="fa-solid fa-pen-to-square"></i> Edit Profile</button>
                </div>
                
                <!-- Right Column: Account Information -->
                <div class="profile-card account-info">
                    <h2 class="info-title">Account Information</h2>
                    <div class="info-list">
                        <div class="info-item">
                            <div class="info-icon"><i class="fa-solid fa-user"></i></div>
                            <div class="info-text">
                                <span class="info-label">Full Name</span>
                                <span class="info-value">Sanji Vinsmoke</span>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon"><i class="fa-solid fa-envelope"></i></div>
                            <div class="info-text">
                                <span class="info-label">Email Address</span>
                                <span class="info-value">Sanji@thelastmuster.com</span>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon"><i class="fa-solid fa-mobile-screen"></i></div>
                            <div class="info-text">
                                <span class="info-label">MAC Address</span>
                                <span class="info-value">AA:BB:CC:DD:EE:FF<br>AA:BB:CC:DD:EE:FF</span>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon"><i class="fa-solid fa-calendar"></i></div>
                            <div class="info-text">
                                <span class="info-label">Member Since</span>
                                <span class="info-value">January 1, 2026</span>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
                            <div class="info-text">
                                <span class="info-label">Contact Number</span>
                                <span class="info-value">09652564525</span>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
                            <div class="info-text">
                                <span class="info-label">Location</span>
                                <span class="info-value">Iriga City, Philippines</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <!-- Edit Profile Modal -->
        <div id="editProfileModal" class="modal-overlay">
            <div class="modal-content" style="max-width: 500px; padding: 40px;">
                <h2 class="modal-title" style="font-family: 'Poppins', sans-serif; margin-bottom: 24px; font-size: 1.25rem; font-weight: 800; color: #1e293b;">Edit Profile</h2>
                
                <div class="edit-photo-container">
                    <div class="edit-photo-circle">
                        <i class="fa-solid fa-camera"></i>
                        <span>Choose<br>Photo</span>
                    </div>
                </div>
                
                <form class="edit-profile-form">
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" value="sanji@thelastmuster.com" class="form-input">
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label>First Name</label>
                            <input type="text" value="sanji" class="form-input">
                        </div>
                        <div class="form-group">
                            <label>Last Name</label>
                            <input type="text" value="vinsmoke" class="form-input">
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="text" value="09652564525" class="form-input">
                    </div>
                    
                    <div class="form-group">
                        <label>Location</label>
                        <input type="text" value="Iriga City, Philippines" class="form-input">
                    </div>
                    
                    <div class="form-group">
                        <label>MAC Address</label>
                        <input type="text" value="AA:DD:ADD:DA" class="form-input">
                    </div>
                    
                    <div class="form-actions">
                        <button type="button" class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                        <button type="button" class="btn-save" onclick="closeEditModal()">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

<%- contentFor('script') %>
<script>
        function openEditModal() {
            document.getElementById('editProfileModal').classList.add('active');
        }

        function closeEditModal() {
            document.getElementById('editProfileModal').classList.remove('active');
        }

        window.onclick = function(event) {
            const modal = document.getElementById('editProfileModal');
            if (event.target == modal) {
                closeEditModal();
            }
        }

    </script>

