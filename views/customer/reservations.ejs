    <main class="content">
        <h1 class="page-title">My Bookings</h1>
        
        <!-- Approved Active Session Card -->
        <% if (session) { %>
            <div class="active-session-card">
                <span class="badge-active"><%= session.is_paused ? 'Paused' : 'Active' %></span>
                
                <h2 class="session-title">Active Session</h2>
                <p class="session-subtitle">
                    Started at <%= new Date(session.start_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %> 
                    - Ends at <%= new Date(session.end_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %> / 3-hour package
                </p>
                
                <div class="metric-group">
                    <div class="metric-item">
                        <p class="metric-label">Remaining Time</p>
                        <div id="remainingTime" class="metric-value">00:00</div>
                    </div>
                    <div class="metric-item" style="margin-left: 40px;">
                        <p class="metric-label">Assigned Seat</p>
                        <div class="metric-value"><%= activeSeat %></div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="active-session-card" style="background-color: #e2e8f0;">
                <h2 class="session-title" style="color: #64748b;">No Active Session</h2>
                <p class="session-subtitle" style="color: #64748b;">Visit the counter to start a session.</p>
            </div>
        <% } %>
        
        <div class="section-header">
            <h2 class="section-title">Reservation History</h2>
            <button class="btn-action" onclick="window.location.href='/customer/reserve-new'">
                <i class="fa-solid fa-plus"></i> New Reservation
            </button>
        </div>
        
        <!-- Modern Table Container -->
        <div class="table-container">
            <table class="reservations-table">
                <thead>
                    <tr>
                        <th>DATE & TIME</th>
                        <th>SEAT</th>
                        <th>DURATION</th>
                        <th>STATUS</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (reservations.length > 0) { %>
                        <% reservations.forEach(res => { %>
                            <tr>
                                <td>
                                    <div style="display: flex; flex-direction: column;">
                                        <span style="font-weight: 800; color: #1e293b;">
                                            <%= new Date(res.start_time).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                        </span>
                                        <span style="font-size: 0.8rem; color: #64748b;">
                                            <%= new Date(res.start_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %> - 
                                            <%= new Date(res.end_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <span class="seat-badge"><%= res.seat_label %></span>
                                </td>
                                <td>
                                    <span style="color: #475569;"><%= res.duration_hours %> Hour(s)</span>
                                </td>
                                <td>
                                    <% 
                                        const statusClass = res.status === 'confirmed' ? 'status-confirmed' : 
                                                          (res.status === 'pending' ? 'status-pending' : 'status-completed');
                                    %>
                                    <span class="status-pill <%= statusClass %>">
                                        <i class="fa-solid <%= res.status === 'confirmed' ? 'fa-circle-check' : 'fa-circle-info' %>"></i>
                                        <%= res.status %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4">
                                <div class="empty-state">
                                    <i class="fa-regular fa-calendar-xmark" style="font-size: 3rem; margin-bottom: 12px; display: block;"></i>
                                    <p>You haven't made any reservations yet.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</div>

