<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Staff' %>

<%- contentFor('style') %>
<style>

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .45);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 16px;
    }

    .modal-overlay.open {
      display: flex;
    }

    .modal {
      background: var(--white);
      border-radius: var(--radius);
      padding: 28px;
      width: 100%;
      max-width: 480px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
      display: flex;
      flex-direction: column;
      gap: 16px;
      max-height: 90vh;
      overflow-y: auto;
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .modal-title {
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 700;
    }

    .modal-close {
      background: none;
      border: none;
      font-size: 1.3rem;
      color: var(--text-sm);
      cursor: pointer;
    }

    .modal-body {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .profile-layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 16px;
    }

    .profile-card {
      border-radius: var(--radius);
      padding: 28px 20px;
      background: var(--white);
      border: 1px solid rgba(226, 232, 240, .8);
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
    }

    .avatar-wrapper {
      position: relative;
      width: 100px;
      height: 100px;
      cursor: pointer;
      margin-bottom: 8px;
    }
    
    .avatar {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: linear-gradient(135deg, #254b7a, #2E6098);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Poppins', sans-serif;
      font-size: 1.8rem;
      font-weight: 800;
      color: #fff;
      box-shadow: 0 4px 14px rgba(30, 58, 95, .2);
      overflow: hidden;
      border: 3px solid #fff;
    }
    
    .avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: none;
    }
    
    .avatar.has-image img {
      display: block;
    }
    
    .avatar.has-image span {
      display: none;
    }
    
    .avatar-overlay {
      position: absolute;
      bottom: 0;
      right: 0;
      background: var(--orange);
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 0.9rem;
      border: 3px solid #fff;
      transition: all 0.2s ease;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    
    .avatar-wrapper:hover .avatar-overlay {
      transform: scale(1.1);
      background: #e67e22;
    }
    
    .cropper-container-wrapper {
      width: 100%;
      max-height: 400px;
      background: #f1f5f9;
      border-radius: 8px;
      overflow: hidden;
    }
    
    #cropImage {
      max-width: 100%;
      display: block;
    }

    /* Round Cropper */
    .cropper-view-box,
    .cropper-face {
      border-radius: 50%;
    }

    .cropper-view-box {
      box-shadow: 0 0 0 1px #39f;
      outline: 0;
    }

    .cropper-face {
      background-color: inherit !important;
    }

    /* Hide square grid and lines */
    .cropper-view-box {
      outline: none !important;
    }

    .cropper-dashed,
    .cropper-point,
    .cropper-line,
    .cropper-center {
      display: none !important;
    }

    /* Make the modal (background) transparent where the circle is */
    .cropper-modal {
      opacity: 0.6 !important;
      background-color: #000 !important;
    }

    /* Camera Styles */
    .camera-container {
      width: 100%;
      aspect-ratio: 1;
      background: #000;
      border-radius: 8px;
      overflow: hidden;
      position: relative;
    }

    #cameraVideo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transform: scaleX(-1); /* Mirror view */
    }

    .choice-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 24px;
      border: 2px dashed var(--border);
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s ease;
      flex: 1;
    }

    .choice-btn:hover {
      border-color: var(--orange);
      background: var(--cream-lt);
      transform: translateY(-2px);
    }

    .choice-btn i {
      font-size: 2rem;
      color: var(--orange);
    }

    .choice-btn span {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
    }

    .profile-name {
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 700;
    }

    .profile-email {
      font-size: 12px;
      color: var(--text-sm);
    }

    .role-tag {
      background: var(--orange);
      color: #fff;
      padding: 3px 14px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .06em;
    }

    .info-card {
      border-radius: var(--radius);
      padding: 22px;
      background: var(--white);
      border: 1px solid rgba(226, 232, 240, .8);
      box-shadow: var(--shadow);
    }

    .info-title {
      font-family: 'Poppins', sans-serif;
      font-size: .9rem;
      font-weight: 700;
      padding-bottom: 12px;
      border-bottom: 2px solid var(--border);
      margin-bottom: 4px;
    }

    .info-field {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }

    .info-field:last-child {
      border-bottom: none;
    }

    .info-icon {
      width: 36px;
      height: 36px;
      border-radius: 9px;
      background: var(--cream-lt);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--orange);
      font-size: .9rem;
      flex-shrink: 0;
    }

    .info-lbl {
      font-size: 10px;
      font-weight: 700;
      color: var(--text-sm);
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 2px;
    }

    .info-val {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
    }

    @media(max-width:800px) {
      .profile-layout {
        grid-template-columns: 1fr;
      }
    }
  
</style>

<div class="toast-stack" id="toastStack"></div>
  <div class="app">
    <%- include('../partials/staff_sidebar', { active: 'Profile' }) %>
    <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>
    <main class="content">
      <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>

      <h1 class="page-title">Profile</h1>
      <div class="profile-layout">
        <div class="profile-card">
          <div class="avatar-wrapper" onclick="openModal('avatarChoiceModal')">
            <div class="avatar" id="avatarInitials">
              <span id="initialsText">LM</span>
              <img id="avatarImg" src="" alt="Avatar">
            </div>
            <div class="avatar-overlay">
              <i class="fa-solid fa-camera"></i>
            </div>
          </div>
          <input type="file" id="avatarInput" hidden accept="image/*">
          <div class="profile-name" id="profileName">Luffy Monkey</div>
          <div class="profile-email" id="profileEmail">luffy@thelastmuster.com</div>
          <div class="role-tag">STAFF</div>
          <button class="btn btn-ghost" style="margin-top:6px" onclick="openModal('editProfileModal')"><i
              class="fa-solid fa-pen"></i> Edit Profile</button>
        </div>
        <div class="info-card">
          <div class="info-title">Account Information</div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-user"></i></div>
            <div>
              <div class="info-lbl">Full Name</div>
              <div class="info-val" id="infoName">Luffy Monkey</div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-envelope"></i></div>
            <div>
              <div class="info-lbl">Email Address</div>
              <div class="info-val" id="infoEmail">Luffy@thelastmuster.com</div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-shield-halved"></i></div>
            <div>
              <div class="info-lbl">Role</div>
              <div class="info-val">Admin</div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-calendar"></i></div>
            <div>
              <div class="info-lbl">Staff Since</div>
              <div class="info-val">January 1, 2026</div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
            <div>
              <div class="info-lbl">Contact Number</div>
              <div class="info-val" id="infoPhone">09652564525</div>
            </div>
          </div>
          <div class="info-field">
            <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
            <div>
              <div class="info-lbl">Location</div>
              <div class="info-val" id="infoLocation">Iriga City, Philippines</div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-overlay" id="avatarChoiceModal">
        <div class="modal" style="max-width: 400px;">
          <div class="modal-header">
            <div class="modal-title">Update Profile Picture</div>
            <button class="modal-close" onclick="closeModal('avatarChoiceModal')">&times;</button>
          </div>
          <div class="modal-body" style="flex-direction: row; gap: 16px;">
            <div class="choice-btn" onclick="startCamera()">
              <i class="fa-solid fa-camera"></i>
              <span>Take Photo</span>
            </div>
            <div class="choice-btn" onclick="document.getElementById('avatarInput').click(); closeModal('avatarChoiceModal');">
              <i class="fa-solid fa-upload"></i>
              <span>Upload Photo</span>
            </div>
          </div>
        </div>
      </div>

      <div class="modal-overlay" id="cameraModal">
        <div class="modal" style="max-width: 480px;">
          <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-video"></i> Camera</div>
            <button class="modal-close" onclick="stopCamera(); closeModal('cameraModal');">&times;</button>
          </div>
          <div class="modal-body">
            <div class="camera-container">
              <video id="cameraVideo" autoplay playsinline></video>
            </div>
          </div>
          <div class="modal-footer">
            <button class="btn btn-ghost" onclick="stopCamera(); closeModal('cameraModal');">Cancel</button>
            <button class="btn btn-primary" onclick="capturePhoto()"><i class="fa-solid fa-circle"></i> Take Photo</button>
          </div>
        </div>
      </div>

      <div class="modal-overlay" id="cropModal">
        <div class="modal" style="max-width: 600px;">
          <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-crop"></i> Adjust Photo</div>
            <button class="modal-close" onclick="closeModal('cropModal')">&times;</button>
          </div>
          <div class="modal-body">
            <div class="cropper-container-wrapper">
              <img id="cropImage" src="">
            </div>
            <p style="font-size: 12px; color: var(--text-sm); text-align: center;">Drag to position, scroll to zoom</p>
          </div>
          <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeModal('cropModal')">Cancel</button>
            <button class="btn btn-primary" id="cropSaveBtn"><i class="fa-solid fa-check"></i> Apply Crop</button>
          </div>
        </div>
      </div>

      <div class="modal-overlay" id="editProfileModal">
        <div class="modal">
          <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-pen"></i> Edit Profile</div><button class="modal-close"
              onclick="closeModal('editProfileModal')">&times;</button>
          </div>
          <div class="modal-body">
            <div class="form-group"><label class="form-label">Full Name</label><input class="form-control" id="ep-name"
                type="text" value="Luffy Monkey"></div>
            <div class="form-group"><label class="form-label">Email Address</label><input class="form-control"
                id="ep-email" type="email" value="Luffy@thelastmuster.com"></div>
            <div class="form-group"><label class="form-label">Contact Number</label><input class="form-control"
                id="ep-phone" type="tel" value="09652564525"></div>
            <div class="form-group"><label class="form-label">Location</label><input class="form-control" id="ep-loc"
                type="text" value="Iriga City, Philippines"></div>
          </div>
          <div class="modal-footer"><button class="btn btn-ghost"
              onclick="closeModal('editProfileModal')">Cancel</button><button class="btn btn-primary"
              onclick="saveProfile()"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button></div>
        </div>
      </div>
    </main>
  </div>

<%- contentFor('script') %>
<script>

    function openSidebar() {
      document.getElementById('sidebar').classList.add('mobile-open');
      document.getElementById('mobileOverlay').classList.add('show');
    }

    function closeSidebar() {
      document.getElementById('sidebar').classList.remove('mobile-open');
      document.getElementById('mobileOverlay').classList.remove('show');
    }

    function openModal(id) {
      document.getElementById(id).classList.add('open');
    }

    function closeModal(id) {
      document.getElementById(id).classList.remove('open');
    }

    function saveProfile() {
      const name = document.getElementById('ep-name').value.trim(),
        email = document.getElementById('ep-email').value.trim();

      if (!name || !email) {
        alert('Name and email are required');
        return;
      }

      const phone = document.getElementById('ep-phone').value.trim(),
        loc = document.getElementById('ep-loc').value.trim();

      document.getElementById('profileName').textContent = name;
      document.getElementById('profileEmail').textContent = email;

      document.getElementById('infoName').textContent = name;
      document.getElementById('infoEmail').textContent = email;
      document.getElementById('infoPhone').textContent = phone;
      document.getElementById('infoLocation').textContent = loc;

      document.getElementById('initialsText').textContent =
        name.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();

      alert('Profile updated successfully');

      closeModal('editProfileModal');
    }

    // Avatar Logic
    let cropper = null;
    let videoStream = null;
    const avatarInput = document.getElementById('avatarInput');
    const cropModal = document.getElementById('cropModal');
    const cropImage = document.getElementById('cropImage');
    const avatarImg = document.getElementById('avatarImg');
    const avatarDiv = document.getElementById('avatarInitials');
    const cameraVideo = document.getElementById('cameraVideo');

    async function startCamera() {
      closeModal('avatarChoiceModal');
      openModal('cameraModal');
      try {
        videoStream = await navigator.mediaDevices.getUserMedia({ video: { aspectRatio: 1 }, audio: false });
        cameraVideo.srcObject = videoStream;
      } catch (err) {
        console.error("Camera error:", err);
        alert("Could not access camera. Please check permissions.");
        closeModal('cameraModal');
      }
    }

    function stopCamera() {
      if (videoStream) {
        videoStream.getTracks().forEach(track => track.stop());
        videoStream = null;
      }
    }

    function capturePhoto() {
      const canvas = document.createElement('canvas');
      canvas.width = cameraVideo.videoWidth;
      canvas.height = cameraVideo.videoHeight;
      const ctx = canvas.getContext('2d');
      // Flip horizontally to match mirrored video
      ctx.translate(canvas.width, 0);
      ctx.scale(-1, 1);
      ctx.drawImage(cameraVideo, 0, 0, canvas.width, canvas.height);
      
      const dataUrl = canvas.toDataURL('image/jpeg');
      stopCamera();
      closeModal('cameraModal');
      
      initCropper(dataUrl);
    }

    avatarInput.addEventListener('change', function (e) {
      const files = e.target.files;
      if (files && files.length > 0) {
        const file = files[0];
        const reader = new FileReader();
        reader.onload = function (event) {
          initCropper(event.target.result);
        };
        reader.readAsDataURL(file);
      }
    });

    function initCropper(src) {
      cropImage.src = src;
      openModal('cropModal');
      
      if (cropper) {
        cropper.destroy();
      }
      
      setTimeout(() => {
        cropper = new Cropper(cropImage, {
          aspectRatio: 1,
          viewMode: 2,
          guides: true,
          center: true,
          highlight: false,
          cropBoxMovable: true,
          cropBoxResizable: true,
          toggleDragModeOnDblclick: false,
        });
      }, 200);
    }

    document.getElementById('cropSaveBtn').addEventListener('click', function () {
      if (!cropper) return;
      
      const canvas = cropper.getCroppedCanvas({
        width: 200,
        height: 200,
      });

      avatarImg.src = canvas.toDataURL();
      avatarDiv.classList.add('has-image');
      
      closeModal('cropModal');
      avatarInput.value = '';
      toast('✓ Profile picture updated', 'success');
    });

    function toast(msg, type) {
      const t = document.createElement('div');
      t.style.cssText = `
        position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
        background: ${type === 'success' ? '#059669' : '#1e293b'};
        color: #fff; padding: 12px 24px; border-radius: 50px; font-size: 13px;
        font-weight: 600; z-index: 9999; box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        opacity: 0; transition: all 0.3s ease;
      `;
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(() => { t.style.opacity = '1'; t.style.bottom = '40px'; }, 10);
      setTimeout(() => { t.style.opacity = '0'; t.style.bottom = '20px'; setTimeout(() => t.remove(), 300); }, 2500);
    }
  </script>

