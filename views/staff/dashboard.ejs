<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Staff Dashboard' %>

<%- contentFor('style') %>
<style>

    .welcome-banner {
      background: linear-gradient(135deg, #f97316, #ea580c);
      color: white;
      padding: 20px 24px;
      border-radius: 12px;
      margin-bottom: 24px;
    }
    .stat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px; }
    .stat-card { border-radius:var(--radius); padding:18px 20px; color:#fff; position:relative; overflow:hidden; }
    .stat-card::after { content:''; position:absolute; top:-16px; right:-16px; width:70px; height:70px; border-radius:50%; background:rgba(255,255,255,0.08); }
    .stat-icon { font-size:1.3rem; opacity:0.9; margin-bottom:8px; }
    .stat-lbl  { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; opacity:0.85; margin-bottom:6px; }
    .stat-val  { font-family:'Poppins',sans-serif; font-size:2.2rem; font-weight:800; line-height:1; }
    
    /* Stat card backgrounds */
    .sc-gold { background: linear-gradient(135deg, #8A8636, #b0ac4a); }
    .sc-orange { background: linear-gradient(135deg, #CF6322, #e0793a); }
    .sc-teal { background: linear-gradient(135deg, #2a6b5e, #3a8a7a); }
    .sc-green { background: linear-gradient(135deg, #3d7a52, #5a9e6f); }

    .charts-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:24px; }
    .chart-card { background:white; border-radius:var(--radius); padding:16px; border:1px solid var(--border); }
    .chart-title { font-size:13px; font-weight:700; margin-bottom:12px; }
    .chart-box { height:260px; }

    .dash-bottom { display:grid; grid-template-columns:1fr 300px; gap:16px; margin-bottom:24px; }
    .payments-section { margin-top:8px; }
    .payments-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
    .payment-card { background:white; border-radius:var(--radius); padding:16px; border:1px solid var(--border); box-shadow:var(--shadow); }
    .payment-card .section-title { margin-bottom:12px; font-size:13px; }
    .payment-list { display:flex; flex-direction:column; gap:10px; max-height:280px; overflow-y:auto; }
    .payment-item { display:flex; align-items:center; justify-content:space-between; padding:10px 0; border-bottom:2px solid #CF6322; }
    .payment-item:last-child { border-bottom:none; }
    .payment-info { flex:1; }
    .payment-name { font-weight:700; font-size:12px; margin-bottom:2px; }
    .payment-detail { font-size:10px; color:var(--text-sm); }
    .payment-amount { font-weight:800; font-size:13px; color:var(--orange); margin-right:12px; }
    .pay-btn { background:var(--green); color:white; border:none; padding:5px 12px; border-radius:20px; font-size:10px; font-weight:600; cursor:pointer; }
    .pay-btn:hover { background:#2d5c3d; }

    .feed-list { display:flex; flex-direction:column; gap:7px; max-height:260px; overflow-y:auto; }
    .feed-item { display:flex; align-items:center; gap:8px; padding:8px 10px; background:var(--cream-lt); border-radius:8px; }
    .feed-seat { font-size:10px; font-weight:700; color:#fff; border-radius:4px; padding:2px 7px; white-space:nowrap; }
    .feed-seat.in  { background:var(--green); }
    .feed-seat.out { background:#e53e3e; }
    .feed-text { font-size:11px; color:var(--text-md); flex:1; }
    .feed-time { font-size:10px; color:var(--text-sm); }

    @media(max-width:900px){ 
      .stat-grid{grid-template-columns:repeat(2,1fr);} 
      .dash-bottom{grid-template-columns:1fr;} 
      .payments-grid{grid-template-columns:1fr;}
      .charts-row{grid-template-columns:1fr;}
    }
    /* Dynamic Seat Map Styles */
    .seat-map-container {
      width: 100%;
      height: 380px;
      background: #f8fafc;
      border-radius: 8px;
      overflow: hidden;
      position: relative;
      border: 1px solid var(--border);
    }

    #dynamicSeatMap {
      position: absolute;
      width: 800px;
      height: 450px;
      transform-origin: 0 0;
      transition: transform 0.3s ease;
    }

    .fp-item {
      position: absolute;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .item-visual {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.2s ease, background-color 0.3s ease;
    }

    .chair-icon {
      -webkit-mask-size: contain;
      mask-size: contain;
      -webkit-mask-repeat: no-repeat;
      mask-repeat: no-repeat;
      -webkit-mask-position: center;
      mask-position: center;
    }

    .item-label {
      position: absolute;
      top: calc(100% + 2px);
      left: 50%;
      transform: translateX(-50%);
      font-size: 8px;
      font-weight: 700;
      color: #475569;
      white-space: nowrap;
    }

    .item-label.center {
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 9px;
    }

    .map-legend {
      display: flex;
      gap: 12px;
      margin-bottom: 12px;
      font-size: 11px;
      font-weight: 600;
    }

    .legend-dot {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .legend-dot span {
      width: 10px;
      height: 10px;
      border-radius: 2px;
      display: inline-block;
    }
    
</style>

<div class="app">
    <!-- Sidebar -->
    <%- include('../partials/staff_sidebar', { active: 'Dashboard' }) %>

    <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>

    <main class="content">
      <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>
      
      <!-- Welcome Banner -->
      <div class="welcome-banner">
        <h2>Welcome back, <strong>Staff Zoro</strong> 👋</h2>
        <p>Manage daily operations, monitor seat status, and assist customers</p>
      </div>

      <!-- Stats with backgrounds -->
      <div class="stat-grid">
        <div class="stat-card sc-gold"><div class="stat-icon"><i class="fa-solid fa-users"></i></div><div class="stat-lbl">TOTAL ACTIVE USERS</div><div class="stat-val"><%= stats.activeUsers %></div></div>
        <div class="stat-card sc-orange"><div class="stat-icon"><i class="fa-solid fa-user"></i></div><div class="stat-lbl">TOTAL CUSTOMERS</div><div class="stat-val"><%= stats.totalCustomers %></div></div>
        <div class="stat-card sc-teal"><div class="stat-icon"><i class="fa-solid fa-wifi"></i></div><div class="stat-lbl">ACTIVE WI-FI SESSION</div><div class="stat-val"><%= stats.wifiSessions %></div></div>
        <div class="stat-card sc-green"><div class="stat-icon"><i class="fa-solid fa-couch"></i></div><div class="stat-lbl">SEAT AVAILABLE</div><div class="stat-val" id="statAvailable"><%= stats.availableSeats %></div></div>
      </div>

      <!-- Charts -->
      <div class="charts-row">
        <div class="chart-card">
          <div class="chart-title">Today's Traffic</div>
          <div class="chart-box"><canvas id="trafficChart"></canvas></div>
        </div>
        <div class="chart-card">
          <div class="chart-title">Seat Status Distribution</div>
          <div class="chart-box"><canvas id="seatChart"></canvas></div>
        </div>
      </div>

      <!-- Seat Map + Activity -->
      <div class="dash-bottom">
        <div class="card">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <div class="section-title" style="margin-bottom:0">Live Seat Status</div>
            <button class="btn btn-ghost" style="padding: 4px 12px; font-size: 11px;" onclick="renderLiveSeatMap()" title="Sync with Seat Management">
              <i class="fa-solid fa-rotate"></i> Sync
            </button>
          </div>
          <div class="map-legend">
            <div class="legend-dot"><span style="background:#10b981"></span>Available</div>
            <div class="legend-dot"><span style="background:#d65c29"></span>Taken</div>
            <div class="legend-dot"><span style="background:#1e293b"></span>Reserved</div>
            <div class="legend-dot"><span style="background:#facc15"></span>Idle</div>
          </div>
          <div class="seat-map-container" id="seatMapViewport">
            <div id="dynamicSeatMap"></div>
          </div>
        </div>
        <div class="card">
          <div class="section-title">Recent Activity</div>
          <div class="feed-list" id="activityFeed"></div>
        </div>
      </div>

      <!-- Pending Payments -->
      <div class="payments-section">
        <div class="section-title" style="margin-bottom:16px;"><i class="fa-solid fa-credit-card"></i> Pending Payments</div>
        <div class="payments-grid">
          <div class="payment-card"><div class="section-title"><i class="fa-solid fa-calendar-check"></i> Reservations</div><div class="payment-list" id="reservationPaymentsList"></div></div>
          <div class="payment-card"><div class="section-title"><i class="fa-solid fa-wifi"></i> WiFi Extensions</div><div class="payment-list" id="wifiPaymentsList"></div></div>
          <div class="payment-card"><div class="section-title"><i class="fa-solid fa-star"></i> Plan Upgrades</div><div class="payment-list" id="upgradePaymentsList"></div></div>
        </div>
      </div>
    </main>
  </div>

<%- contentFor('script') %>
<script>
// Sidebar functions

function openSidebar(){ document.getElementById('sidebar').classList.add('mobile-open'); document.getElementById('mobileOverlay').classList.add('show'); }
function closeSidebar(){ document.getElementById('sidebar').classList.remove('mobile-open'); document.getElementById('mobileOverlay').classList.remove('show'); }

// Pending Payments Data
let pendingReservations = <%- JSON.stringify(pendingReservations) %>;

let pendingWifiExtensions = [
  { id: 1, name: "Sanji Vinsmoke", seat: "A1", hours: 1, amount: 50, paid: false },
  { id: 2, name: "Brook Musician", seat: "A7", hours: 2, amount: 100, paid: false }
];

let pendingUpgrades = [
  { id: 1, name: "Jinbe Knight", seat: "A2", fromPlan: "Member", toPlan: "Premium", amount: 1199, paid: false },
  { id: 2, name: "Nami Catburglar", seat: "C5", fromPlan: "Member", toPlan: "Premium", amount: 1199, paid: false }
];

function formatPHP(amount) { return '₱' + amount.toLocaleString(); }
function escapeHtml(str) { return String(str).replace(/[&<>]/g, function(m) { if (m === '&') return '&amp;'; if (m === '<') return '&lt;'; if (m === '>') return '&gt;'; return m; }); }

// Render Reservation Payments
function renderReservationPayments() {
  const container = document.getElementById('reservationPaymentsList');
  if (pendingReservations.length === 0) { container.innerHTML = '<div class="empty-payments">No pending payments</div>'; return; }
  container.innerHTML = pendingReservations.map(item => `<div class="payment-item"><div class="payment-info"><div class="payment-name">${escapeHtml(item.name)}</div><div class="payment-detail">Seat ${item.seat} • ${item.date}</div></div><div class="payment-amount">${formatPHP(item.amount)}</div><button class="pay-btn" onclick="markPaymentPaid('reservation', ${item.id})">Pay Now</button></div>`).join('');
}

function renderWifiPayments() {
  const container = document.getElementById('wifiPaymentsList');
  const unpaid = pendingWifiExtensions.filter(item => !item.paid);
  if (unpaid.length === 0) { container.innerHTML = '<div class="empty-payments">No pending payments</div>'; return; }
  container.innerHTML = unpaid.map(item => `<div class="payment-item"><div class="payment-info"><div class="payment-name">${escapeHtml(item.name)}</div><div class="payment-detail">Seat ${item.seat} • +${item.hours} hr(s)</div></div><div class="payment-amount">${formatPHP(item.amount)}</div><button class="pay-btn" onclick="markPaymentPaid('wifi', ${item.id})">Pay Now</button></div>`).join('');
}

function renderUpgradePayments() {
  const container = document.getElementById('upgradePaymentsList');
  const unpaid = pendingUpgrades.filter(item => !item.paid);
  if (unpaid.length === 0) { container.innerHTML = '<div class="empty-payments">No pending payments</div>'; return; }
  container.innerHTML = unpaid.map(item => `<div class="payment-item"><div class="payment-info"><div class="payment-name">${escapeHtml(item.name)}</div><div class="payment-detail">Seat ${item.seat} • ${item.fromPlan} → ${item.toPlan}</div></div><div class="payment-amount">${formatPHP(item.amount)}</div><button class="pay-btn" onclick="markPaymentPaid('upgrade', ${item.id})">Pay Now</button></div>`).join('');
}

window.markPaymentPaid = function(type, id) {
  if (type === 'reservation') { let item = pendingReservations.find(i => i.id === id); if (item) item.paid = true; renderReservationPayments(); }
  else if (type === 'wifi') { let item = pendingWifiExtensions.find(i => i.id === id); if (item) item.paid = true; renderWifiPayments(); }
  else if (type === 'upgrade') { let item = pendingUpgrades.find(i => i.id === id); if (item) item.paid = true; renderUpgradePayments(); }
  alert('Payment marked as paid!');
};

// Render Activity Feed
function renderActivityFeed() {
  const activityFeed = <%- JSON.stringify(activities) %>;
  if (activityFeed.length === 0) {
    document.getElementById('activityFeed').innerHTML = '<div style="text-align:center; padding:20px; color:#94a3b8; font-size:11px;">No recent activity</div>';
    return;
  }
  document.getElementById('activityFeed').innerHTML = activityFeed.map(a => `<div class="feed-item"><span class="feed-seat ${a.type}">${a.seat}</span><span class="feed-text">Seat ${a.action}</span><span class="feed-time">${a.time}</span></div>`).join('');
}

// Render Charts
const trafficLabels = ['8am', '9am', '10am', '11am', '12pm', '1pm', '2pm', '3pm', '4pm', '5pm', '6pm', '7pm'];
const trafficData = [12, 24, 38, 52, 68, 84, 72, 58, 42, 28, 18, 10];

// Set Chart.js Defaults
Chart.defaults.font.family = "'Montserrat', sans-serif";
Chart.defaults.color = "#1E2A38";
Chart.defaults.plugins.tooltip.titleFont = { family: "'Poppins', sans-serif", weight: '700' };
Chart.defaults.plugins.tooltip.bodyFont = { family: "'Montserrat', sans-serif" };

function renderTrafficChart() {
  const ctx = document.getElementById('trafficChart').getContext('2d');
  new Chart(ctx, {
    type: 'line',
    data: { labels: trafficLabels, datasets: [{ label: 'Customers', data: trafficData, borderColor: '#CF6322', backgroundColor: 'rgba(207,99,34,.1)', borderWidth: 2.5, fill: true, tension: 0.3, pointBackgroundColor: '#CF6322', pointRadius: 4 }] },
    options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => `${ctx.raw} customers` } } }, scales: { y: { beginAtZero: true } } }
  });
}

function renderSeatChart() {
  const ctx = document.getElementById('seatChart').getContext('2d');
  new Chart(ctx, {
    type: 'doughnut',
    data: { labels: ['Active', 'Idle', 'Inactive', 'Reserved'], datasets: [{ data: [15, 8, 7, 5], backgroundColor: ['#3d7a52', '#CF6322', '#e53e3e', '#8A8636'], borderWidth: 0 }] },
    options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } } } }
  });
}

// Dynamic Seat Map Rendering
async function renderLiveSeatMap() {
  const container = document.getElementById('dynamicSeatMap');
  const viewport = document.getElementById('seatMapViewport');
  if (!container) return;

  try {
    const res = await fetch('/api/layout');
    const data = await res.json();
    let items = data.items || [];
    
    container.innerHTML = '';

    if (items.length === 0) {
      container.innerHTML = '<div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-weight:600;">No layout found.</div>';
      return;
    }

    // Update stat counter
    const chairs = items.filter(i => (i.type === 'chair' || i.type === 'chair-sq'));
    const openChairs = chairs.filter(i => !i.statuses || i.statuses[0] === 'open');
    const statEl = document.getElementById('statAvailable');
    if (statEl) statEl.textContent = `${openChairs.length}/${chairs.length}`;

    items.forEach(item => {
      const el = document.createElement('div');
      el.className = 'fp-item';
      el.style.left = item.x + 'px';
      el.style.top = item.y + 'px';
      el.style.width = item.w + 'px';
      el.style.height = item.h + 'px';
      el.style.zIndex = (item.type === 'chair' || item.type === 'chair-sq') ? 5 : item.type.startsWith('block') ? 2 : 3;

      const visual = document.createElement('div');
      visual.className = 'item-visual';
      visual.style.transform = 'rotate(' + (item.rot || 0) + 'deg)';

      if (item.type === 'chair') {
        visual.classList.add('chair-icon');
        visual.style.webkitMaskImage = 'url(/images/chair.png)';
        visual.style.maskImage = 'url(/images/chair.png)';
        const status = (item.statuses && item.statuses[0]) || 'open';
        
        if (status === 'taken') {
          visual.style.backgroundColor = '#d65c29'; // Orange
        } else if (status === 'reserved') {
          visual.style.backgroundColor = '#1e293b'; // Dark
        } else if (status === 'idle') {
          visual.style.backgroundColor = '#facc15'; // Yellow
        } else {
          visual.style.backgroundColor = '#10b981'; // Green
        }
      } else if (item.type === 'chair-sq') {
        const status = (item.statuses && item.statuses[0]) || 'open';
        const sqColor = status === 'taken' ? '#d65c29' : status === 'reserved' ? '#1e293b' : status === 'idle' ? '#facc15' : '#10b981';
        visual.style.background = sqColor;
        visual.style.borderRadius = '4px';
      } else if (item.type === 'round-table' || item.type === 'rect-table') {
        visual.style.background = item.color || '#fdba74';
        visual.style.border = '1.5px solid #f97316';
        visual.style.borderRadius = item.type === 'round-table' ? '50%' : '6px';
      } else if (item.type === 'room') {
        const status = (item.statuses && item.statuses[0]) || 'open';
        const roomColor = status === 'taken' ? '#d65c29' : status === 'reserved' ? '#1e293b' : item.color;
        visual.style.background = roomColor;
        visual.style.border = '2px solid #16a34a';
        visual.style.borderRadius = '8px';
      } else {
        visual.style.background = item.color || '#cbd5e1';
        visual.style.borderRadius = '4px';
      }
      el.appendChild(visual);

      if (item.label || item.type === 'room') {
        const lbl = document.createElement('span');
        lbl.className = 'item-label';
        if (item.type !== 'chair' && item.type !== 'chair-sq') {
          lbl.classList.add('center');
          const status = (item.statuses && item.statuses[0]) || 'open';
          const isDark = (item.color === '#22c55e' || status === 'taken' || status === 'reserved');
          lbl.style.color = isDark ? '#fff' : '#1e293b';
        }
        lbl.textContent = item.label || (item.type === 'room' ? 'Room' : '');
        el.appendChild(lbl);
      }
      container.appendChild(el);
    });

    const rect = viewport.getBoundingClientRect();
    const vWidth = rect.width || viewport.clientWidth || 600;
    const vHeight = rect.height || viewport.clientHeight || 380;
    const scale = Math.min(vWidth / 800, vHeight / 450) * 0.95;
    container.style.transform = `scale(${scale})`;
    container.style.left = `${(vWidth - (800 * scale)) / 2}px`;
    container.style.top = `${(vHeight - (450 * scale)) / 2}px`;
  } catch (e) {
    console.error(e);
    container.innerHTML = '<div style="color:red; padding:20px;">Error loading live status.</div>';
  }
}

// Polling interval for live status
setInterval(renderLiveSeatMap, 10000);
window.addEventListener('resize', renderLiveSeatMap);

// Initialize All
function renderAll() {
  renderReservationPayments();
  renderWifiPayments();
  renderUpgradePayments();
  renderActivityFeed();
  renderTrafficChart();
  renderSeatChart();
  renderLiveSeatMap();
}

window.onload = renderAll;
</script>

