<%- contentFor('script') %>
<script>
  let reservations = [];
  let wifiRequests = [];
  let upgradeRequests = [];
  let layoutItems = [];
  
  let selectedSeatForWalkin = null;
  let currentMacCount = 1;
  let currentPaymentItem = null;
  let currentPaymentType = null;
  let currentModalContext = null;

  /* api fetchers function */
  async function loadAllData() {
    try {
      const [resRes, wifiRes, planRes, layoutRes] = await Promise.all([
        fetch('/api/reservations'),
        fetch('/api/wifi-extensions'),
        fetch('/api/plan-upgrades'),
        fetch('/api/layout')
      ]);
      
      const resData = await resRes.json();
      const wifiData = await wifiRes.json();
      const planData = await planRes.json();
      const layoutData = await layoutRes.json();
      
      reservations = resData.reservations || [];
      wifiRequests = wifiData.requests || [];
      upgradeRequests = planData.requests || [];
      layoutItems = layoutData.items || [];
      
      renderAll();
    } catch (e) {
      console.error('Error loading data:', e);
    }
  }

  async function updateStatus(type, id, status, paymentStatus = null) {
    let endpoint = '';
    let body = { status };
    if (paymentStatus) body.payment_status = paymentStatus;

    if (type === 'reservation') endpoint = `/api/reservations/${id}/status`;
    else if (type === 'wifi') endpoint = `/api/wifi-extensions/${id}/status`;
    else if (type === 'upgrade') endpoint = `/api/plan-upgrades/${id}/status`;

    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (data.success) {
        loadAllData();
        return true;
      }
      return false;
    } catch (e) {
      console.error(e);
      return false;
    }
  }

  /* rendering function */
  function formatPHP(amount) { return '₱' + (amount || 0).toLocaleString(); }
  function escapeHtml(str) { if (!str) return ''; return String(str).replace(/[&<>]/g, m => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;' }[m] || m)); }
  
  function getStatusBadge(status, paymentStatus) {
    if (status === 'cancelled') return '<span class="badge-unpaid">Cancelled</span>';
    if (status === 'completed') return '<span class="badge-paid">Completed</span>';
    
    if (paymentStatus === 'paid' || status === 'confirmed') return '<span class="badge-paid">Paid / Confirmed</span>';
    if (paymentStatus === 'unpaid') return '<span class="badge-unpaid">Unpaid</span>';
    return '<span class="badge-pending">Pending</span>';
  }
  
  function getPaymentMethodBadge(method) {
    return (method || 'cashier').toLowerCase() === 'gcash' ? '<span class="badge-gcash">GCash</span>' : '<span class="badge-cashier">Cashier</span>';
  }

  function matchesSearch(item, term) { 
    if(!term) return true; 
    const t=term.toLowerCase(); 
    const name = `${item.first_name || ''} ${item.last_name || ''}`.toLowerCase();
    return name.includes(t) || (item.email && item.email.toLowerCase().includes(t)) || (item.seat_label && item.seat_label.toLowerCase().includes(t)); 
  }

  function renderReservations() {
    const filter = document.getElementById('reservationFilter').value;
    const search = document.getElementById('reservationSearch').value;
    let filtered = reservations.filter(r => {
      if (filter === 'all') return true;
      if (filter === 'pending') return r.status === 'pending';
      if (filter === 'paid') return r.payment_status === 'paid' || r.status === 'confirmed';
      if (filter === 'unpaid') return r.payment_status === 'unpaid';
      return true;
    }).filter(r => matchesSearch(r, search));

    const tbody = document.getElementById('reservationBody');
    if(filtered.length === 0) { tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:40px;">No reservations</td></tr>'; return; }
    
    tbody.innerHTML = filtered.map(r => {
      let actionButtons = '';
      if (r.status === 'pending') {
        actionButtons = `<button class="btn-icon btn-success" onclick="openCashierConfirmModal('reservation', ${r.id})" title="Confirm Reservation"><i class="fa-solid fa-check"></i></button>
                         <button class="btn-icon btn-danger" onclick="rejectItem('reservation', ${r.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
      } else if (r.payment_status === 'unpaid') {
        actionButtons = `<button class="btn-icon btn-warning" onclick="openCashierPaymentModal('reservation', ${r.id})" title="Process Payment"><i class="fa-solid fa-credit-card"></i></button>`;
      } else {
        actionButtons = '<span style="color:#94a3b8;">—</span>';
      }
      const date = r.start_time ? new Date(r.start_time).toLocaleDateString() : '—';
      const time = r.start_time ? new Date(r.start_time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : '—';
      return `<tr>
        <td class="td-bold">${escapeHtml(r.first_name)} ${escapeHtml(r.last_name)}</td>
        <td>${escapeHtml(r.email)}</td>
        <td>${r.seat_label || '—'}</td>
        <td>—</td>
        <td>${date}</td>
        <td>${time}</td>
        <td>${formatPHP(r.amount)}</td>
        <td>${getPaymentMethodBadge(r.payment_method)}</td>
        <td>${getStatusBadge(r.status, r.payment_status)}</td>
        <td class="action-group">${actionButtons}</td>
      </tr>`;
    }).join('');
  }
  
  function renderWifi() {
    const filter = document.getElementById('wifiFilter').value;
    const search = document.getElementById('wifiSearch').value;
    let filtered = wifiRequests.filter(w => filter === 'all' || w.status === filter).filter(w => matchesSearch(w, search));
    const tbody = document.getElementById('wifiBody');
    if(filtered.length === 0) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:40px;">No WiFi extension requests</td></tr>'; return; }
    
    tbody.innerHTML = filtered.map(w => {
      let actionButtons = '';
      if (w.status === 'pending') {
        actionButtons = `<button class="btn-icon btn-success" onclick="openCashierConfirmModal('wifi', ${w.id})" title="Confirm Extension"><i class="fa-solid fa-check"></i></button>
                         <button class="btn-icon btn-danger" onclick="rejectItem('wifi', ${w.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
      } else {
        actionButtons = '<span style="color:#94a3b8;">—</span>';
      }
      return `<tr>
        <td class="td-bold">${escapeHtml(w.first_name)} ${escapeHtml(w.last_name)}</td>
        <td>${escapeHtml(w.email)}</td>
        <td>—</td>
        <td>—</td>
        <td>${w.requested_hours} hr(s)</td>
        <td>${formatPHP(w.fee)}</td>
        <td>${getPaymentMethodBadge(w.payment_method)}</td>
        <td>${getStatusBadge(w.status)}</td>
        <td class="action-group">${actionButtons}</td>
      </tr>`;
    }).join('');
  }
  
  function renderUpgrade() {
    const filter = document.getElementById('upgradeFilter').value;
    const search = document.getElementById('upgradeSearch').value;
    let filtered = upgradeRequests.filter(u => filter === 'all' || u.status === filter).filter(u => matchesSearch(u, search));
    const tbody = document.getElementById('upgradeBody');
    if(filtered.length === 0) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:40px;">No plan upgrade requests</td></tr>'; return; }
    
    tbody.innerHTML = filtered.map(u => {
      let actionButtons = '';
      if (u.status === 'pending') {
        actionButtons = `<button class="btn-icon btn-success" onclick="openCashierConfirmModal('upgrade', ${u.id})" title="Confirm Upgrade"><i class="fa-solid fa-check"></i></button>
                         <button class="btn-icon btn-danger" onclick="rejectItem('upgrade', ${u.id})" title="Reject"><i class="fa-solid fa-xmark"></i></button>`;
      } else {
        actionButtons = '<span style="color:#94a3b8;">—</span>';
      }
      return `<tr>
        <td class="td-bold">${escapeHtml(u.first_name)} ${escapeHtml(u.last_name)}</td>
        <td>${escapeHtml(u.email)}</td>
        <td>—</td>
        <td>${u.current_plan || '—'}</td>
        <td>${u.requested_plan}</td>
        <td>${formatPHP(u.fee)}</td>
        <td>${getPaymentMethodBadge(u.payment_method)}</td>
        <td>${getStatusBadge(u.status)}</td>
        <td class="action-group">${actionButtons}</td>
      </tr>`;
    }).join('');
  }

  /* seat layout modal function */
  function renderModalSeatLayout() {
    const container = document.getElementById('modalSeatLayout');
    if (!container) return;

    const chairs = layoutItems.filter(i => i.type === 'chair' || i.type === 'chair-sq');
    
    if (chairs.length === 0) {
      container.innerHTML = '<div style="text-align:center;padding:20px;color:#94a3b8;">No seats found in layout.</div>';
      return;
    }

    container.innerHTML = `
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(60px, 1fr)); gap:10px;">
        ${chairs.map(c => {
          const status = (c.statuses && c.statuses[0]) || 'open';
          const isSelected = selectedSeatForWalkin === c.id;
          let statusClass = 'available';
          if (status === 'taken') statusClass = 'occupied';
          else if (status === 'reserved') statusClass = 'reserved';
          else if (status === 'idle') statusClass = 'idle';

          return `
            <div class="modal-seat ${statusClass} ${isSelected ? 'selected' : ''}" 
                 onclick="selectSeatForWalkin(${c.id}, '${c.label || 'Seat'}', '${status}')">
              <span>${c.label || 'Seat'}</span>
              <span>${status === 'open' ? 'Free' : status.charAt(0).toUpperCase() + status.slice(1,3)}</span>
            </div>
          `;
        }).join('')}
      </div>
    `;
  }

  window.selectSeatForWalkin = function(id, label, status) {
    if (status !== 'open') {
      alert('This seat is already occupied or reserved.');
      return;
    }
    selectedSeatForWalkin = id;
    document.getElementById('selectedSeat').value = id;
    document.getElementById('selectedSeatDisplay').innerHTML = `Selected seat: <strong>${label}</strong>`;
    renderModalSeatLayout();
  };

  /* rfid & mac function */
  function simulateRFIDScan() {
    const mockRFID = "RFID_" + Math.random().toString(36).substring(2, 10).toUpperCase();
    document.getElementById('wi-rfid').value = mockRFID;
    alert(`✅ RFID Scanned Successfully!\nUID: ${mockRFID}`);
  }

  function updateMacFieldsUI() {
    const container = document.getElementById('macFieldsContainer');
    container.innerHTML = '<div class="mac-input-group"><input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" style="display:none;"><i class="fa-solid fa-minus"></i></button></div>';
    currentMacCount = 1;
    document.getElementById('addMacBtn').style.display = 'inline-flex';
  }

  function addNewMacField() {
    if (currentMacCount >= 3) { alert("Maximum 3 MAC addresses allowed."); return; }
    const container = document.getElementById('macFieldsContainer');
    const div = document.createElement('div');
    div.className = 'mac-input-group';
    div.innerHTML = `<input type="text" class="mac-input" placeholder="AA:BB:CC:DD:EE:FF"><button type="button" class="remove-mac-btn" onclick="this.parentElement.remove(); currentMacCount--; document.getElementById('addMacBtn').style.display = 'inline-flex';"><i class="fa-solid fa-minus"></i></button>`;
    container.appendChild(div);
    currentMacCount++;
    if (currentMacCount >= 3) document.getElementById('addMacBtn').style.display = 'none';
  }

  /* payment confirmation function */
  function openCashierConfirmModal(type, id) {
    let item, amount, detailText, label;
    if (type === 'reservation') { 
      item = reservations.find(r => r.id === id); 
      amount = item.amount; 
      detailText = `Reservation`;
      label = item.seat_label;
    } else if (type === 'wifi') { 
      item = wifiRequests.find(w => w.id === id); 
      amount = item.fee; 
      detailText = `${item.requested_hours} hour(s) extension`;
      label = 'WiFi';
    } else { 
      item = upgradeRequests.find(u => u.id === id); 
      amount = item.fee; 
      detailText = `${item.current_plan} → ${item.requested_plan}`;
      label = 'Upgrade';
    }
    
    if (!item) return;
    currentPaymentItem = item;
    currentPaymentType = type;
    currentModalContext = 'confirm';
    
    const confirmBtn = document.getElementById('confirmPaymentFinalBtn');
    confirmBtn.textContent = 'Confirm Request';
    
    document.getElementById('paymentConfirmBody').innerHTML = `
      <div class="payment-info-card">
        <div class="method-header"><i class="fa-solid fa-cash-register cashier-icon"></i><h3 style="margin:0;">Confirm Request</h3></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Customer:</span><span>${escapeHtml(item.first_name)} ${escapeHtml(item.last_name)}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Details:</span><span>${detailText}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Amount:</span><span class="payment-amount-large" style="margin:0;">${formatPHP(amount)}</span></div>
        <div style="background:#fef3c7; padding:12px; border-radius:12px; margin-top:10px;"><i class="fa-solid fa-info-circle"></i> Confirming this will move it to UNPAID status.</div>
      </div>
    `;
    openModal('paymentConfirmModal');
  }

  function openCashierPaymentModal(type, id) {
    let item, amount;
    if (type === 'reservation') { item = reservations.find(r => r.id === id); amount = item.amount; }
    else if (type === 'wifi') { item = wifiRequests.find(w => w.id === id); amount = item.fee; }
    else { item = upgradeRequests.find(u => u.id === id); amount = item.fee; }
    
    if (!item) return;
    currentPaymentItem = item;
    currentPaymentType = type;
    currentModalContext = 'payment';
    
    const confirmBtn = document.getElementById('confirmPaymentFinalBtn');
    confirmBtn.textContent = 'Confirm Payment';
    
    document.getElementById('paymentConfirmBody').innerHTML = `
      <div class="payment-info-card">
        <div class="method-header"><i class="fa-solid fa-cash-register cashier-icon"></i><h3 style="margin:0;">Process Payment</h3></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Customer:</span><span>${escapeHtml(item.first_name)} ${escapeHtml(item.last_name)}</span></div>
        <div class="customer-detail-row"><span class="customer-detail-label">Amount:</span><span class="payment-amount-large" style="margin:0;">${formatPHP(amount)}</span></div>
        <div style="background:#dcfce7; padding:12px; border-radius:12px; margin-top:10px;"><i class="fa-solid fa-circle-check"></i> Collect cash from customer and click confirm.</div>
      </div>
    `;
    openModal('paymentConfirmModal');
  }

  async function finalizePaymentConfirmation() {
    if (!currentPaymentItem) return;
    
    let success = false;
    if (currentModalContext === 'confirm') {
      success = await updateStatus(currentPaymentType, currentPaymentItem.id, 'confirmed', 'paid');
    } else if (currentModalContext === 'payment') {
      success = await updateStatus(currentPaymentType, currentPaymentItem.id, 'confirmed', 'paid');
    }

    if (success) {
      closeModal('paymentConfirmModal');
      currentPaymentItem = null;
    } else {
      alert('Failed to update status. Please try again.');
    }
  }

  async function rejectItem(type, id) {
    if (confirm(`Are you sure you want to reject this ${type}?`)) {
      const success = await updateStatus(type, id, 'cancelled');
      if (!success) alert('Failed to reject item.');
    }
  }

  /* walkin handler function */
  async function addWalkin() {
    const email = document.getElementById('wi-email').value.trim();
    const firstName = document.getElementById('wi-firstname').value.trim();
    const lastName = document.getElementById('wi-lastname').value.trim();
    const elementId = selectedSeatForWalkin;
    const hours = parseFloat(document.getElementById('wi-hours').value) || 2;
    
    if (!firstName || !lastName || !email || !elementId) {
      alert("Please fill required fields and select a seat.");
      return;
    }

    try {
      /* 1. add/find user function */
      const userRes = await fetch('/api/users/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ firstName, lastName, email, role: 'customer', type: document.getElementById('wi-type').value })
      });
      const userData = await userRes.json();
      
      if (!userData.success && !userData.userId) {
        alert('Error creating user.');
        return;
      }

      const userId = userData.userId;

      /* 2. start session function */
      const sessionRes = await fetch('/api/session/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, elementId, hours })
      });
      const sessionData = await sessionRes.json();

      if (sessionData.success) {
        alert('Walk-in customer added successfully!');
        closeModal('walkinModal');
        loadAllData();
      } else {
        alert('Error starting session.');
      }
    } catch (e) {
      console.error(e);
      alert('Network error.');
    }
  }

  /* initialization function */
  function renderAll() {
    renderReservations();
    renderWifi();
    renderUpgrade();
  }

  function filterReservations() { renderReservations(); }
  function filterWifi() { renderWifi(); }
  function filterUpgrade() { renderUpgrade(); }

  function openSidebar() { document.getElementById('sidebar').classList.add('mobile-open'); document.getElementById('mobileOverlay').classList.add('show'); }
  function closeSidebar() { document.getElementById('sidebar').classList.remove('mobile-open'); document.getElementById('mobileOverlay').classList.remove('show'); }
  
  function openModal(id) { 
    document.getElementById(id).classList.add('open'); 
    if(id === 'walkinModal') { 
      renderModalSeatLayout(); 
      updateMacFieldsUI(); 
      selectedSeatForWalkin = null; 
      document.getElementById('selectedSeatDisplay').innerHTML = "No seat selected"; 
    } 
  }
  
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }
  function switchTab(event, tabId) { 
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active')); 
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active')); 
    document.getElementById(tabId).classList.add('active'); 
    event.currentTarget.classList.add('active'); 
  }

  document.getElementById('addMacBtn').addEventListener('click', addNewMacField);
  
  /* initial load function */
  loadAllData();
  /* autorefresh every 30 seconds function */
  setInterval(loadAllData, 30000);
</script>
