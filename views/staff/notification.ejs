<!-- title passed to layout function -->
<% locals.title = 'The Last Muster | Staff' %>

<%- contentFor('style') %>
<style>

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .45);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 16px;
    }

    .modal-overlay.open {
      display: flex;
    }

    .modal {
      background: var(--white);
      border-radius: var(--radius);
      padding: 28px;
      width: 100%;
      max-width: 480px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
      display: flex;
      flex-direction: column;
      gap: 16px;
      max-height: 90vh;
      overflow-y: auto;
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .modal-title {
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 700;
    }

    .modal-close {
      background: none;
      border: none;
      font-size: 1.3rem;
      color: var(--text-sm);
      cursor: pointer;
    }

    .modal-body {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .notif-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
    }

    .notif-item {
      border-radius: 12px;
      padding: 16px 20px;
      margin-bottom: 10px;
      border-left: 4px solid var(--orange);
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
    }

    .notif-orange {
      background: #fff7f3;
      border-left-color: var(--orange);
    }

    .notif-green {
      background: #f0fdf4;
      border-left-color: var(--green);
    }

    .notif-blue {
      background: #eff6ff;
      border-left-color: #3498db;
    }

    .notif-read {
      background: #f8fafc;
      border-left-color: var(--border);
      opacity: .7;
    }

    .notif-title {
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      font-size: .88rem;
      margin-bottom: 4px;
    }

    .notif-body {
      font-size: 11.5px;
      color: var(--text-md);
      line-height: 1.5;
      margin-bottom: 8px;
    }

    .notif-time {
      font-size: 10.5px;
      color: var(--text-sm);
    }

    .notif-actions {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
      flex-shrink: 0;
    }

    .mark-btn {
      background: none;
      border: none;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Montserrat', sans-serif;
      white-space: nowrap;
    }

    .mark-btn:hover {
      text-decoration: underline;
    }
  
</style>

<div class="app">
    <%- include('../partials/staff_sidebar', { active: '' }) %>
    <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>
    <main class="content">
      <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>

      <div class="page-header">
        <h1 class="page-title">Notification</h1>
        <div style="display:flex;gap:8px">

          <button class="btn btn-ghost" onclick="markAllRead()"><i class="fa-solid fa-check-double"></i> Mark all
            read</button>
        </div>
      </div>
      <div class="card" id="notifList">
        <div class="notif-item notif-orange" id="n1">
          <div>
            <div class="notif-title">Reservation Confirmed</div>
            <div class="notif-body">Staff Zoro confirmed reservation for customer Sanji.</div>
            <div class="notif-time"><i class="fa-solid fa-clock"></i> Apr 14, 06:15 PM</div>
          </div>
          <div class="notif-actions"><button class="mark-btn" style="color:var(--orange)" onclick="markRead('n1')">Mark
              as read</button></div>
        </div>
        <div class="notif-item notif-green" id="n2">
          <div>
            <div class="notif-title">New Walk-in Customer</div>
            <div class="notif-body">Walk-in customer checked in at Seat RT2-S1.</div>
            <div class="notif-time"><i class="fa-solid fa-clock"></i> Apr 14, 04:00 PM</div>
          </div>
          <div class="notif-actions"><button class="mark-btn" style="color:var(--green)" onclick="markRead('n2')">Mark
              as read</button></div>
        </div>
        <div class="notif-item notif-blue" id="n3">
          <div>
            <div class="notif-title">WiFi Extension Requested</div>
            <div class="notif-body">Customer Monkey D. Luffy requested a 2-hour WiFi extension.</div>
            <div class="notif-time"><i class="fa-solid fa-clock"></i> Apr 14, 02:30 PM</div>
          </div>
          <div class="notif-actions"><button class="mark-btn" style="color:#3498db" onclick="markRead('n3')">Mark as
              read</button></div>
        </div>
        <div class="notif-item notif-read" id="n4">
          <div>
            <div class="notif-title">Plan Upgrade Approved</div>
            <div class="notif-body">Nami Catburglar's plan upgrade to Premium was approved.</div>
            <div class="notif-time"><i class="fa-solid fa-clock"></i> Apr 13, 10:00 AM</div>
          </div>
          <div class="notif-actions"><button class="mark-btn" style="color:var(--text-sm)">Read</button></div>
        </div>
      </div>


  </div>
  </main>
  </div>

<%- contentFor('script') %>
<script>

    function openSidebar() {
      document.getElementById('sidebar').classList.add('mobile-open');
      document.getElementById('mobileOverlay').classList.add('show');
    }
    function closeSidebar() {
      document.getElementById('sidebar').classList.remove('mobile-open');
      document.getElementById('mobileOverlay').classList.remove('show');
    }

    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }

    function markRead(notifId) {
      const notif = document.getElementById(notifId);
      if (notif) {
        notif.classList.remove('notif-orange', 'notif-green', 'notif-blue');
        notif.classList.add('notif-read');
        const btn = notif.querySelector('.mark-btn');
        if (btn) {
          btn.textContent = 'Read';
          btn.style.color = 'var(--text-sm)';
          btn.onclick = null;
        }
      }
    }

    function markAllRead() {
      const notifs = ['n1', 'n2', 'n3', 'n4'];
      notifs.forEach(id => {
        const notif = document.getElementById(id);
        if (notif && !notif.classList.contains('notif-read')) {
          notif.classList.remove('notif-orange', 'notif-green', 'notif-blue');
          notif.classList.add('notif-read');
          const btn = notif.querySelector('.mark-btn');
          if (btn) {
            btn.textContent = 'Read';
            btn.style.color = 'var(--text-sm)';
            btn.onclick = null;
          }
        }
      });
    }

    function addAnnouncement() {
      alert('Announcement feature coming soon');
      closeModal('announcementModal');
    }

    function createEvent() {
      const name = document.getElementById('ev-name').value.trim(),
        date = document.getElementById('ev-date').value,
        loc = document.getElementById('ev-loc').value;

      if (!name || !date) {
        alert('Name and date are required');
        return;
      }

      const time = document.getElementById('ev-time').value || '';
      const div = document.createElement('div');
      div.className = 'event-item';

      div.innerHTML = `
    <div class="event-name">${name}</div>
    <div class="event-meta">
      <i class="fa-solid fa-clock"></i> ${date}${time ? ' ' + time : ''} · ${loc}
    </div>
    <div class="event-actions">
      <button class="btn btn-ghost btn-sm" onclick="editEvent(this)"><i class="fa-solid fa-pen"></i></button>
      <button class="btn btn-danger btn-sm" onclick="deleteEvent(this)"><i class="fa-solid fa-trash"></i></button>
    </div>
  `;

      document.getElementById('upcomingList').prepend(div);

      alert(`Event "${name}" created`);
      closeModal('createEventModal');

      ['ev-name', 'ev-date', 'ev-time', 'ev-desc']
        .forEach(id => document.getElementById(id).value = '');
    }

    function deleteEvent(btn) {
      if (confirm('Delete this event?')) {
        btn.closest('.event-item').remove();
        alert('Event deleted');
      }
    }
    function editEvent() { alert('Edit feature coming soon'); }

  </script>

