          <div class="modal-body" id="reservationDetailBody"></div>
          <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('reservationDetailModal')">Close</button></div>
        </div>
      </div>
      
      <!-- Event Detail Modal -->
      <div class="modal-overlay" id="eventDetailModal">
        <div class="modal"><div class="modal-header"><div class="modal-title"><i class="fa-solid fa-calendar-star"></i> Event Details</div><button class="modal-close" onclick="closeModal('eventDetailModal')">&times;</button></div>
          <div class="modal-body" id="eventDetailBody"></div>
