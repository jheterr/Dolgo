          <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-calendar-day"></i> Daily Schedule</div>
            <button class="modal-close" onclick="closeModal('scheduleModal')">&times;</button>
          </div>
          <div class="modal-body" id="scheduleModalBody"></div>
          <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeModal('scheduleModal')">Close</button>
          </div>
        </div>
      </div>
      
      <!-- Time Slot Customers Modal -->
      <div class="modal-overlay" id="timeSlotModal">
        <div class="modal">
          <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-users"></i> Customers at</div>
            <button class="modal-close" onclick="closeModal('timeSlotModal')">&times;</button>
          </div>
          <div class="modal-body" id="timeSlotModalBody"></div>
          <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeModal('timeSlotModal')">Close</button>
          </div>
        </div>
      </div>
      
      <!-- Edit Reservation Image Modal -->
      <div class="modal-overlay" id="editSeatImageModal">
        <div class="modal"><div class="modal-header"><div class="modal-title"><i class="fa-solid fa-image"></i> Change Seat Image</div><button class="modal-close" onclick="closeModal('editSeatImageModal')">&times;</button></div>
          <div class="modal-body">
            <div class="form-group"><label class="form-label">Upload New Image for Seat</label>
              <input type="file" id="seat-image-file" accept="image/*" style="display:none;">
              <div class="upload-label" onclick="document.getElementById('seat-image-file').click()"><i class="fa-solid fa-upload"></i> Choose Image</div>
