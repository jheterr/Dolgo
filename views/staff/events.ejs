<%- contentFor('script') %>
<script>
let eventCustomBanners = JSON.parse(localStorage.getItem('eventCustomBanners') || '{}');

function setSeatImage(seatId, imageData) {
  // Now handled via API
}


function openSidebar(){
  document.getElementById('sidebar').classList.add('mobile-open');
  document.getElementById('mobileOverlay').classList.add('show');
}

function closeSidebar(){
  document.getElementById('sidebar').classList.remove('mobile-open');
  document.getElementById('mobileOverlay').classList.remove('show');
}

function openModal(id){
  document.getElementById(id).classList.add('open');
}

function closeModal(id){
  document.getElementById(id).classList.remove('open');
}

let yr=2026,mo=3;
const MN=['January','February','March','April','May','June','July','August','September','October','November','December'];

// Default seat colors
const defaultSeatColors = {
  "A3": "#CF6322", "B2": "#8A8636", "C5": "#4A7C59", "C1": "#CF6322",
  "A7": "#8A8636", "A2": "#4A7C59", "D3": "#CF6322", "B4": "#8A8636",
  "D6": "#4A7C59", "B3": "#CF6322", "C3": "#8A8636", "A5": "#4A7C59"
};

function getDefaultSeatColor(seatId){
  return defaultSeatColors[seatId] || "#CF6322";
}

// Time slots from 8am to 11pm
const timeSlots = [
  "8:00 AM", "9:00 AM", "10:00 AM", "11:00 AM", "12:00 PM",
  "1:00 PM", "2:00 PM", "3:00 PM", "4:00 PM", "5:00 PM",
  "6:00 PM", "7:00 PM", "8:00 PM", "9:00 PM", "10:00 PM", "11:00 PM"
];

// Function to convert time string to hour for comparison
function getTimeHour(timeStr) {
  if (!timeStr) return 0;
  // If timeStr is "08:00 AM"
  if (timeStr.includes('AM') || timeStr.includes('PM')) {
      const hourMap = {
        "08:00 AM": 8, "09:00 AM": 9, "10:00 AM": 10, "11:00 AM": 11,
        "12:00 PM": 12, "01:00 PM": 13, "02:00 PM": 14, "03:00 PM": 15,
        "04:00 PM": 16, "05:00 PM": 17, "06:00 PM": 18, "07:00 PM": 19,
        "08:00 PM": 20, "09:00 PM": 21, "10:00 PM": 22, "11:00 PM": 23
      };
      return hourMap[timeStr] || 0;
  }
  // If timeStr is "HH:mm" or "HH:mm:ss"
  return parseInt(timeStr.split(':')[0]);
}

// Get customers for a specific time slot (confirmed only)
function getCustomersForTimeSlot(date, timeSlot) {
  const resOnDate = customerReservations.filter(r => {
      const d = new Date(r.start_time).toISOString().split('T')[0];
      return d === date && r.status === 'confirmed';
  });
  const slotHour = getTimeHour(timeSlot);
  return resOnDate.filter(r => {
      const h = new Date(r.start_time).getHours();
      return h === slotHour;
  });
}

// Show time slot customers modal
function showTimeSlotCustomers(dateStr, timeSlot, customers) {
  const formattedDate = new Date(dateStr).toLocaleDateString('en-US', { 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
  });
  
  let modalHtml = `<div class="time-slot-title">${timeSlot} - ${formattedDate}</div>`;
  modalHtml += `<div class="time-slot-customers-list">`;
  
  if (customers.length > 0) {
    customers.forEach(c => {
      modalHtml += `
        <div class="customer-time-item" onclick="showReservationDetail(${JSON.stringify(c).replace(/"/g, '&quot;')})">
          <div class="customer-time-name">${escapeHtml(c.customerName)}</div>
          <div><span class="customer-time-seat">Seat ${c.seat}</span></div>
        </div>
      `;
    });
  } else {
    modalHtml += `<div style="text-align:center;padding:30px;color:#94a3b8;">No confirmed reservations at this time</div>`;
  }
  
  modalHtml += `</div>`;
  document.getElementById('timeSlotModalBody').innerHTML = modalHtml;
  openModal('timeSlotModal');
}

// Show schedule modal for clicked date
let events = [];
let customerReservations = [];

async function loadAllData() {
    try {
        const [evRes, revRes] = await Promise.all([
            fetch('/api/events').then(res => res.json()),
            fetch('/api/reservations').then(res => res.json())
        ]);
        events = evRes.events || [];
        customerReservations = revRes.reservations || [];
        
        renderCal();
        switchView();
    } catch (e) { console.error('Error loading events:', e); }
}

// Polling for updates
setInterval(loadAllData, 10000);
loadAllData();

function getEventsByDate(dateStr){ 
    return events.filter(e => new Date(e.event_date).toISOString().split('T')[0] === dateStr); 
}
function getReservationsByDate(dateStr){ 
    return customerReservations.filter(r => new Date(r.start_time).toISOString().split('T')[0] === dateStr); 
}

function isToday(dateStr){
  const today = new Date();
  const todayStr = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
  return dateStr === todayStr;
}
function getTodayReservations(){
  const today = new Date();
  const todayStr = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
  return customerReservations.filter(r => r.date === todayStr);
}
function getUpcomingReservations(){
  const today = new Date();
  const todayStr = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
  return customerReservations.filter(r => r.date > todayStr);
}
function getUpcomingEvents(){
  const today = new Date();
  const todayStr = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
  return events.filter(e => e.date >= todayStr);
}
function getPastEvents(){
  const today = new Date();
  const todayStr = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
  return events.filter(e => e.date < todayStr);
}

function sortReservations(items){
  const sortType = document.getElementById('sortSelect').value;
  if(sortType === 'date_asc') return [...items].sort((a,b)=>a.date.localeCompare(b.date));
  if(sortType === 'date_desc') return [...items].sort((a,b)=>b.date.localeCompare(a.date));
  if(sortType === 'name_asc') return [...items].sort((a,b)=>a.customerName.localeCompare(b.customerName));
  if(sortType === 'name_desc') return [...items].sort((a,b)=>b.customerName.localeCompare(a.customerName));
  return items;
}
function sortEvents(items){
  const sortType = document.getElementById('sortSelect').value;
  if(sortType === 'date_asc') return [...items].sort((a,b)=>a.date.localeCompare(b.date));
  if(sortType === 'date_desc') return [...items].sort((a,b)=>b.date.localeCompare(a.date));
  if(sortType === 'name_asc') return [...items].sort((a,b)=>a.name.localeCompare(b.name));
  if(sortType === 'name_desc') return [...items].sort((a,b)=>b.name.localeCompare(a.name));
  return items;
}

function switchView(){
  const viewType = document.getElementById('viewSelect').value;
  const container = document.getElementById('cardsContainer');
  let items = [], isEvent = false;
  switch(viewType){
    case 'todayReservations': items = sortReservations(getTodayReservations()); break;
    case 'upcomingReservations': items = sortReservations(getUpcomingReservations()); break;
    case 'upcomingEvents': items = sortEvents(getUpcomingEvents()); isEvent = true; break;
    case 'pastEvents': items = sortEvents(getPastEvents()); isEvent = true; break;
    default: items = sortReservations(getTodayReservations());
  }
  if(items.length === 0){ container.innerHTML = `<div class="empty-state"><i class="fa-regular fa-folder-open"></i><p>No items to display</p></div>`; return; }
  if(isEvent){
    container.innerHTML = items.map(ev => {
      const d = new Date(ev.event_date);
      const dateStr = d.toLocaleDateString();
      const timeStr = d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
      return `
        <div class="event-card" onclick="showEventDetail(${JSON.stringify(ev).replace(/"/g, '&quot;')})">
          <div class="card-banner" style="background-image: url('${ev.image || 'data:image/svg+xml,%3Csvg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 200 100\'%3E%3Crect width=\'200\' height=\'100\' fill=\'%23CF6322\'/%3E%3Ctext x=\'100\' y=\'55\' text-anchor=\'middle\' fill=\'white\' font-size=\'14\' font-weight=\'bold\'%3E'+ev.title.substring(0,15)+'%3C/text%3E%3C/svg%3E'}'); background-size: cover;">
            <div class="card-badge">${viewType === 'upcomingEvents' ? 'Upcoming' : 'Past'}</div>
          </div>
          <div class="card-content">
            <div class="card-title">${escapeHtml(ev.title)}</div>
            <div class="card-meta"><span><i class="fa-regular fa-calendar"></i> ${dateStr}</span><span><i class="fa-regular fa-clock"></i> ${timeStr}</span><span class="card-location"><i class="fa-solid fa-location-dot"></i> ${ev.location}</span></div>
            <div class="card-description">${escapeHtml((ev.description || '').substring(0,80))}${ev.description && ev.description.length>80?'...':''}</div>
          </div>
        </div>
      `;
    }).join('');
  } else {
    container.innerHTML = items.map(r => {
      const name = `${r.first_name} ${r.last_name}`;
      const d = new Date(r.start_time);
      const dateStr = d.toLocaleDateString();
      const timeStr = d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
      const duration = Math.round((new Date(r.end_time) - d) / (1000 * 60 * 60));
      return `
        <div class="event-card" onclick="showReservationDetail(${JSON.stringify(r).replace(/"/g, '&quot;')})">
          <div class="card-banner" style="background-image: url('${r.seat_image || `data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='${getDefaultSeatColor(r.seat_label).replace('#','%23')}'/%3E%3Ctext x='50' y='55' text-anchor='middle' fill='white' font-size='12' font-weight='bold'%3ESeat ${r.seat_label}%3C/text%3E%3C/svg%3E`}'); background-size: cover;">
            <div class="card-badge" style="background:#8A8636;">${r.status === 'confirmed' ? 'Confirmed' : 'Pending'}</div>
          </div>
          <div class="card-content">
            <div class="card-title">${escapeHtml(name)}</div>
            <div class="card-meta"><span><i class="fa-regular fa-calendar"></i> ${dateStr}</span><span><i class="fa-regular fa-clock"></i> ${timeStr}</span><span class="card-location"><i class="fa-solid fa-chair"></i> Seat ${r.seat_label || 'N/A'}</span></div>
            <div class="card-description">${duration} hour(s) • ${r.status === 'confirmed' ? 'Confirmed reservation' : 'Awaiting payment'}</div>
          </div>
        </div>
      `;
    }).join('');
  }
}

function showReservationDetail(reservation){
  const modalBody = document.getElementById('reservationDetailBody');
  const name = `${reservation.first_name} ${reservation.last_name}`;
  const d = new Date(reservation.start_time);
  const dateStr = d.toLocaleDateString();
  const timeStr = d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
  const duration = Math.round((new Date(reservation.end_time) - d) / (1000 * 60 * 60));
  
  modalBody.innerHTML = `
    <div style="text-align:center;margin-bottom:15px;">
      <div style="position:relative;">
        <img src="${reservation.seat_image || `data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 100'%3E%3Crect width='200' height='100' fill='${getDefaultSeatColor(reservation.seat_label).replace('#','%23')}'/%3E%3Ctext x='100' y='55' text-anchor='middle' fill='white' font-size='16' font-weight='bold'%3ESeat ${reservation.seat_label || 'N/A'}%3C/text%3E%3C/svg%3E`}" style="width:100%;max-width:300px;border-radius:12px;object-fit:cover;">
        <button onclick="event.stopPropagation(); openSeatImageEditor('${reservation.seat_label}', '${reservation.seat_image || ''}')" style="position:absolute;bottom:10px;right:10px;background:#CF6322;color:white;border:none;border-radius:20px;padding:4px 12px;cursor:pointer;font-size:11px;"><i class="fa-solid fa-camera"></i> Change Image</button>
      </div>
    </div>
    <div class="reservation-detail-row"><span class="reservation-label">Customer Name:</span><span class="reservation-value">${escapeHtml(name)}</span></div>
    <div class="reservation-detail-row"><span class="reservation-label">Email:</span><span class="reservation-value">${escapeHtml(reservation.email)}</span></div>
    <div class="reservation-detail-row"><span class="reservation-label">Phone:</span><span class="reservation-value">${escapeHtml(reservation.phone || 'N/A')}</span></div>
    <div class="reservation-detail-row"><span class="reservation-label">Date:</span><span class="reservation-value">${dateStr}</span></div>
    <div class="reservation-detail-row"><span class="reservation-label">Time:</span><span class="reservation-value">${timeStr}</span></div>
    <div class="reservation-detail-row"><span class="reservation-label">Seat:</span><span class="reservation-value">${reservation.seat_label || 'N/A'}</span></div>
    <div class="reservation-detail-row"><span class="reservation-label">Hours:</span><span class="reservation-value">${duration} hour(s)</span></div>
    <div class="reservation-detail-row"><span class="reservation-label">Status:</span><span class="reservation-value"><span class="badge ${reservation.status === 'confirmed' ? 'badge-green' : 'badge-pending-payment'}">${reservation.status === 'confirmed' ? 'Confirmed' : 'Pending'}</span></span></div>`;
  openModal('reservationDetailModal');
}

let currentSeatForImage = null;
function openSeatImageEditor(seatId, currentImg){
  currentSeatForImage = seatId;
  document.getElementById('seat-image-preview').className = 'image-preview';
  if(currentImg){
    document.getElementById('seat-image-preview').src = currentImg;
    document.getElementById('seat-image-preview').classList.add('show');
  } else {
    document.getElementById('seat-image-preview').classList.remove('show');
  }
  openModal('editSeatImageModal');
}

function saveSeatImage(){
  const fileInput = document.getElementById('seat-image-file');
  if(fileInput.files && fileInput.files[0]){
    const reader = new FileReader();
    reader.onload = async function(e){
      const imageData = e.target.result;
      try {
          const res = await fetch('/api/floor-elements/image', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ label: currentSeatForImage, image: imageData })
          });
          const data = await res.json();
          if(data.success) {
              closeModal('editSeatImageModal');
              loadAllData();
          }
      } catch(err) { console.error(err); }
    };
    reader.readAsDataURL(fileInput.files[0]);
  } else {
    alert('Please select an image first');
  }
}

document.getElementById('seat-image-file').addEventListener('change', function(e){
  if(e.target.files && e.target.files[0]){
    const reader = new FileReader();
    reader.onload = function(ev){
      document.getElementById('seat-image-preview').src = ev.target.result;
      document.getElementById('seat-image-preview').classList.add('show');
    };
    reader.readAsDataURL(e.target.files[0]);
  }
});

function showEventDetail(event){
  const modalBody = document.getElementById('eventDetailBody');
  const d = new Date(event.event_date);
  const dateStr = d.toLocaleDateString();
  const timeStr = d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});

  modalBody.innerHTML = `
    <div style="text-align:center;margin-bottom:15px;">
      <img src="${event.image || 'data:image/svg+xml,%3Csvg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 200 100\'%3E%3Crect width=\'200\' height=\'100\' fill=\'%23CF6322\'/%3E%3Ctext x=\'100\' y=\'55\' text-anchor=\'middle\' fill=\'white\' font-size=\'14\' font-weight=\'bold\'%3E'+event.title.substring(0,20)+'%3C/text%3E%3C/svg%3E'}" style="width:100%;border-radius:12px;object-fit:cover;max-height:200px;">
    </div>
    <div class="event-detail-row"><span class="reservation-label">Event Name:</span><span class="reservation-value">${escapeHtml(event.title)}</span></div>
    <div class="event-detail-row"><span class="reservation-label">Date:</span><span class="reservation-value">${dateStr}</span></div>
    <div class="event-detail-row"><span class="reservation-label">Time:</span><span class="reservation-value">${timeStr}</span></div>
    <div class="event-detail-row"><span class="reservation-label">Location:</span><span class="reservation-value">${event.location}</span></div>
    <div class="event-detail-row"><span class="reservation-label">Price:</span><span class="reservation-value">₱${event.price}</span></div>
    <div class="event-detail-row"><span class="reservation-label">Description:</span><span class="reservation-value">${escapeHtml(event.description)}</span></div>`;
  openModal('eventDetailModal');
}

function renderCal(){
  document.getElementById('calTitle').textContent=MN[mo]+' '+yr;
  const g=document.getElementById('calGrid');
  g.innerHTML=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(d=>`<div class="cal-head">${d}</div>`).join('');
  const first=new Date(yr,mo,1).getDay(), days=new Date(yr,mo+1,0).getDate();
  for(let i=0;i<first;i++) g.innerHTML+='<div class="cal-day empty"></div>';
  for(let d=1;d<=days;d++){
    const dateStr = `${yr}-${String(mo+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isTodayFlag = isToday(dateStr);
    const dayEvents = events.filter(e => e.date === dateStr);
    const dayReservations = customerReservations.filter(r => r.date === dateStr && r.status === 'confirmed');
    let tagsHtml = '';
    dayEvents.slice(0,1).forEach(e => { tagsHtml += `<div class="cal-tag cal-tag-event" title="${e.title}">📅 ${e.title.length>12?e.title.substring(0,10)+'…':e.title}</div>`; });
    if(dayEvents.length > 1) tagsHtml += `<div class="cal-tag cal-tag-event">+${dayEvents.length-1} more</div>`;
    dayReservations.slice(0,1).forEach(r => { 
      const name = `${r.first_name} ${r.last_name}`;
      tagsHtml += `<div class="cal-tag cal-tag-reservation" title="${name} - Seat ${r.seat_label}">📖 ${name.length>12?name.substring(0,10)+'…':name}</div>`; 
    });
    if(dayReservations.length > 1) tagsHtml += `<div class="cal-tag cal-tag-reservation">+${dayReservations.length-1} more</div>`;
    g.innerHTML+=`<div class="cal-day${isTodayFlag?' today':''}" data-date="${dateStr}"><strong>${d}</strong>${tagsHtml}</div>`;
  }
  document.querySelectorAll('.cal-day:not(.empty)').forEach(day => {
    day.addEventListener('click', () => {
      const date = day.getAttribute('data-date');
      showScheduleModal(date);
    });
  });
}

function changeMonth(dir){
  mo+=dir;
  if(mo>11){mo=0;yr++;}
  if(mo<0){mo=11;yr--;}
  renderCal();
}

function escapeHtml(str){ if(!str)return ''; return String(str).replace(/[&<>]/g,function(m){if(m==='&')return '&amp;';if(m==='<')return '&lt;';if(m==='>')return '&gt;';return m;}); }

renderCal(); switchView();
</script>

