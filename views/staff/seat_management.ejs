<!-- Title passed to layout -->
<% locals.title = 'The Last Muster | Staff' %>

<%- contentFor('style') %>
<style>

.seat-page { display:grid; grid-template-columns:1fr 320px; gap:20px; }
  .right-col { display:flex; flex-direction:column; gap:16px; }
  .transfer-card { background:#fff5f5; border-radius:var(--radius); padding:18px; border-left:4px solid #e53e3e; }
  .transfer-title { font-family:'Poppins',sans-serif; font-weight:700; font-size:0.88rem; color:#e53e3e; margin-bottom:12px; }
  .transfer-info { background:#fff; border-radius:8px; padding:12px 14px; font-size:12px; }
  .transfer-name { font-weight:700; margin-bottom:2px; }
  .transfer-sub  { color:var(--text-sm); font-size:11px; margin-bottom:10px; }
  .transfer-btns { display:flex; gap:8px; }
  .active-cust-card { background:var(--white); border-radius:var(--radius); padding:18px; box-shadow:var(--shadow); flex:1; }
  .cust-list { display:flex; flex-direction:column; gap:8px; margin-top:12px; max-height:280px; overflow-y:auto; }
  .cust-row { display:flex; justify-content:space-between; align-items:center; padding:10px 12px; background:var(--cream-lt); border-radius:8px; cursor:pointer; transition:0.15s; }
  .cust-row:hover { background:#f0fdf4; }
  .cust-row-name { font-weight:700; font-size:12px; margin-bottom:2px; }
  .cust-row-sub  { font-size:11px; color:var(--text-sm); }
  .detail-panel { background:var(--white); border-radius:var(--radius); padding:20px; box-shadow:var(--shadow); border-left:4px solid var(--orange); margin-top:4px; }
  .detail-name { font-family:'Poppins',sans-serif; font-size:1.1rem; font-weight:700; margin-bottom:4px; }
  .detail-meta { font-size:12px; color:var(--text-sm); margin-bottom:14px; }
  
  .canvas-viewport { width: 100%; height: 500px; overflow: auto; background: #f8fafc; border: 1.5px solid var(--border); border-radius: 10px; position: relative; display: flex; justify-content: center; align-items: flex-start; padding: 10px; }
  .canvas-board { position: relative; width: 800px; height: 450px; background: #f0f4f8; background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 20px 20px; cursor: default; transform-origin: 0 0; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
  .fp-item { position: absolute; user-select: none; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  
  .item-visual {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, background-color 0.3s ease;
  }

  .item-visual.chair-icon {
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }

  .fp-item .item-label {
    position: absolute;
    top: calc(100% + 4px);
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Poppins', sans-serif;
    font-size: 9px;
    font-weight: 700;
    color: #475569;
    white-space: nowrap;
    pointer-events: none;
    z-index: 10;
  }

  .fp-item .item-label.center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 10px;
  }
  
  .map-legend div span {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin-right: 4px;
  }

  @media(max-width:1100px){ .seat-page{grid-template-columns:1fr;} }
  
</style>

<div class="app">
    <%- include('../partials/staff_sidebar', { active: 'Seat Management' }) %>

    <div class="mobile-overlay" id="mobileOverlay" onclick="closeSidebar()"></div>
    
    <main class="content">
      <button class="mobile-menu-btn" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>

      <div class="page-header" style="display:flex;justify-content:space-between;align-items:center">
        <div>
          <h1 class="page-title" style="margin:0">Seat Management</h1>
          <p style="font-size:12px;color:var(--text-sm)">Real-time status tracking</p>
        </div>
      </div>
      <div class="seat-page">
        <div class="card" style="padding:0;overflow:hidden;box-shadow:var(--shadow-md);border:none;background:rgba(255,255,255,0.7);backdrop-filter:blur(5px)">
          
          <div class="map-legend" style="display:flex;gap:12px;padding:8px 12px;background:rgba(255,255,255,0.6);border-radius:8px;font-size:10px;font-weight:600;margin-bottom:10px;">
            <div><span style="background:#10b981"></span>Available</div>
            <div><span style="background:#d65c29"></span>Taken</div>
            <div><span style="background:#1e293b"></span>Reserved</div>
            <div><span style="background:#facc15"></span>Idle</div>
            <div><span style="background:#22c55e"></span>Meeting Room</div>
            <span style="color:var(--orange)"><i class="fa-solid fa-hand-pointer" style="font-size:9px"></i> Click seat to view details</span>
          </div>
          
          <div class="canvas-viewport">
            <div class="canvas-board mode-select" id="canvas"></div>
          </div>
        </div>
        <div class="right-col">
          <div class="transfer-card">
            <div class="transfer-title"><i class="fa-solid fa-arrow-right-arrow-left"></i> Transfer Seat Request</div>
            <div class="transfer-info">
              <div class="transfer-name">Monkey D. Luffy</div>
              <div class="transfer-sub">Current: T3-S1 → Requested: RT2-S2</div>
              <div class="transfer-btns">
                <button class="btn btn-success btn-sm" onclick="acceptTransfer()" style="flex:1"><i class="fa-solid fa-check"></i> Accept</button>
                <button class="btn btn-danger btn-sm"  onclick="declineTransfer()" style="flex:1"><i class="fa-solid fa-xmark"></i> Decline</button>
              </div>
            </div>
          </div>
          <div class="active-cust-card">
            <div class="section-title"><i class="fa-solid fa-users"></i> Active Customers</div>
            <div class="cust-list" id="custList"></div>
          </div>
        </div>
      </div>
      <div class="detail-panel" id="detailPanel" style="display:none">
        <div class="detail-name" id="detailName"></div>
        <div class="detail-meta" id="detailMeta"></div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <button class="btn btn-primary btn-sm" onclick="doTransfer()"><i class="fa-solid fa-arrow-right-arrow-left"></i> Transfer Seat</button>
          <button class="btn btn-ghost btn-sm" onclick="closeDetail()"><i class="fa-solid fa-xmark"></i> Close</button>
        </div>
      </div>
      <p id="hintText" style="text-align:center;color:var(--text-sm);font-size:12px;margin-top:12px;opacity:0.8">
        <i class="fa-regular fa-hand-pointer"></i> Click a seat or customer to view details
      </p>
    </main>
  </div>

<%- contentFor('script') %>
<script>
function confirmLogout(){
  if(confirm('Are you sure you want to logout?')){
    setTimeout(()=>location.reload(),1500);
  }
}

function openSidebar(){
  document.getElementById('sidebar').classList.add('mobile-open');
  document.getElementById('mobileOverlay').classList.add('show');
}

function closeSidebar(){
  document.getElementById('sidebar').classList.remove('mobile-open');
  document.getElementById('mobileOverlay').classList.remove('show');
}

const customers = [
  {seat:'T3-S1',name:'Monkey D. Luffy',time:'09:30 AM'},
  {seat:'T3-S5',name:'Nami Catburglar',time:'10:15 AM'},
  {seat:'T3-S6',name:'Sanji Vinsmoke',time:'11:00 AM'},
  {seat:'RT1-S2',name:'Zoro Roronoa',time:'08:45 AM'},
  {seat:'RT2-S1',name:'Jinbe',time:'09:50 AM'},
  {seat:'C1-S2',name:'Brook',time:'09:10 AM'},
  {seat:'RT3-S1',name:'Franky',time:'10:30 AM'},
  {seat:'RT3-S4',name:'Robin',time:'08:00 AM'},
];

function showDetail(name,seat,time){
  document.getElementById('detailName').textContent = name;
  document.getElementById('detailMeta').innerHTML = `Seat: <strong>${seat}</strong> · Started: ${time}`;
  document.getElementById('detailPanel').style.display = 'block';
  document.getElementById('hintText').style.display = 'none';
}

function closeDetail(){
  document.getElementById('detailPanel').style.display = 'none';
  document.getElementById('hintText').style.display = 'block';
}

function doTransfer(){
  const n=document.getElementById('detailName').textContent;
  if(confirm(`Transfer seat for ${n}?`)){
    closeDetail();
  }
}

function acceptTransfer(){
  if(confirm('Accept this transfer request?')){

  }
}

function declineTransfer(){
  if(confirm('Decline this transfer request?')){

  }
}

function buildList(){
  const el = document.getElementById('custList'); 
  el.innerHTML='';
  
  customers.forEach(c=>{
    const d=document.createElement('div'); 
    d.className='cust-row';
    
    d.innerHTML=`
      <div>
        <div class="cust-row-name">${c.name}</div>
        <div class="cust-row-sub">
          <i class="fa-solid fa-couch" style="font-size:10px"></i> ${c.seat} · ${c.time}
        </div>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();doTransferFor('${c.name}')">
        <i class="fa-solid fa-arrow-right-arrow-left"></i>
      </button>
    `;
    
    d.onclick=()=>showDetail(c.name,c.seat,c.time);
    el.appendChild(d);
  });
}

function doTransferFor(name){
  if(confirm(`Transfer seat for ${name}?`)){
  }
}

let items = [];

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

async function loadLayout() {
  try {
    const res = await fetch('/api/layout');
    const data = await res.json();
    if (data && data.items) {
      items = data.items;
      renderCanvas();
    }
  } catch (e) {
    console.error(e);
  }
}

function renderCanvas() {
  const canvas = document.getElementById('canvas');
  canvas.innerHTML = '';
  items.forEach(item => {
    const el = document.createElement('div');
    el.className = 'fp-item';
    el.style.left = item.x + 'px';
    el.style.top = item.y + 'px';
    el.style.width = item.w + 'px';
    el.style.height = item.h + 'px';
    el.style.zIndex = (item.type === 'chair' || item.type === 'chair-sq') ? 5 : item.type.startsWith('block') ? 2 : 3;

    const visual = document.createElement('div');
    visual.className = 'item-visual';
    visual.style.transform = 'rotate(' + (item.rot || 0) + 'deg)';

    if (item.type === 'chair') {
      visual.classList.add('chair-icon');
      visual.style.webkitMaskImage = 'url(/images/chair.png)';
      visual.style.maskImage = 'url(/images/chair.png)';
      const status = item.statuses ? item.statuses[0] : 'open';
      if (status === 'taken') visual.style.backgroundColor = '#d65c29';
      else if (status === 'reserved') visual.style.backgroundColor = '#1e293b';
      else if (status === 'idle') visual.style.backgroundColor = '#facc15';
      else visual.style.backgroundColor = '#10b981';
      el.onclick = (e) => { e.stopPropagation(); showDetail(item.label || 'Seat', item.label, '9:30 AM'); };
    } else if (item.type === 'chair-sq') {
      const status = item.statuses ? item.statuses[0] : 'open';
      const sqColor = status === 'taken' ? '#d65c29' : status === 'reserved' ? '#1e293b' : status === 'idle' ? '#facc15' : '#10b981';
      visual.style.background = sqColor;
      visual.style.borderRadius = '6px';
      visual.style.border = '2px solid #8B4513';
      el.onclick = (e) => { e.stopPropagation(); showDetail(item.label || 'Seat', item.label, '9:30 AM'); };
    } else if (item.type === 'round-table') {
      visual.style.background = item.color;
      visual.style.borderRadius = '50%';
      visual.style.border = '2px solid #f97316';
    } else if (item.type === 'rect-table') {
      visual.style.background = item.color;
      visual.style.borderRadius = '8px';
      visual.style.border = '2px solid #f97316';
    } else if (item.type === 'room') {
      const status = item.statuses ? item.statuses[0] : 'open';
      const roomColor = status === 'taken' ? '#9ca3af' : status === 'reserved' ? '#ef4444' : item.color;
      visual.style.background = roomColor;
      visual.style.borderRadius = '8px';
      visual.style.border = '2px solid #16a34a';
      el.onclick = (e) => { e.stopPropagation(); showDetail(item.label || 'Room', item.label, '9:30 AM'); };
    } else {
      visual.style.background = item.color;
      visual.style.borderRadius = '4px';
      if (item.color === '#22c55e') visual.style.border = '2px solid #16a34a';
      else if (item.color === '#fde68a') visual.style.border = '1.5px solid #f59e0b';
    }
    el.appendChild(visual);

    if (item.label || item.type === 'room') {
      const lbl = document.createElement('span');
      lbl.className = 'item-label';
      if (item.type !== 'chair' && item.type !== 'chair-sq') {
        lbl.classList.add('center');
        const status = item.statuses ? item.statuses[0] : 'open';
        const isDark = (item.color === '#22c55e' || status === 'taken' || status === 'reserved');
        lbl.style.color = isDark ? '#fff' : '#1e293b';
      } else if (item.type === 'chair-sq') {
        lbl.classList.add('center');
        const status = item.statuses ? item.statuses[0] : 'open';
        const isDark = (status === 'taken' || status === 'reserved');
        lbl.style.color = isDark ? '#fff' : '#1e293b';
      }
      lbl.textContent = item.label || (item.type === 'room' ? 'Room' : '');
      el.appendChild(lbl);
    }
    canvas.appendChild(el);
  });
}

window.onload = () => {
  buildList();
  loadLayout();
};
</script>
