<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- typeof title !== 'undefined' ? title : 'The Last Muster' %></title>
  
  <!-- Global Styles -->
  <link rel="stylesheet" href="/stylesheets/<%= typeof role !== 'undefined' ? role : 'main' %>.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <!-- Chart.js (available globally for all pages) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>

  <!-- Page Specific Head Scripts (e.g. additional CDN libs) -->
  <%- typeof head !== 'undefined' ? head : '' %>

  <!-- Page Specific Styles -->
  <%- typeof style !== 'undefined' ? style : '' %>

</head>
<body>
  
  <!-- Main Application Body -->
  <%- body %>

  <!-- Page Specific Scripts -->
  <%- typeof script !== 'undefined' ? script : '' %>
</body>

</html>
