<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- typeof title !== 'undefined' ? title : 'The Last Muster' %></title>
  
  <!-- global styles function -->
  <link rel="stylesheet" href="/stylesheets/<%= typeof role !== 'undefined' ? role : 'main' %>.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <!-- chart.js (available globally for all pages) function -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>

  <!-- page specific head scripts (e.g. additional cdn libs) function -->
  <%- typeof head !== 'undefined' ? head : '' %>

  <!-- page specific styles function -->
  <%- typeof style !== 'undefined' ? style : '' %>

</head>
<body>
  
  <!-- main application body function -->
  <%- body %>

  <!-- global logout script function -->
  <script>
    function handleLogout() {
      window.location.href = '/login/logout';
    }
  </script>

  <!-- page specific scripts function -->
  <%- typeof script !== 'undefined' ? script : '' %>

  <!-- global scripts function -->
  <script>
    function confirmLogout() {
      if (confirm('Are you sure you want to logout?')) {
        window.location.href = '/login';
      }
    }
  </script>
</body>

</html>

