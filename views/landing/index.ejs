  <!-- ═══════════════════════ TERMS MODAL ═══════════════════════ -->
  <div id="termsModal" class="modal">
    <div class="modal-card">
      <span class="modal-close-card" onclick="closeTermsModal()">&times;</span>
      <div class="modal-header">
        <div class="section-tag tag-orange"><i class="fas fa-file-contract"></i> LEGAL</div>
        <h2 class="modal-title">Terms & Conditions</h2>
        <p class="modal-subtitle">House Rules for a Safe & Productive Community</p>
      </div>
      <div class="modal-body">
        <ul class="rules-list">
          <li><strong>Respect the space:</strong> Treat the furniture, and equipment with care.</li>
          <li><strong>Privacy:</strong> Respect other members' belongings and privacy.</li>
          <li><strong>Consideration:</strong> Keep conversations at a considerate volume.</li>
          <li><strong>Cleanliness:</strong> Maintain cleanliness at your desk or shared area.</li>
          <li><strong>Waste:</strong> Dispose of trash properly. We have trash bins near the pantry.</li>
          <li><strong>Headphones:</strong> Use headphones for music, videos, and online meetings.</li>
          <li><strong>Calls:</strong> Keep phone calls short and soft-spoken in open areas.</li>
          <li><strong>Collaboration:</strong> Book a meeting/huddle room for group discussions.</li>
          <li><strong>Equitable use:</strong> Do not hog desks, outlets, or equipment unnecessarily.</li>
