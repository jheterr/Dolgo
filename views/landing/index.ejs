<%- contentFor('script') %>
<script>
    // Mobile navigation toggle
    function toggleMobileNav() {
      document.getElementById('navLinks').classList.toggle('mobile-open');
    }

    // Close mobile nav when a link is clicked
    document.querySelectorAll('.nav-links a').forEach(link => {
      link.addEventListener('click', () => {
        document.getElementById('navLinks').classList.remove('mobile-open');
      });
    });

    // Quick Reserve time slot selection
    function selectTime(el) {
      document.querySelectorAll('.time-slot').forEach(s => s.classList.remove('selected'));
      el.classList.add('selected');
    }

    function reserveNow() {
      const selected = document.querySelector('.time-slot.selected');
      if (selected) {
        alert('Reservation request sent for ' + selected.textContent + '! We\'ll confirm shortly via message.');
      } else {
        alert('Please select a time slot first.');
      }
    }

    // Navbar scroll effect
    window.addEventListener('scroll', () => {
      const navbar = document.getElementById('navbar');
      if (window.scrollY > 50) {
        navbar.style.boxShadow = '0 4px 30px rgba(0,0,0,0.35)';
      } else {
        navbar.style.boxShadow = '0 2px 20px rgba(0,0,0,0.25)';
      }
    });

    // Image Modal Functions
    function openModal(imgSrc) {
      const modal = document.getElementById('imageModal');
      const modalImg = document.getElementById('modalImg');
      modal.classList.add('show');
      modalImg.src = imgSrc;
      document.body.style.overflow = 'hidden'; // Prevent scroll
    }

    function closeModal() {
      const modal = document.getElementById('imageModal');
      modal.classList.remove('show');
      document.body.style.overflow = ''; // Allow scroll
    }

    // Terms Modal Functions
    function openTermsModal() {
      const modal = document.getElementById('termsModal');
      modal.classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    function closeTermsModal() {
      const modal = document.getElementById('termsModal');
      modal.classList.remove('show');
      document.body.style.overflow = '';
    }

    // Add event listeners to gallery images
    document.querySelectorAll('.gallery-track img').forEach(img => {
      img.addEventListener('click', () => {
        openModal(img.src);
      });
    });

    // Close modal on click outside
    window.addEventListener('click', (event) => {
      const imgModal = document.getElementById('imageModal');
      const termsModal = document.getElementById('termsModal');
      if (event.target == imgModal) {
        closeModal();
      }
      if (event.target == termsModal) {
        closeTermsModal();
      }
    });

    // Scroll animations — IntersectionObserver
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.animate-in').forEach(el => observer.observe(el));
  </script>

