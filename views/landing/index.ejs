  <!-- ═══════════════════════ RESERVE ═══════════════════════ -->
  <section class="section reserve" id="reserve">
    <div class="animate-in">
      <div class="section-tag tag-orange"><i class="fas fa-calendar-alt"></i> RESERVATIONS</div>
      <h2 class="section-heading">RESERVE YOUR SPOT<br>BEFORE YOU ARRIVE.</h2>
      <p class="section-subtitle">Secure your preferred time slot so your seat is always ready when you walk in.</p>
    </div>

    <div class="reserve-layout">
      <div class="reserve-steps animate-in">
        <div class="reserve-step">
          <div class="step-icon si-blue"><i class="fas fa-user"></i></div>
          <div class="step-text">
            <h4>Log in to Your Account</h4>
            <p>Use your The Last Muster credentials to access the reservation system anytime.</p>
          </div>
        </div>
        <div class="reserve-step">
          <div class="step-icon si-green"><i class="fas fa-calendar-day"></i></div>
          <div class="step-text">
            <h4>Pick a Date & Time</h4>
            <p>Choose your preferred date and available time slot from the booking calendar.</p>
          </div>
        </div>
        <div class="reserve-step">
          <div class="step-icon si-olive"><i class="fas fa-chair"></i></div>
          <div class="step-text">
            <h4>Select Your Seat</h4>
            <p>Pick from open seats or cozy nooks based on your work style.</p>
          </div>
        </div>
        <div class="reserve-step">
          <div class="step-icon si-orange"><i class="fas fa-check-circle"></i></div>
          <div class="step-text">
            <h4>Confirm & Walk In</h4>
            <p>Get a confirmation code. Show it at the front desk and your seat is ready.</p>
          </div>
        </div>
      </div>

      <div class="quick-reserve animate-in">
        <h3>Quick Reserve</h3>
        <p class="qr-sub">Select a time slot for today's session</p>
        <div class="time-grid">
          <button class="time-slot" onclick="selectTime(this)">09:00 AM</button>
          <button class="time-slot" onclick="selectTime(this)">10:00 AM</button>
          <button class="time-slot" onclick="selectTime(this)">11:00 AM</button>
          <button class="time-slot" onclick="selectTime(this)">12:00 PM</button>
          <button class="time-slot" onclick="selectTime(this)">01:00 PM</button>
          <button class="time-slot" onclick="selectTime(this)">02:00 PM</button>
          <button class="time-slot" onclick="selectTime(this)">03:00 PM</button>
          <button class="time-slot" onclick="selectTime(this)">04:00 PM</button>
          <button class="time-slot" onclick="selectTime(this)">05:00 PM</button>
        </div>
        <button class="btn-reserve" onclick="reserveNow()">Reserve Now</button>
      </div>
    </div>
  </section>

